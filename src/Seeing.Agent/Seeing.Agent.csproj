<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Seeing.Agent</RootNamespace>
    <AssemblyName>Seeing.Agent</AssemblyName>
    
    <!-- NuGet 包信息 -->
    <PackageId>Seeing.Agent</PackageId>
    <Version>1.0.0</Version>
    <Authors>Seeing.Agent Team</Authors>
    <Description>A complete AI Agent framework with Skill, SubAgent, Rules, Hook and Extension support</Description>
    <PackageTags>AI;Agent;LLM;Skill;Tool;Hook;MCP</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <RepositoryUrl>https://github.com/seeing-agent/seeing-agent</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    
    <!-- 编译选项 -->
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <WarningLevel>4</WarningLevel>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
    <!-- OpenAI SDK：文件 / 输入音频等多模态 API 仍带实验性诊断 OPENAI001 -->
    <NoWarn>$(NoWarn);OPENAI001</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <!-- 核心依赖 -->
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Configuration" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Json" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Binder" />
    <PackageReference Include="Microsoft.Extensions.Logging" />
    <PackageReference Include="Microsoft.Extensions.Logging.Console" />
    <PackageReference Include="Microsoft.Extensions.Options" />
    <PackageReference Include="Microsoft.Extensions.Options.ConfigurationExtensions" />
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" />
    
    <!-- 缓存支持 -->
    <PackageReference Include="Microsoft.Extensions.Caching.Memory" />
    
    <!-- HTTP 和弹性策略 -->
    <PackageReference Include="Microsoft.Extensions.Http" />
    <PackageReference Include="Microsoft.Extensions.Http.Polly" />
    
    <!-- MCP 协议支持 -->
    <PackageReference Include="ModelContextProtocol.Core" />
    
    <!-- LLM SDK 支持 -->
    <PackageReference Include="OpenAI" />
    <PackageReference Include="YamlDotNet" />
    <ProjectReference Include="..\\Seeing.Session\\Seeing.Session.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\..\README.md" Pack="true" PackagePath="\" Condition="Exists('..\..\README.md')" />
  </ItemGroup>

</Project>
