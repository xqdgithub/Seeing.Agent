@using AntDesign
@using System.Text.Json
@using Seeing.Agent.WebUI.Models

<div class="tool-call-compact"
     style="display: flex; align-items: center; padding: 4px 8px; background: var(--color-bg-secondary); border-radius: var(--radius-sm); margin: 4px 0; cursor: pointer;"
     onclick="@ToggleExpand">
     
     <!-- 状态图标 -->
     <Icon Type="@GetStatusIcon()" 
           Style="@GetStatusIconStyle()" />
     
     <!-- 工具名称 -->
     <span style="margin-left: 6px; font-weight: 500; font-size: 13px;">
         @ToolCall.Name
     </span>
     
     <!-- 状态标签 -->
     <Tag Color="@GetStatusColor()"
          Style="margin-left: 6px; font-size: 11px;">
         @GetStatusText()
     </Tag>
     
     <!-- 简要结果/错误预览 -->
     @if (!string.IsNullOrEmpty(ToolCall.Result))
     {
         <span style="margin-left: 8px; color: var(--color-success); font-size: 12px; max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
             @GetResultPreview()
         </span>
     }
     else if (!string.IsNullOrEmpty(ToolCall.Error))
     {
         <span style="margin-left: 8px; color: var(--color-error); font-size: 12px; max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
             @GetErrorPreview()
         </span>
     }
     
     <!-- 执行中动画 -->
     @if (ToolCall.Status == "running" || ToolCall.Status == "pending")
     {
         <Spin Size="@SpinSize.Small" Style="margin-left: 8px;" />
     }
     
     <!-- 展开/收起指示 -->
     <Icon Type="@(_isExpanded ? IconType.Outline.Down : IconType.Outline.Right)"
           Style="margin-left: auto; font-size: 12px; color: var(--color-text-tertiary);" />
</div>

<!-- 详情展开区域 -->
@if (_isExpanded)
{
    <div Style="padding: 8px 12px; background: var(--color-bg-tertiary); border-radius: var(--radius-sm); margin-top: 2px;">
        
        <!-- 参数 -->
        @if (!string.IsNullOrEmpty(ToolCall.Parameters) && ToolCall.Parameters != "{}")
        {
            <div Style="margin-bottom: 4px;">
                <span Style="font-size: 11px; color: var(--color-text-secondary);">参数: </span>
                <span Style="font-size: 12px; color: var(--color-text);">@FormatParametersBrief()</span>
            </div>
        }
        
        <!-- 结果 -->
        @if (!string.IsNullOrEmpty(ToolCall.Result))
        {
            <div>
                <span Style="font-size: 11px; color: var(--color-success);">结果: </span>
                <pre Style="font-size: 12px; margin: 0; white-space: pre-wrap; word-break: break-all; max-height: 150px; overflow: auto;">@TruncateResult(ToolCall.Result, 500)</pre>
            </div>
        }
        
        <!-- 错误 -->
        @if (!string.IsNullOrEmpty(ToolCall.Error))
        {
            <div>
                <span Style="font-size: 11px; color: var(--color-error);">错误: </span>
                <pre Style="font-size: 12px; margin: 0; color: var(--color-error); white-space: pre-wrap;">@ToolCall.Error</pre>
            </div>
        }
    </div>
}

@code {
    /// <summary>
    /// 工具调用数据
    /// </summary>
    [Parameter]
    public ToolCallViewModel ToolCall { get; set; } = new();
    
    /// <summary>
    /// 内部展开状态（避免修改 Parameter 属性）
    /// </summary>
    private bool _isExpanded = false;
    
    /// <summary>
    /// 切换展开状态
    /// </summary>
    private void ToggleExpand()
    {
        _isExpanded = !_isExpanded;
    }
    
    /// <summary>
    /// 获取状态图标
    /// </summary>
    private string GetStatusIcon()
    {
        return ToolCall.Status?.ToLowerInvariant() switch
        {
            "pending" => IconType.Outline.ClockCircle,
            "running" => IconType.Outline.Loading,
            "success" => IconType.Outline.CheckCircle,
            "failed" => IconType.Outline.CloseCircle,
            "rejected" => IconType.Outline.Stop,
            _ => IconType.Outline.QuestionCircle
        };
    }
    
    /// <summary>
    /// 获取状态图标样式
    /// </summary>
    private string GetStatusIconStyle()
    {
        return ToolCall.Status?.ToLowerInvariant() switch
        {
            "pending" => "color: var(--color-warning); font-size: 14px;",
            "running" => "color: var(--color-primary); font-size: 14px; animation: spin 1s linear infinite;",
            "success" => "color: var(--color-success); font-size: 14px;",
            "failed" => "color: var(--color-error); font-size: 14px;",
            "rejected" => "color: var(--color-text-tertiary); font-size: 14px;",
            _ => "color: var(--color-text-tertiary); font-size: 14px;"
        };
    }
    
    /// <summary>
    /// 获取状态颜色
    /// </summary>
    private string GetStatusColor()
    {
        return ToolCall.Status?.ToLowerInvariant() switch
        {
            "pending" => "warning",
            "running" => "processing",
            "success" => "success",
            "failed" => "error",
            "rejected" => "default",
            _ => "default"
        };
    }
    
    /// <summary>
    /// 获取状态文本
    /// </summary>
    private string GetStatusText()
    {
        return ToolCall.Status?.ToLowerInvariant() switch
        {
            "pending" => "等待",
            "running" => "执行中",
            "success" => "完成",
            "failed" => "失败",
            "rejected" => "拒绝",
            _ => ToolCall.Status ?? "未知"
        };
    }
    
    /// <summary>
    /// 获取结果预览（第一行，最多 40 字符）
    /// </summary>
    private string GetResultPreview()
    {
        if (string.IsNullOrEmpty(ToolCall.Result)) return "";
        var firstLine = ToolCall.Result.Split('\n')[0].Trim();
        if (firstLine.StartsWith("{") || firstLine.StartsWith("["))
        {
            // JSON 结果，尝试提取关键信息
            try
            {
                var element = JsonSerializer.Deserialize<JsonElement>(ToolCall.Result);
                if (element.ValueKind == JsonValueKind.Object)
                {
                    // 提取第一个属性值
                    var firstProp = element.EnumerateObject().FirstOrDefault();
                    if (firstProp.Value.ValueKind == JsonValueKind.String)
                        return firstProp.Value.GetString() ?? firstLine[..Math.Min(40, firstLine.Length)];
                }
            }
            catch { }
        }
        if (firstLine.Length > 40) return firstLine[..40] + "...";
        return firstLine;
    }
    
    /// <summary>
    /// 获取错误预览（最多 40 字符）
    /// </summary>
    private string GetErrorPreview()
    {
        if (string.IsNullOrEmpty(ToolCall.Error)) return "";
        if (ToolCall.Error.Length > 40) return ToolCall.Error[..40] + "...";
        return ToolCall.Error;
    }
    
    /// <summary>
    /// 格式化参数简要显示
    /// </summary>
    private string FormatParametersBrief()
    {
        if (string.IsNullOrEmpty(ToolCall.Parameters)) return "";
        
        try
        {
            var element = JsonSerializer.Deserialize<JsonElement>(ToolCall.Parameters);
            if (element.ValueKind == JsonValueKind.Object)
            {
                // 只显示键名，不显示值
                var keys = element.EnumerateObject().Select(p => p.Name).Take(5);
                var result = string.Join(", ", keys);
                if (element.EnumerateObject().Count() > 5)
                    result += "...";
                return result;
            }
            return ToolCall.Parameters.Length > 50 
                ? ToolCall.Parameters[..50] + "..." 
                : ToolCall.Parameters;
        }
        catch
        {
            return ToolCall.Parameters.Length > 50 
                ? ToolCall.Parameters[..50] + "..." 
                : ToolCall.Parameters;
        }
    }
    
    /// <summary>
    /// 截断结果文本
    /// </summary>
    private string TruncateResult(string text, int maxLength)
    {
        if (string.IsNullOrEmpty(text)) return "";
        if (text.Length <= maxLength) return text;
        return text[..maxLength] + "...(更多内容已省略)";
    }
}