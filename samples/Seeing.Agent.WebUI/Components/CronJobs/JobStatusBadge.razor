@using AntDesign
@using Seeing.Agent.Scheduler.Models

@code {
    [Parameter] public JobState State { get; set; }
    [Parameter] public bool ShowText { get; set; } = true;
}

@{
    var (color, icon, text) = GetStateDisplay(State);
}

<Tag Color="@color">
    @if (ShowText)
    {
        <Icon Type="@icon" />
        @text
    }
    else
    {
        <Icon Type="@icon" />
    }
</Tag>

@code {
    private static (string color, string icon, string text) GetStateDisplay(JobState state) => state switch
    {
        JobState.Normal => ("green", IconType.Outline.CheckCircle, "正常"),
        JobState.Running => ("blue", IconType.Outline.Sync, "运行中"),
        JobState.Paused => ("orange", IconType.Outline.PauseCircle, "已暂停"),
        JobState.Completed => ("default", IconType.Outline.CheckCircle, "已完成"),
        JobState.Error => ("red", IconType.Outline.CloseCircle, "错误"),
        JobState.Blocked => ("purple", IconType.Outline.Lock, "阻塞"),
        _ => ("default", IconType.Outline.QuestionCircle, "未知")
    };
}