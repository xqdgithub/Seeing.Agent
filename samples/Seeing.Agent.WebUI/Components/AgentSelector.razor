@using AntDesign
@using Seeing.Agent.WebUI.State
@inject AppState AppState
@implements IDisposable

@if (!Collapsed)
{
  <div class="agent-selector" style="padding: 12px 16px; border-bottom: 1px solid var(--color-border, #f0f0f0);">
    <div style="font-size: 12px; color: var(--color-text-secondary, #8c8c8c); margin-bottom: 4px;">当前智能体</div>
    @if (_agentNames.Count > 0)
    {
      <Select TItemValue="string" TItem="string"
              Style="width: 100%;"
              Value="@AppState.SelectedAgent"
              ValueExpression="@(() => AppState.SelectedAgent)"
              ValueChanged="@OnAgentChanged"
              DataSource="@_agentNames"
              Placeholder="选择智能体" />
    }
    else
    {
      <Input ReadOnly Value="@(AppState.SelectedAgent)" Placeholder="加载中..." />
    }
  </div>
}
else
{
  <Tooltip Title="@($"智能体: {AppState.SelectedAgent}")" Placement="@Placement.Right">
    <div style="text-align: center; padding: 12px 0; border-bottom: 1px solid var(--color-border, #f0f0f0);">
      <Icon Type="@IconType.Outline.Robot" Style="font-size: 20px;" />
    </div>
  </Tooltip>
}

@code {
  [Parameter] public bool Collapsed { get; set; }

  private List<string> _agentNames = new();

  protected override void OnInitialized()
  {
    AppState.OnChange += OnAppStateChange;
    RefreshOptions();
  }

  private void OnAppStateChange()
  {
    RefreshOptions();
    _ = InvokeAsync(StateHasChanged);
  }

  private void RefreshOptions()
  {
    _agentNames = AppState.AvailableAgents
      .Where(a => !string.IsNullOrEmpty(a.Name))
      .Select(a => a.Name)
      .ToList();
  }

  private void OnAgentChanged(string value)
  {
    var agent = value ?? "";
    if (!string.IsNullOrEmpty(agent) && !_agentNames.Contains(agent))
      agent = _agentNames.FirstOrDefault() ?? agent;
    AppState.SelectedAgent = agent;
    AppState.NotifyChange();
  }

  public void Dispose() => AppState.OnChange -= OnAppStateChange;
}
