@using AntDesign
@using Microsoft.AspNetCore.Components.Routing
@using Seeing.Agent.WebUI.State
@implements IDisposable
@inject AppState AppState
@inject NavigationManager NavigationManager

<Sider Class="app-sider"
       Width="@GetSiderWidth()"
       Collapsed="@Collapsed"
       CollapsedChanged="@OnCollapsedChanged"
       Theme="@SiderTheme.Light"
       Style="overflow: auto; height: 100vh; position: fixed; left: 0; top: 0; z-index: 100;">
    <div class="sider-header">
        @if (!Collapsed)
        {
            <div class="logo-section">
                <img src="ai.svg" alt="Seeing.Agent" class="app-logo" width="24" height="24" />
                <span class="logo-text">Seeing.Agent</span>
            </div>
        }
        else
        {
            <Tooltip Title="Seeing.Agent" Placement="@Placement.Right">
                <img src="ai.svg" alt="Seeing.Agent" class="app-logo app-logo-collapsed" width="24" height="24" />
            </Tooltip>
        }
    </div>

    <Menu Mode="@MenuMode.Inline"
          Theme="@MenuTheme.Light"
          SelectedKeys="@_selectedKeys"
          @bind-OpenKeys="_openKeys"
          Class="sider-menu">

        <MenuItem Key="chat" OnClick="@(() => NavigateTo(GetChatPath()))">
            <Icon Type="@IconType.Outline.Message" />
            <span>聊天</span>
        </MenuItem>

        <SubMenu Key="control">
            <TitleTemplate>
                <Icon Type="@IconType.Outline.Control" />
                <span>控制中心</span>
            </TitleTemplate>
            <ChildContent>
                <MenuItem Key="sessions" OnClick="@(() => NavigateTo("/sessions"))">
                    <Icon Type="@IconType.Outline.Team" />
                    <span>会话</span>
                </MenuItem>
                <MenuItem Key="cron-jobs" OnClick="@(() => NavigateTo("/cron-jobs"))">
                    <Icon Type="@IconType.Outline.ClockCircle" />
                    <span>定时任务</span>
                </MenuItem>
                <MenuItem Key="heartbeat" OnClick="@(() => NavigateTo("/heartbeat"))">
                    <Icon Type="@IconType.Outline.Heart" />
                    <span>心跳</span>
                </MenuItem>
            </ChildContent>
        </SubMenu>

        <SubMenu Key="workspace">
            <TitleTemplate>
                <Icon Type="@IconType.Outline.Folder" />
                <span>工作区</span>
            </TitleTemplate>
            <ChildContent>
                <MenuItem Key="skills" OnClick="@(() => NavigateTo("/skills"))">
                    <Icon Type="@IconType.Outline.Star" />
                    <span>技能</span>
                </MenuItem>
                <MenuItem Key="tools" OnClick="@(() => NavigateTo("/tools"))">
                    <Icon Type="@IconType.Outline.Tool" />
                    <span>工具</span>
                </MenuItem>
                <MenuItem Key="mcp" OnClick="@(() => NavigateTo("/mcp"))">
                    <Icon Type="@IconType.Outline.Api" />
                    <span>MCP</span>
                </MenuItem>
                <MenuItem Key="acp" OnClick="@(() => NavigateTo("/acp"))">
                    <Icon Type="@IconType.Outline.Robot" />
                    <span>ACP</span>
                </MenuItem>
                <MenuItem Key="memory" OnClick="@(() => NavigateTo("/memory"))">
                    <Icon Type="@IconType.Outline.Database" />
                    <span>记忆</span>
                </MenuItem>
                <MenuItem Key="agent-config" OnClick="@(() => NavigateTo("/agent-config"))">
                    <Icon Type="@IconType.Outline.Setting" />
                    <span>智能体配置</span>
                </MenuItem>
            </ChildContent>
        </SubMenu>

        <SubMenu Key="settings">
            <TitleTemplate>
                <Icon Type="@IconType.Outline.Setting" />
                <span>设置</span>
            </TitleTemplate>
            <ChildContent>
                <MenuItem Key="agents" OnClick="@(() => NavigateTo("/agents"))">
                    <Icon Type="@IconType.Outline.UsergroupAdd" />
                    <span>智能体管理</span>
                </MenuItem>
                <MenuItem Key="models" OnClick="@(() => NavigateTo("/models"))">
                    <Icon Type="@IconType.Outline.CloudServer" />
                    <span>模型</span>
                </MenuItem>
                <MenuItem Key="gateway" OnClick="@(() => NavigateTo("/gateway"))">
                    <Icon Type="@IconType.Outline.Global" />
                    <span>Gateway</span>
                </MenuItem>
                <MenuItem Key="gateway-clients" OnClick="@(() => NavigateTo("/gateway-clients"))">
                    <Icon Type="@IconType.Outline.Api" />
                    <span>Gateway 客户端</span>
                </MenuItem>
                <MenuItem Key="security" OnClick="@(() => NavigateTo("/security"))">
                    <Icon Type="@IconType.Outline.Lock" />
                    <span>安全</span>
                </MenuItem>
                <MenuItem Key="settings-page" OnClick="@(() => NavigateTo("/settings"))">
                    <Icon Type="@IconType.Outline.Tool" />
                    <span>系统设置</span>
                </MenuItem>
            </ChildContent>
        </SubMenu>
    </Menu>
</Sider>

@code {
    [Parameter] public bool Collapsed { get; set; }
    [Parameter] public EventCallback<bool> CollapsedChanged { get; set; }

    private string[] _selectedKeys = Array.Empty<string>();
    private string[] _openKeys = new[] { "control", "workspace", "settings" };

    protected override void OnInitialized()
    {
        AppState.OnChange += OnAppStateChange;
        NavigationManager.LocationChanged += OnLocationChanged;
        UpdateSelectedKey();
    }

    public void Dispose()
    {
        AppState.OnChange -= OnAppStateChange;
        NavigationManager.LocationChanged -= OnLocationChanged;
    }

    private int GetSiderWidth() => Collapsed ? 80 : 240;

    private void UpdateSelectedKey()
    {
        var path = NavigationManager.ToBaseRelativePath(NavigationManager.Uri).TrimEnd('/');
        var segment = path.Split('/', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? "";

        _selectedKeys = segment switch
        {
            "" or "home" => new[] { "chat" },
            "session" => new[] { "chat" },
            "settings" => new[] { "settings-page" },
            _ => new[] { segment }
        };
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        UpdateSelectedKey();
        InvokeAsync(StateHasChanged);
    }

    private void OnAppStateChange() => InvokeAsync(StateHasChanged);

    private void NavigateTo(string path) => NavigationManager.NavigateTo(path);

    private string GetChatPath() =>
        !string.IsNullOrEmpty(AppState.CurrentSessionId)
            ? $"/session/{AppState.CurrentSessionId}"
            : "/sessions";

    private async Task OnCollapsedChanged(bool collapsed)
    {
        Collapsed = collapsed;
        if (CollapsedChanged.HasDelegate)
            await CollapsedChanged.InvokeAsync(collapsed);
    }
}
