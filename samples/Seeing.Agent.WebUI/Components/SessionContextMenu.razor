@using AntDesign
@using Microsoft.AspNetCore.Components.Web
@using Seeing.Session.Core

<!-- 右键上下文菜单 -->
<div Class="@GetContextMenuClass()"
     Style="@GetContextMenuStyle()">
    <Menu Theme="@MenuTheme.Light"
          Mode="@MenuMode.Vertical"
          Class="context-menu">
        <MenuItem OnClick="@OnRenameClick">
            <Icon Type="@IconType.Outline.Edit" />
            <span>重命名</span>
        </MenuItem>
        <MenuItem OnClick="@OnBranchClick">
            <Icon Type="@IconType.Outline.Fork" />
            <span>分支会话</span>
        </MenuItem>
        <MenuDivider />
        <MenuItem OnClick="@OnDeleteClick" Class="menu-item-danger">
            <Icon Type="@IconType.Outline.Delete" Style="color: var(--color-error);" />
            <span Style="color: var(--color-error);">删除会话</span>
        </MenuItem>
    </Menu>
</div>

<!-- 重命名弹窗 -->
@if (RenameModalVisible)
{
    <Modal Title="重命名会话"
           Visible="true"
           OnOk="@OnRenameConfirm"
           OnCancel="@OnRenameCancel"
           OkText="@OkText"
           CancelText="@CancelText">
        <Form Model="@RenameSession"
              LabelColSpan="4"
              WrapperColSpan="20">
            <FormItem Label="标题">
                <Input @bind-Value="@RenameSession.Title"
                       Placeholder="请输入会话标题"
                       AllowClear="true" />
            </FormItem>
        </Form>
    </Modal>
}

<!-- 删除确认弹窗 -->
<Popconfirm Title="确定删除此会话吗？"
             Visible="@DeleteConfirmVisible"
             OnConfirm="@OnDeleteConfirm"
             OnCancel="@OnDeleteCancel"
             OkText="@DeleteOkText"
             CancelText="@CancelText">
    <span Style="display: none;" @ref="@DeleteTriggerRef"></span>
</Popconfirm>

@code {
    /// <summary>
    /// 确定按钮文本
    /// </summary>
    private const string OkText = "确定";
    
    /// <summary>
    /// 取消按钮文本
    /// </summary>
    private const string CancelText = "取消";
    
    /// <summary>
    /// 删除确认按钮文本
    /// </summary>
    private const string DeleteOkText = "删除";

    /// <summary>
    /// 是否显示上下文菜单
    /// </summary>
    [Parameter]
    public bool Visible { get; set; }

    /// <summary>
    /// 菜单位置 X
    /// </summary>
    [Parameter]
    public int PositionX { get; set; }

    /// <summary>
    /// 菜单位置 Y
    /// </summary>
    [Parameter]
    public int PositionY { get; set; }

    /// <summary>
    /// 当前操作的会话
    /// </summary>
    [Parameter]
    public SessionData? CurrentSession { get; set; }

    /// <summary>
    /// 重命名事件回调
    /// </summary>
    [Parameter]
    public EventCallback<SessionData> OnRename { get; set; }

    /// <summary>
    /// 删除事件回调
    /// </summary>
    [Parameter]
    public EventCallback<SessionData> OnDelete { get; set; }

    /// <summary>
    /// 分支事件回调
    /// </summary>
    [Parameter]
    public EventCallback<SessionData> OnBranch { get; set; }

    /// <summary>
    /// 关闭菜单事件回调
    /// </summary>
    [Parameter]
    public EventCallback OnClose { get; set; }

    /// <summary>
    /// 重命名弹窗显示状态
    /// </summary>
    private bool RenameModalVisible { get; set; }

    /// <summary>
    /// 删除确认显示状态
    /// </summary>
    private bool DeleteConfirmVisible { get; set; }

    /// <summary>
    /// 重命名时的临时会话对象
    /// </summary>
    private SessionData RenameSession { get; set; } = new();

    /// <summary>
    /// 删除触发元素的引用
    /// </summary>
    private ElementReference DeleteTriggerRef { get; set; }

    /// <summary>
    /// 获取上下文菜单 CSS 类
    /// </summary>
    private string GetContextMenuClass()
    {
        return Visible ? "session-context-menu visible" : "session-context-menu";
    }

    /// <summary>
    /// 获取上下文菜单样式
    /// </summary>
    private string GetContextMenuStyle()
    {
        return $"left: {PositionX}px; top: {PositionY}px;";
    }

    /// <summary>
    /// 重命名点击
    /// </summary>
    private async Task OnRenameClick()
    {
        if (CurrentSession != null)
        {
            RenameSession = new SessionData
            {
                Id = CurrentSession.Id,
                Title = CurrentSession.Title,
                CreatedAt = CurrentSession.CreatedAt,
                UpdatedAt = CurrentSession.UpdatedAt
            };
            RenameModalVisible = true;
        }
        await OnClose.InvokeAsync();
    }

    /// <summary>
    /// 确认重命名
    /// </summary>
    private async Task OnRenameConfirm()
    {
        RenameModalVisible = false;
        if (CurrentSession != null && OnRename.HasDelegate)
        {
            CurrentSession.Title = RenameSession.Title;
            CurrentSession.UpdatedAt = DateTime.Now;
            await OnRename.InvokeAsync(CurrentSession);
        }
    }

    /// <summary>
    /// 取消重命名
    /// </summary>
    private async Task OnRenameCancel()
    {
        RenameModalVisible = false;
    }

    /// <summary>
    /// 分支点击
    /// </summary>
    private async Task OnBranchClick()
    {
        if (CurrentSession != null && OnBranch.HasDelegate)
        {
            await OnBranch.InvokeAsync(CurrentSession);
        }
        await OnClose.InvokeAsync();
    }

    /// <summary>
    /// 删除点击
    /// </summary>
    private async Task OnDeleteClick()
    {
        DeleteConfirmVisible = true;
        await OnClose.InvokeAsync();
    }

    /// <summary>
    /// 确认删除
    /// </summary>
    private async Task OnDeleteConfirm()
    {
        DeleteConfirmVisible = false;
        if (CurrentSession != null && OnDelete.HasDelegate)
        {
            await OnDelete.InvokeAsync(CurrentSession);
        }
    }

    /// <summary>
    /// 取消删除
    /// </summary>
    private async Task OnDeleteCancel()
    {
        DeleteConfirmVisible = false;
    }

    /// <summary>
    /// 关闭菜单
    /// </summary>
    public async Task Close()
    {
        Visible = false;
        await OnClose.InvokeAsync();
    }
}