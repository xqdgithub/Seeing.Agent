@using AntDesign
@using Markdig
@using Seeing.Agent.WebUI.Models
@implements IDisposable

<div Class="@GetMessageClass()">
    <!-- 消息头部：角色和时间戳 -->
    <div Class="message-header">
        <div Class="message-role">
            <Avatar Size="@AvatarSize.Small"
                    Icon="@GetRoleIcon()"
                    Style="@GetAvatarStyle()" />
            <span Class="message-role-name" Style="margin-left: var(--space-2); font-weight: 600;">
                @GetRoleDisplayName()
            </span>
        </div>
        <div Class="message-time">
            <span Class="message-time-text" Style="font-size: var(--font-size-xs); color: var(--color-text-secondary);">
                @Message.Timestamp.ToString("HH:mm:ss")
            </span>
        </div>
    </div>
    
    <!-- 推理过程（类似工具调用的折叠样式） -->
    @if (!string.IsNullOrEmpty(Message.Reasoning))
    {
        var isReasoningExpanded = !Message.IsComplete || _reasoningExpanded;
        <div class="reasoning-card-compact"
             style="display: flex; align-items: center; padding: 4px 8px; background: var(--color-bg-secondary); border-radius: var(--radius-sm); margin: 4px 0; cursor: pointer;"
             onclick="@ToggleReasoning">
            
            <!-- 状态图标 -->
            @if (!Message.IsComplete)
            {
                <Icon Type="@IconType.Outline.Loading" Style="color: var(--color-primary); font-size: 14px; animation: spin 1s linear infinite;" />
            }
            else
            {
                <Icon Type="@IconType.Outline.Bulb" Style="color: var(--color-warning); font-size: 14px;" />
            }
            
            <!-- 标题 -->
            <span style="margin-left: 6px; font-weight: 500; font-size: 13px;">
                思考过程
            </span>
            
            <!-- 状态标签 -->
            @if (!Message.IsComplete)
            {
                <Tag Color="@("processing")" Style="margin-left: 6px; font-size: 11px;">
                    思考中
                </Tag>
            }
            else
            {
                <Tag Color="@("warning")" Style="margin-left: 6px; font-size: 11px;">
                    @GetReasoningCharCount() 字符
                </Tag>
            }
            
            <!-- 预览文本（折叠时显示） -->
            @if (!isReasoningExpanded && Message.IsComplete)
            {
                <span style="margin-left: 8px; color: var(--color-text-secondary); font-size: 12px; max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                    @GetReasoningPreview()
                </span>
            }
            
            <!-- 执行中动画 -->
            @if (!Message.IsComplete)
            {
                <Spin Size="@SpinSize.Small" Style="margin-left: 8px;" />
            }
            
            <!-- 展开/收起指示 -->
            <Icon Type="@(isReasoningExpanded ? IconType.Outline.Down : IconType.Outline.Right)"
                  Style="margin-left: auto; font-size: 12px; color: var(--color-text-tertiary);" />
        </div>
        
        <!-- 详情展开区域 -->
        @if (isReasoningExpanded)
        {
            <div class="reasoning-detail"
                 style="padding: 8px 12px; background: var(--color-bg-tertiary); border-radius: var(--radius-sm); margin-top: 2px; border-left: 3px solid @(Message.IsComplete ? "var(--color-warning)" : "var(--color-primary)");">
                <div style="font-size: 12px; color: var(--color-text-secondary); max-height: 300px; overflow-y: auto;">
                    @((MarkupString)RenderReasoningMarkdown(Message.Reasoning))
                </div>
            </div>
        }
    }
    
    <!-- 消息内容（根据 ContentPosition 插入工具卡片） -->
    @if (Message.ToolCalls.Count > 0 && Message.ToolCalls.Any(tc => tc.ContentPosition.HasValue))
    {
        <!-- 有位置信息的工具调用：按位置插入到内容中间 -->
        @RenderContentWithToolCalls()
    }
    else
    {
        <!-- 无位置信息的工具调用：显示在内容之前 -->
        @if (Message.ToolCalls.Count > 0)
        {
            <div Class="message-toolcalls" Style="margin-bottom: var(--space-2);">
                @foreach (var toolCall in Message.ToolCalls)
                {
                    <ToolCallCard ToolCall="@toolCall" />
                }
            </div>
        }
        
        <!-- 附件显示区域（在消息内容之前） -->
        @if (Message.HasAttachments)
        {
            <div Class="message-attachments" Style="margin-bottom: var(--space-2);">
                @RenderAttachments()
            </div>
        }
        
        <div Class="message-content">
            @((MarkupString)RenderMarkdown(Message.Content))
        </div>
    }
    
    <!-- 消息状态指示 -->
    @if (!Message.IsComplete && string.IsNullOrEmpty(Message.Reasoning))
    {
        <div Class="message-loading">
            <Spin Size="@SpinSize.Small" />
            <span Style="margin-left: var(--space-2); color: var(--color-text-secondary);">
                正在生成...
            </span>
        </div>
    }
</div>

@code {
    /// <summary>
    /// 消息数据
    /// </summary>
    [Parameter]
    public MessageViewModel Message { get; set; } = new();
    
    /// <summary>
    /// 工具点击事件回调
    /// </summary>
    [Parameter]
    public EventCallback<ToolCallViewModel> OnToolClick { get; set; }
    
    /// <summary>
    /// 推理过程是否展开
    /// </summary>
    private bool _reasoningExpanded = false;
    
    // ========== Markdown 渲染缓存 ==========
    
    /// <summary>
    /// 缓存的内容原文（用于检测变化）
    /// </summary>
    private string _cachedContent = string.Empty;
    
    /// <summary>
    /// 缓存的渲染结果
    /// </summary>
    private string _cachedContentHtml = string.Empty;
    
    /// <summary>
    /// 缓存的推理内容原文
    /// </summary>
    private string _cachedReasoning = string.Empty;
    
    /// <summary>
    /// 缓存的推理渲染结果
    /// </summary>
    private string _cachedReasoningHtml = string.Empty;
    
    /// <summary>
    /// 上一次消息 ID（用于检测消息切换）
    /// </summary>
    private string _lastMessageId = string.Empty;
    
    /// <summary>
    /// Markdown 渲染管道
    /// </summary>
    private static readonly MarkdownPipeline MarkdownPipeline = new MarkdownPipelineBuilder()
        .UseAutoLinks()
        .UseTaskLists()
        .UsePipeTables()
        .UseEmphasisExtras()
        .UseListExtras()
        .Build();
    
    /// <summary>
    /// 获取推理内容字符数
    /// </summary>
    private int GetReasoningCharCount()
    {
        return Message.Reasoning?.Length ?? 0;
    }
    
    /// <summary>
    /// 渲染附件列表
    /// </summary>
    private RenderFragment RenderAttachments()
    {
        return builder =>
        {
            var seq = 0;
            
            // 图片附件网格
            var images = Message.Parts.Where(p => p.IsImage).ToList();
            if (images.Count > 0)
            {
                builder.OpenElement(seq++, "div");
                builder.AddAttribute(seq++, "class", "message-attachments-images");
                builder.AddAttribute(seq++, "style", $"display: grid; grid-template-columns: repeat({Math.Min(images.Count, 3)}, 1fr); gap: var(--space-2); margin-bottom: var(--space-2);");
                
                foreach (var img in images)
                {
                    var displayUrl = img.GetDisplayUrl();
                    if (!string.IsNullOrEmpty(displayUrl))
                    {
                        builder.OpenElement(seq++, "div");
                        builder.AddAttribute(seq++, "class", "message-attachment-image-wrapper");
                        builder.AddAttribute(seq++, "style", "position: relative; border-radius: var(--border-radius); overflow: hidden; cursor: pointer;");
                        
                        // 使用 AntDesign Image 组件支持预览
                        builder.OpenComponent<AntDesign.Image>(seq++);
                        builder.AddAttribute(seq++, "Src", displayUrl);
                        builder.AddAttribute(seq++, "Alt", img.FileName ?? "图片");
                        builder.AddAttribute(seq++, "Style", "width: 100%; max-width: 200px; height: auto; object-fit: cover; border-radius: var(--border-radius);");
                        builder.CloseComponent();
                        
                        builder.CloseElement(); // div wrapper
                    }
                }
                
                builder.CloseElement(); // images grid
            }
            
            // 文件附件列表
            var files = Message.Parts.Where(p => p.IsFile).ToList();
            if (files.Count > 0)
            {
                builder.OpenElement(seq++, "div");
                builder.AddAttribute(seq++, "class", "message-attachments-files");
                builder.AddAttribute(seq++, "style", "display: flex; flex-wrap: wrap; gap: var(--space-2);");
                
                foreach (var file in files)
                {
                    builder.OpenElement(seq++, "div");
                    builder.AddAttribute(seq++, "class", "message-attachment-file");
                    builder.AddAttribute(seq++, "style", "display: flex; align-items: center; padding: var(--space-1) var(--space-2); background: var(--color-bg-container); border-radius: var(--border-radius); border: 1px solid var(--color-border); gap: var(--space-1);");
                    
                    // 文件图标
                    builder.OpenComponent<AntDesign.Icon>(seq++);
                    builder.AddAttribute(seq++, "Type", GetFileIconType(file));
                    builder.AddAttribute(seq++, "Style", "font-size: 16px; color: var(--color-text-secondary);");
                    builder.CloseComponent();
                    
                    // 文件名
                    builder.OpenElement(seq++, "span");
                    builder.AddAttribute(seq++, "class", "message-attachment-filename");
                    builder.AddAttribute(seq++, "style", "font-size: var(--font-size-sm); color: var(--color-text);");
                    builder.AddContent(seq++, file.FileName ?? "未命名文件");
                    builder.CloseElement();
                    
                    builder.CloseElement(); // file item
                }
                
                builder.CloseElement(); // files list
            }
        };
    }
    
    /// <summary>
    /// 获取文件图标类型
    /// </summary>
    private string GetFileIconType(ContentPartViewModel part)
    {
        return part.GetIconType() switch
        {
            "pdf" => IconType.Outline.FilePdf,
            "word" => IconType.Outline.FileWord,
            "excel" => IconType.Outline.FileExcel,
            "ppt" => IconType.Outline.FilePpt,
            "text" => IconType.Outline.FileText,
            "archive" => IconType.Outline.FileZip,
            "audio" => IconType.Outline.Sound,
            "video" => IconType.Outline.VideoCamera,
            "data" => IconType.Outline.FileMarkdown,
            "code" => IconType.Outline.FileMarkdown,
            _ => IconType.Outline.File
        };
    }
    
    /// <summary>
    /// 渲染内容并在正确位置插入工具卡片
    /// </summary>
    private RenderFragment RenderContentWithToolCalls()
    {
        return builder =>
        {
            // 按位置排序工具调用
            var sortedToolCalls = Message.ToolCalls
                .Where(tc => tc.ContentPosition.HasValue)
                .OrderBy(tc => tc.ContentPosition)
                .ToList();
            
            // 无位置的工具调用显示在开头
            var noPositionToolCalls = Message.ToolCalls
                .Where(tc => !tc.ContentPosition.HasValue)
                .ToList();
            
            // 先显示无位置的工具调用
            if (noPositionToolCalls.Count > 0)
            {
                builder.OpenElement(0, "div");
                builder.AddAttribute(1, "class", "message-toolcalls");
                builder.AddAttribute(2, "style", "margin-bottom: var(--space-2);");
                
                foreach (var tc in noPositionToolCalls)
                {
                    builder.OpenComponent<ToolCallCard>(3);
                    builder.AddAttribute(4, "ToolCall", tc);
                    builder.CloseComponent();
                }
                
                builder.CloseElement();
            }
            
            // 分割内容并插入工具卡片
            var content = Message.Content;
            var lastPos = 0;
            var seq = 10;
            
            foreach (var tc in sortedToolCalls)
            {
                var pos = tc.ContentPosition ?? 0;
                
                // 确保位置有效
                if (pos < 0 || pos > content.Length)
                    pos = content.Length;
                
                // 渲染位置之前的内容
                if (pos > lastPos)
                {
                    var segment = content.Substring(lastPos, pos - lastPos);
                    builder.OpenElement(seq++, "div");
                    builder.AddAttribute(seq++, "class", "message-content-segment");
                    builder.AddContent(seq++, new MarkupString(RenderMarkdown(segment)));
                    builder.CloseElement();
                }
                
                // 渲染工具卡片
                builder.OpenElement(seq++, "div");
                builder.AddAttribute(seq++, "class", "message-toolcalls");
                builder.AddAttribute(seq++, "style", "margin: var(--space-1) 0;");
                builder.OpenComponent<ToolCallCard>(seq++);
                builder.AddAttribute(seq++, "ToolCall", tc);
                builder.CloseComponent();
                builder.CloseElement();
                
                lastPos = pos;
            }
            
            // 渲染剩余内容
            if (lastPos < content.Length)
            {
                var remaining = content.Substring(lastPos);
                builder.OpenElement(seq++, "div");
                builder.AddAttribute(seq++, "class", "message-content-segment");
                builder.AddContent(seq++, new MarkupString(RenderMarkdown(remaining)));
                builder.CloseElement();
            }
        };
    }
    
    /// <summary>
    /// 获取消息样式类名
    /// </summary>
    private string GetMessageClass()
    {
        var roleClass = Message.Role.ToLowerInvariant();
        return $"message-item message-{roleClass}";
    }
    
    /// <summary>
    /// 获取角色图标
    /// </summary>
    private string GetRoleIcon()
    {
        return Message.Role.ToLowerInvariant() switch
        {
            "user" => IconType.Outline.User,
            "assistant" => IconType.Outline.Robot,
            "system" => IconType.Outline.Setting,
            "tool" => IconType.Outline.Tool,
            _ => IconType.Outline.Message
        };
    }
    
    /// <summary>
    /// 获取头像样式
    /// </summary>
    private string GetAvatarStyle()
    {
        return Message.Role.ToLowerInvariant() switch
        {
            "user" => "background: var(--color-primary);",
            "assistant" => "background: var(--color-success);",
            "system" => "background: var(--color-warning);",
            "tool" => "background: var(--color-info);",
            _ => "background: var(--color-text-tertiary);"
        };
    }
    
    /// <summary>
    /// 获取角色显示名称
    /// </summary>
    private string GetRoleDisplayName()
    {
        return Message.Role.ToLowerInvariant() switch
        {
            "user" => "用户",
            "assistant" => "助手",
            "system" => "系统",
            "tool" => "工具",
            _ => Message.Role
        };
    }
    
    /// <summary>
    /// 渲染 Markdown 内容（带缓存优化）
    /// </summary>
    private string RenderMarkdown(string content)
    {
        if (string.IsNullOrEmpty(content))
            return string.Empty;
        
        // 检测消息切换，清空缓存
        if (Message.Id != _lastMessageId)
        {
            _lastMessageId = Message.Id;
            _cachedContent = string.Empty;
            _cachedContentHtml = string.Empty;
            _cachedReasoning = string.Empty;
            _cachedReasoningHtml = string.Empty;
        }
        
        // 内容未变化，返回缓存结果
        if (content == _cachedContent)
            return _cachedContentHtml;
        
        // 内容变化，重新渲染并缓存
        _cachedContent = content;
        _cachedContentHtml = Markdown.ToHtml(content, MarkdownPipeline);
        return _cachedContentHtml;
    }
    
    /// <summary>
    /// 渲染推理内容 Markdown（带缓存优化）
    /// </summary>
    private string RenderReasoningMarkdown(string reasoning)
    {
        if (string.IsNullOrEmpty(reasoning))
            return string.Empty;
        
        // 内容未变化，返回缓存结果
        if (reasoning == _cachedReasoning)
            return _cachedReasoningHtml;
        
        // 内容变化，重新渲染并缓存
        _cachedReasoning = reasoning;
        _cachedReasoningHtml = Markdown.ToHtml(reasoning, MarkdownPipeline);
        return _cachedReasoningHtml;
    }
    
    /// <summary>
    /// 获取推理内容第一行预览
    /// </summary>
    private string GetReasoningPreview()
    {
        if (string.IsNullOrEmpty(Message.Reasoning))
            return string.Empty;
        var firstLine = Message.Reasoning.Split('\n')[0].Trim();
        if (firstLine.Length > 50)
            return firstLine[..50] + "...";
        return firstLine;
    }
    
    /// <summary>
    /// 切换推理过程展开状态
    /// </summary>
    public async Task ToggleReasoning()
    {
        _reasoningExpanded = !_reasoningExpanded;
        await InvokeAsync(StateHasChanged);
    }
    
    public void Dispose()
    {
        // 清理资源
    }
}