@using AntDesign
@using Microsoft.AspNetCore.Components.Web
@using Microsoft.JSInterop
@using Seeing.Agent.WebUI.State
@using Seeing.Agent.WebUI.Models
@inject SessionState SessionState
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

<div Class="message-list" @ref="@MessageListElement" Id="@ContainerId">
    @if (Messages.Count == 0)
    {
        <Empty Class="message-list-empty">
            <DescriptionTemplate>
                暂无消息，开始对话吧
            </DescriptionTemplate>
        </Empty>
    }
    else
    {
        <div Class="message-list-container">
            @foreach (var message in Messages)
            {
                <!-- 用户消息：传统左右布局 -->
                @if (message.Role == "user")
                {
                    <ChatMessageItem @key="message.Id"
                                     Message="@message" 
                                     OnToolClick="@OnToolClickHandler" />
                }
                <!-- 助手消息：按 Loop 分组显示 -->
                else if (message.Role == "assistant")
                {
                    <!-- 只显示该 LoopId 的第一条助手消息（避免重复渲染同一 Loop） -->
                    @if (IsFirstAssistantInLoop(message))
                    {
                        <LoopGroupItem @key="message.LoopId ?? message.Id"
                                       Loop="@BuildLoopFromMessage(message)"
                                       OnToolClick="@OnToolClickHandler" />
                    }
                }
                <!-- 工具消息：独立组件展示 -->
                else if (message.Role == "tool")
                {
                    <ChatMessageItem @key="message.Id"
                                     Message="@message" 
                                     OnToolClick="@OnToolClickHandler" />
                }
                <!-- 系统消息和其他消息：传统布局 -->
                else
                {
                    <!-- 压缩摘要消息：特殊样式 -->
                    @if (message.IsCompactionSummary)
                    {
                        <div class="compaction-summary-message" style="margin: 8px 0; padding: 12px; background: var(--ant-info-bg); border-radius: 6px;">
                            <Icon Type="@IconType.Outline.FileText" Style="margin-right: 8px;" />
                            @((MarkupString)message.Content.Replace("\n", "<br/>"))
                        </div>
                    }
                    else
                    {
                        <ChatMessageItem @key="message.Id"
                                         Message="@message" 
                                         OnToolClick="@OnToolClickHandler" />
                    }
                }
            }
            
            <!-- 自动滚动锚点 -->
            <div Id="@ScrollAnchorId" Class="scroll-anchor"></div>
            
            <!-- "滚动到底部"按钮（用户向上滚动时显示） -->
            @if (_showScrollToBottomButton)
            {
                <div Class="scroll-to-bottom-button" onclick="@OnScrollToBottomClick">
                    <Icon Type="@IconType.Outline.ArrowDown" />
                </div>
            }
        </div>
    }
</div>

@code {
    /// <summary>
    /// 消息列表元素引用，用于自动滚动
    /// </summary>
    private ElementReference MessageListElement { get; set; }
    
    /// <summary>
    /// 滚动容器 ID
    /// </summary>
    private const string ContainerId = "message-list-container";
    
    /// <summary>
    /// 滚动锚点 ID
    /// </summary>
    private const string ScrollAnchorId = "message-list-scroll-anchor";
    
    /// <summary>
    /// 是否显示"滚动到底部"按钮
    /// </summary>
    private bool _showScrollToBottomButton = false;
    
    /// <summary>
    /// 是否已初始化滚动管理器
    /// </summary>
    private bool _scrollManagerInitialized = false;
    
    /// <summary>
    /// 消息列表数据源
    /// </summary>
    [Parameter]
    public List<MessageViewModel> Messages { get; set; } = new();
    
    /// <summary>
    /// 工具点击事件回调
    /// </summary>
    [Parameter]
    public EventCallback<ToolCallViewModel> OnToolClick { get; set; }
    
    /// <summary>
    /// 是否自动滚动到底部
    /// </summary>
    [Parameter]
    public bool AutoScroll { get; set; } = true;

    // ========== Loop 缓存系统 ==========
    
    /// <summary>
    /// 最大缓存数量
    /// </summary>
    private const int MaxCacheSize = 100;
    
    /// <summary>
    /// LoopId → LoopIndex 映射
    /// </summary>
    private readonly Dictionary<string, int> _loopIndexMap = new();
    
    /// <summary>
    /// LoopId → LoopGroupViewModel 缓存
    /// </summary>
    private readonly Dictionary<string, LoopGroupViewModel> _loopCache = new();
    
    /// <summary>
    /// LoopId → 消息列表
    /// </summary>
    private readonly Dictionary<string, List<MessageViewModel>> _loopMessages = new();
    
    /// <summary>
    /// 已处理的用户消息 ID 集合（用于关联用户消息到 Loop）
    /// </summary>
    private readonly HashSet<string> _processedUserMessageIds = new();
    
    /// <summary>
    /// 下一个 Loop 索引
    /// </summary>
    private int _nextLoopIndex = 1;
    
    /// <summary>
    /// 上次处理的消息数量
    /// </summary>
    private int _lastProcessedCount = 0;

    /// <summary>
    /// 上次第一条消息的ID（用于检测消息列表是否被重置）
    /// </summary>
    private string? _lastFirstMessageId = null;

    /// <summary>
    /// 获取已渲染的 LoopId 集合（每次渲染时重置）
    /// </summary>
    private readonly HashSet<string> _currentRenderLoopIds = new();

    /// <summary>
    /// 判断是否是同一 Loop 中的第一条助手消息
    /// 使用方式：在渲染周期内，同一 LoopId 只渲染一次
    /// </summary>
    private bool IsFirstAssistantInLoop(MessageViewModel message)
    {
        if (string.IsNullOrEmpty(message.LoopId))
            return true;

        // 检查当前渲染周期是否已处理过此 LoopId
        if (_currentRenderLoopIds.Contains(message.LoopId))
        {
            return false;
        }
        
        // 标记为已处理
        _currentRenderLoopIds.Add(message.LoopId);
        return true;
    }
    
    /// <summary>
    /// 重置渲染周期状态（在每次渲染开始时调用）
    /// </summary>
    protected override void OnParametersSet()
    {
        // 重置渲染周期状态
        _currentRenderLoopIds.Clear();
        
        // 检测消息列表是否被重置（消息数量减少或第一条消息ID变化）
        var firstMsgId = Messages.FirstOrDefault()?.Id;
        if (Messages.Count < _lastProcessedCount || 
            (_lastFirstMessageId != null && firstMsgId != _lastFirstMessageId))
        {
            // 消息列表被重置，清空所有缓存
            ClearCache();
        }
        
        _lastFirstMessageId = firstMsgId;
        
        // 检查是否需要更新缓存
        if (Messages.Count != _lastProcessedCount)
        {
            UpdateCacheIncremental();
        }
        else if (Messages.Count > 0)
        {
            // 消息数量没变但内容可能变化（如 ToolCalls 更新）
            // 需要刷新 _loopMessages 中的消息引用
            RefreshLoopMessagesReferences();
        }
    }

    /// <summary>
    /// 刷新 Loop 消息引用（当消息数量不变但内容变化时）
    /// </summary>
    private void RefreshLoopMessagesReferences()
    {
        // 构建 ID -> Message 映射；会话中可能存在重复 Id（历史 step 碰撞），取最后一条
        var messageById = new Dictionary<string, MessageViewModel>(StringComparer.Ordinal);
        foreach (var m in Messages)
        {
            if (string.IsNullOrEmpty(m.Id))
                continue;
            messageById[m.Id] = m;
        }
        
        // 遍历所有 Loop，更新消息引用
        foreach (var kvp in _loopMessages.ToList())
        {
            var loopId = kvp.Key;
            var oldMessages = kvp.Value;
            
            // 更新每条消息的引用
            for (var i = 0; i < oldMessages.Count; i++)
            {
                var oldMsg = oldMessages[i];
                if (!string.IsNullOrEmpty(oldMsg.Id) &&
                    messageById.TryGetValue(oldMsg.Id, out var newMsg))
                {
                    oldMessages[i] = newMsg;
                }
            }
            
            // 使缓存失效，强制重新构建 LoopGroupViewModel
            _loopCache.Remove(loopId);
        }
    }

    /// <summary>
    /// 从助手消息构建 Loop 分组（使用缓存优化）
    /// </summary>
    private LoopGroupViewModel BuildLoopFromMessage(MessageViewModel assistantMessage)
    {
        var loopId = assistantMessage.LoopId ?? $"single-{Messages.IndexOf(assistantMessage)}";
        
        // 尝试从缓存获取
        if (_loopCache.TryGetValue(loopId, out var cached))
        {
            return cached;
        }
        
        // 缓存未命中，构建新的
        return BuildAndCacheLoop(loopId, assistantMessage);
    }
    
    /// <summary>
    /// 增量更新缓存
    /// </summary>
    private void UpdateCacheIncremental()
    {
        var newCount = Messages.Count;
        
        // 只处理新增的消息
        for (var i = _lastProcessedCount; i < newCount; i++)
        {
            var msg = Messages[i];
            
            if (msg.Role == "assistant")
            {
                var loopId = msg.LoopId ?? $"single-{i}";
                
                // 添加到消息分组
                if (!_loopMessages.ContainsKey(loopId))
                {
                    _loopMessages[loopId] = new List<MessageViewModel>();
                    
                    // 分配新索引
                    _loopIndexMap[loopId] = _nextLoopIndex++;
                }
                
                _loopMessages[loopId].Add(msg);
                
                // 使缓存失效
                _loopCache.Remove(loopId);
            }
            else if (msg.Role == "user" && !string.IsNullOrEmpty(msg.Id) && !_processedUserMessageIds.Contains(msg.Id))
            {
                _processedUserMessageIds.Add(msg.Id);
            }
        }
        
        _lastProcessedCount = newCount;
        
        // 清理超限缓存
        TrimCacheIfNeeded();
    }
    
    /// <summary>
    /// 构建并缓存 Loop
    /// </summary>
    private LoopGroupViewModel BuildAndCacheLoop(string loopId, MessageViewModel assistantMessage)
    {
        var loopMessages = _loopMessages.TryGetValue(loopId, out var messages) 
            ? messages 
            : new List<MessageViewModel> { assistantMessage };
        
        var loopIndex = _loopIndexMap.TryGetValue(loopId, out var index) ? index : _nextLoopIndex++;
        
        // 计算统计信息
        var totalSteps = loopMessages.Count;
        var startTime = loopMessages.FirstOrDefault()?.Timestamp;
        var endTime = loopMessages.LastOrDefault()?.Timestamp;
        var isComplete = loopMessages.All(m => m.IsComplete);
        var hasError = loopMessages.Any(m => m.ToolCalls.Any(t => !string.IsNullOrEmpty(t.Error)));
        
        var loop = new LoopGroupViewModel
        {
            LoopId = loopId,
            LoopIndex = loopIndex,
            Messages = loopMessages.ToList(), // 复制一份避免外部修改
            IsComplete = isComplete,
            TotalSteps = totalSteps,
            StartTime = startTime,
            EndTime = isComplete ? endTime : null,
            Duration = startTime.HasValue && endTime.HasValue && isComplete 
                ? endTime.Value - startTime.Value 
                : null,
            Success = !hasError
        };
        
        _loopCache[loopId] = loop;
        
        return loop;
    }
    
    /// <summary>
    /// 清理超限缓存
    /// </summary>
    private void TrimCacheIfNeeded()
    {
        if (_loopCache.Count > MaxCacheSize)
        {
            // 按索引排序，保留最近的 MaxCacheSize 个
            var toRemove = _loopIndexMap
                .OrderByDescending(kvp => kvp.Value)
                .Skip(MaxCacheSize)
                .Select(kvp => kvp.Key)
                .ToList();
            
            foreach (var key in toRemove)
            {
                _loopCache.Remove(key);
                _loopMessages.Remove(key);
                _loopIndexMap.Remove(key);
            }
        }
    }
    
    /// <summary>
    /// 清空缓存（消息列表清空时调用）
    /// </summary>
    public void ClearCache()
    {
        _loopCache.Clear();
        _loopMessages.Clear();
        _loopIndexMap.Clear();
        _processedUserMessageIds.Clear();
        _currentRenderLoopIds.Clear();
        _nextLoopIndex = 1;
        _lastProcessedCount = 0;
        _lastFirstMessageId = null;
    }
    
    /// <summary>
    /// 工具点击处理
    /// </summary>
    private async Task OnToolClickHandler(ToolCallViewModel tool)
    {
        if (OnToolClick.HasDelegate)
        {
            await OnToolClick.InvokeAsync(tool);
        }
    }
    
    /// <summary>
    /// 组件渲染后初始化滚动管理器并自动滚动
    /// </summary>
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // 初始化滚动管理器
            try
            {
                await JSRuntime.InvokeVoidAsync("initMessageListScroll", ContainerId, ScrollAnchorId);
                _scrollManagerInitialized = true;
            }
            catch
            {
                // JSInterop 可能未就绪，静默忽略
            }
        }
        
        if (AutoScroll && Messages.Count > 0)
        {
            await ScrollToBottomAsync();
        }
        
        // 检查是否应该显示"滚动到底部"按钮
        await CheckScrollPositionAsync();
    }
    
    /// <summary>
    /// 智能滚动到底部（尊重用户滚动行为）
    /// </summary>
    private async Task ScrollToBottomAsync()
    {
        if (!_scrollManagerInitialized) return;
        
        try
        {
            await JSRuntime.InvokeVoidAsync("smartScrollToBottom");
        }
        catch
        {
            // JSInterop 可能未就绪，静默忽略
        }
    }
    
    /// <summary>
    /// 强制滚动到底部（忽略用户滚动）
    /// </summary>
    public async Task ForceScrollToBottomAsync()
    {
        if (!_scrollManagerInitialized) return;
        
        try
        {
            await JSRuntime.InvokeVoidAsync("forceScrollToBottom");
            _showScrollToBottomButton = false;
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
            // JSInterop 可能未就绪，静默忽略
        }
    }
    
    /// <summary>
    /// 检查滚动位置，决定是否显示"滚动到底部"按钮
    /// </summary>
    private async Task CheckScrollPositionAsync()
    {
        if (!_scrollManagerInitialized) return;
        
        try
        {
            var shouldAutoScroll = await JSRuntime.InvokeAsync<bool>("shouldAutoScroll");
            if (_showScrollToBottomButton == shouldAutoScroll)
            {
                _showScrollToBottomButton = !shouldAutoScroll;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch
        {
            // JSInterop 可能未就绪，静默忽略
        }
    }
    
    /// <summary>
    /// "滚动到底部"按钮点击处理
    /// </summary>
    private async Task OnScrollToBottomClick()
    {
        await ForceScrollToBottomAsync();
    }
    
    /// <summary>
    /// 添加新消息（供外部调用）
    /// </summary>
    public void AddMessage(MessageViewModel message)
    {
        Messages.Add(message);
        StateHasChanged();
    }
    
    /// <summary>
    /// 清空消息列表
    /// </summary>
    public void ClearMessages()
    {
        Messages.Clear();
        _showScrollToBottomButton = false;
        ClearCache();
        StateHasChanged();
    }
    
    /// <summary>
    /// 释放资源
    /// </summary>
    public async ValueTask DisposeAsync()
    {
        if (_scrollManagerInitialized)
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("destroyMessageListScroll");
            }
            catch
            {
                // JSInterop 可能未就绪，静默忽略
            }
        }
    }
}
