@using AntDesign
@using Markdig
@using Seeing.Agent.WebUI.Models
@implements IDisposable

<div Class="@GetMessageClass()">
    <!-- 消息头部：角色、Loop 信息和时间戳 -->
    <div Class="message-header">
        <div Class="message-role">
            <Avatar Size="@AvatarSize.Small"
                    Icon="@IconType.Outline.Robot"
                    Style="background: var(--color-success);" />
            <span Class="message-role-name" Style="margin-left: var(--space-2); font-weight: 600;">
                助手
            </span>
            
            @* Loop 标签 *@
            @if (Loop.LoopIndex > 0)
            {
                <Tag Color="@GetLoopTagColor()" 
                     Style="margin-left: var(--space-2); font-size: 11px;">
                    @if (Loop.IsExecuting)
                    {
                        <Icon Type="@IconType.Outline.Loading" Style="margin-right: 4px;" />
                    }
                    Loop #@Loop.LoopIndex
                </Tag>
            }
            
            @* 状态指示 *@
            @if (Loop.IsExecuting)
            {
                <Badge Status="@BadgeStatus.Processing" Style="margin-left: var(--space-1);" />
            }
        </div>
        
        <div Class="message-meta">
            @if (Loop.TotalToolCalls > 0)
            {
                <span Class="meta-item" Title="工具调用次数">
                    <Icon Type="@IconType.Outline.Tool" Style="font-size: 12px;" />
                    @Loop.TotalToolCalls 工具
                </span>
            }
            
            @if (!string.IsNullOrEmpty(Loop.GetFormattedDuration()))
            {
                <span Class="meta-item" Title="执行耗时">
                    <Icon Type="@IconType.Outline.ClockCircle" Style="font-size: 12px;" />
                    @Loop.GetFormattedDuration()
                </span>
            }
            
            @if (Loop.TokenUsage != null)
            {
                <span Class="meta-item token-count" Title="Token 使用量">
                    <Icon Type="@IconType.Outline.Calculator" Style="font-size: 12px;" />
                    @Loop.TokenUsage.TotalTokens
                </span>
            }
            
            <span Class="message-time" Style="font-size: var(--font-size-xs); color: var(--color-text-secondary);">
                @GetTimestamp()
            </span>
        </div>
    </div>
    
    @* Loop 内的消息内容（按 Step 排序） *@
    @foreach (var message in Loop.Messages.OrderBy(m => m.Step))
    {
        @* 推理过程（如果有）- 类似工具调用的折叠样式 *@
        @if (!string.IsNullOrEmpty(message.Reasoning))
        {
            var isReasoningExpanded = !message.IsComplete || IsReasoningManuallyExpanded(message.Id);
            <div class="reasoning-card-compact"
                 style="display: flex; align-items: center; padding: 4px 8px; background: var(--color-bg-secondary); border-radius: var(--radius-sm); margin: 4px 0; cursor: pointer;"
                 onclick="@(() => ToggleReasoning(message.Id))">
                
                <!-- 状态图标 -->
                @if (!message.IsComplete)
                {
                    <Icon Type="@IconType.Outline.Loading" Style="color: var(--color-primary); font-size: 14px; animation: spin 1s linear infinite;" />
                }
                else
                {
                    <Icon Type="@IconType.Outline.Bulb" Style="color: var(--color-warning); font-size: 14px;" />
                }
                
                <!-- 标题 -->
                <span style="margin-left: 6px; font-weight: 500; font-size: 13px;">
                    思考过程
                </span>
                
                <!-- 状态标签 -->
                @if (!message.IsComplete)
                {
                    <Tag Color="@("processing")" Style="margin-left: 6px; font-size: 11px;">
                        思考中
                    </Tag>
                }
                else
                {
                    <Tag Color="@("warning")" Style="margin-left: 6px; font-size: 11px;">
                        @GetReasoningCharCount(message.Reasoning) 字符
                    </Tag>
                }
                
                <!-- 预览文本（折叠时显示） -->
                @if (!isReasoningExpanded && message.IsComplete)
                {
                    <span style="margin-left: 8px; color: var(--color-text-secondary); font-size: 12px; max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                        @GetReasoningPreview(message.Reasoning)
                    </span>
                }
                
                <!-- 执行中动画 -->
                @if (!message.IsComplete)
                {
                    <Spin Size="@SpinSize.Small" Style="margin-left: 8px;" />
                }
                
                <!-- 展开/收起指示 -->
                <Icon Type="@(isReasoningExpanded ? IconType.Outline.Down : IconType.Outline.Right)"
                      Style="margin-left: auto; font-size: 12px; color: var(--color-text-tertiary);" />
            </div>
            
            <!-- 详情展开区域 -->
            @if (isReasoningExpanded)
            {
                <div class="reasoning-detail"
                     style="padding: 8px 12px; background: var(--color-bg-tertiary); border-radius: var(--radius-sm); margin-top: 2px; border-left: 3px solid @(message.IsComplete ? "var(--color-warning)" : "var(--color-primary)");">
                    <div style="font-size: 12px; color: var(--color-text-secondary); max-height: 300px; overflow-y: auto;">
                        @((MarkupString)RenderReasoningMarkdown(message.Reasoning, message.Id))
                    </div>
                </div>
            }
        }
        
        @* 工具调用（如果有）*@
        @if (message.ToolCalls.Count > 0)
        {
            <div Class="message-toolcalls" Style="margin: var(--space-2) 0;">
                @foreach (var toolCall in message.ToolCalls)
                {
                    <ToolCallCard ToolCall="@toolCall" />
                }
            </div>
        }
        
        @* 消息内容 *@
        @if (!string.IsNullOrEmpty(message.Content))
        {
            <div Class="message-content">
                @((MarkupString)RenderMarkdown(message.Content, message.Id))
            </div>
        }
    }
    
    @* 加载状态 *@
    @if (Loop.IsExecuting && Loop.Messages.All(m => string.IsNullOrEmpty(m.Content) && string.IsNullOrEmpty(m.Reasoning)))
    {
        <div Class="message-loading">
            <Spin Size="@SpinSize.Small" />
            <span Style="margin-left: var(--space-2); color: var(--color-text-secondary);">
                正在思考...
            </span>
        </div>
    }
    
    @* 错误信息 *@
    @if (!string.IsNullOrEmpty(Loop.Error))
    {
        <Alert Type="@AlertType.Error"
               Message="@Loop.Error"
               ShowIcon="true"
               Class="loop-error"
               Style="margin-top: var(--space-2);" />
    }
</div>

@code {
    /// <summary>
    /// Loop 分组数据
    /// </summary>
    [Parameter]
    public LoopGroupViewModel Loop { get; set; } = new();

    /// <summary>
    /// 工具点击事件回调
    /// </summary>
    [Parameter]
    public EventCallback<ToolCallViewModel> OnToolClick { get; set; }

    /// <summary>
    /// 每个消息的推理展开状态（按消息 ID 存储）
    /// </summary>
    private readonly Dictionary<string, bool> _reasoningExpandedStates = new();

    /// <summary>
    /// Markdown 渲染管道
    /// </summary>
    private static readonly MarkdownPipeline MarkdownPipeline = new MarkdownPipelineBuilder()
        .UseAutoLinks()
        .UseTaskLists()
        .UsePipeTables()
        .UseEmphasisExtras()
        .UseListExtras()
        .Build();
    
    // ========== Markdown 渲染缓存 ==========
    
    /// <summary>
    /// 消息渲染缓存（按消息 ID 存储）
    /// </summary>
    private readonly Dictionary<string, (string content, string html)> _renderCache = new();
    
    /// <summary>
    /// 推理渲染缓存（按消息 ID 存储）
    /// </summary>
    private readonly Dictionary<string, (string reasoning, string html)> _reasoningCache = new();
    
    /// <summary>
    /// 上一次 Loop ID（用于检测切换，清空缓存）
    /// </summary>
    private string _lastLoopId = string.Empty;
    
    /// <summary>
    /// 判断消息的推理内容是否被用户手动展开
    /// </summary>
    private bool IsReasoningManuallyExpanded(string messageId)
    {
        return _reasoningExpandedStates.TryGetValue(messageId, out var expanded) && expanded;
    }
    
    /// <summary>
    /// 切换消息的推理展开状态
    /// </summary>
    private void ToggleReasoning(string messageId)
    {
        if (_reasoningExpandedStates.ContainsKey(messageId))
        {
            _reasoningExpandedStates[messageId] = !_reasoningExpandedStates[messageId];
        }
        else
        {
            _reasoningExpandedStates[messageId] = true;
        }
    }
    
    /// <summary>
    /// 获取推理内容字符数
    /// </summary>
    private int GetReasoningCharCount(string reasoning)
    {
        return reasoning?.Length ?? 0;
    }

    /// <summary>
    /// 获取消息样式类名
    /// </summary>
    private string GetMessageClass()
    {
        var statusClass = Loop.IsExecuting ? "message-streaming" : 
                          Loop.Success ? "message-complete" : "message-error";
        return $"message-item message-assistant {statusClass}";
    }

    /// <summary>
    /// 获取 Loop 标签颜色
    /// </summary>
    private string GetLoopTagColor()
    {
        if (Loop.IsExecuting)
            return "blue";
        return Loop.Success ? "green" : "red";
    }

    /// <summary>
    /// 获取时间戳显示
    /// </summary>
    private string GetTimestamp()
    {
        var time = Loop.Messages.FirstOrDefault()?.Timestamp ?? DateTime.Now;
        return time.ToString("HH:mm:ss");
    }

    /// <summary>
    /// 渲染 Markdown 内容（带缓存优化）
    /// </summary>
    private string RenderMarkdown(string content, string messageId)
    {
        if (string.IsNullOrEmpty(content))
            return string.Empty;
        
        // 检测 Loop 切换，清空缓存
        if (Loop.LoopId != _lastLoopId)
        {
            _lastLoopId = Loop.LoopId;
            _renderCache.Clear();
            _reasoningCache.Clear();
        }
        
        // 检查缓存
        if (_renderCache.TryGetValue(messageId, out var cached))
        {
            if (cached.content == content)
                return cached.html;
        }
        
        // 重新渲染并缓存
        var html = Markdig.Markdown.ToHtml(content, MarkdownPipeline);
        _renderCache[messageId] = (content, html);
        return html;
    }
    
    /// <summary>
    /// 渲染推理内容 Markdown（带缓存优化）
    /// </summary>
    private string RenderReasoningMarkdown(string reasoning, string messageId)
    {
        if (string.IsNullOrEmpty(reasoning))
            return string.Empty;
        
        // 检测 Loop 切换，清空缓存
        if (Loop.LoopId != _lastLoopId)
        {
            _lastLoopId = Loop.LoopId;
            _renderCache.Clear();
            _reasoningCache.Clear();
        }
        
        // 检查缓存
        if (_reasoningCache.TryGetValue(messageId, out var cached))
        {
            if (cached.reasoning == reasoning)
                return cached.html;
        }
        
        // 重新渲染并缓存
        var html = Markdig.Markdown.ToHtml(reasoning, MarkdownPipeline);
        _reasoningCache[messageId] = (reasoning, html);
        return html;
    }

    /// <summary>
    /// 获取推理内容预览
    /// </summary>
    private string GetReasoningPreview(string reasoning)
    {
        if (string.IsNullOrEmpty(reasoning))
            return string.Empty;
        var firstLine = reasoning.Split('\n')[0].Trim();
        if (firstLine.Length > 50)
            return firstLine[..50] + "...";
        return firstLine;
    }

    public void Dispose()
    {
        // 清理资源
        _reasoningExpandedStates.Clear();
        _renderCache.Clear();
        _reasoningCache.Clear();
    }
}
