@using AntDesign
@using Seeing.Agent.TokenBudget.Api.Responses

<div class="token-budget-inline @GetStatusClass()">
    <div class="progress-mini">
        <div class="progress-fill" style="width: @GetProgressValue()%;"></div>
    </div>
    <span class="token-text">@FormatTokens(Status.CurrentTokens)/@FormatTokens(Status.MaxTokens)</span>
    <span class="token-percent">@Status.UsagePercentage.ToString("F1")%</span>
    @if (Status.Level != "normal")
    {
        <span class="status-indicator @Status.Level">⚠</span>
    }
@*     <Tooltip Title="查看详情">
        <Button Type="@ButtonType.Text" Size="@ButtonSize.Small" Class="expand-btn" OnClick="ToggleDetails">📊</Button>
    </Tooltip> *@
</div>

<Modal Visible="@ShowDetails"
       Title="Token 预算"
       Footer="null"
       Width="360"
       Centered="true"
       OnCancel="HandleCancel"
       OnOk="HandleCancel">
    <div class="token-details">
        <!-- 使用情况概览 -->
        <div class="usage-overview">
            <div class="usage-bar">
                <div class="used-bar" style="width: @Math.Min(100, Status.UsagePercentage)%;"></div>
            </div>
            <div class="usage-labels">
                <span>已使用 @FormatTokens(Status.CurrentTokens)</span>
                <span>@Status.UsagePercentage.ToString("F1")%</span>
                <span>可用 @FormatTokens(Status.AvailableTokens)</span>
            </div>
        </div>

        @if (Status.NeedsCompaction)
        {
            <Alert Type="@AlertType.Warning"
                   Message="Token 使用率较高，建议压缩会话以释放空间"
                   ShowIcon="true"
                   Style="margin-top: 16px;" />
            <div style="margin-top: 12px; text-align: center;">
                <Button Type="@ButtonType.Primary" OnClick="TriggerCompaction">压缩会话</Button>
            </div>
        }
    </div>
</Modal>

@code {
    [Parameter]
    public BudgetStatusResponse Status { get; set; } = new();

    [Parameter]
    public EventCallback OnCompactRequested { get; set; }

    [Parameter]
    public EventCallback OnSettingsRequested { get; set; }

    private bool ShowDetails { get; set; }

    private string GetStatusClass() => Status.Level switch
    {
        "warning" => "status-warning",
        "critical" => "status-critical",
        "overflow" => "status-overflow",
        _ => "status-normal"
    };

    private double GetProgressValue() => Math.Min(100, Status.UsagePercentage);

    private string FormatTokens(int tokens)
    {
        if (tokens >= 1000000) return $"{tokens / 1000000.0:F1}M";
        if (tokens >= 1000) return $"{tokens / 1000.0:F1}K";
        return tokens.ToString();
    }

    private void ToggleDetails() => ShowDetails = !ShowDetails;

    private void HandleCancel() => ShowDetails = false;

    private async Task TriggerCompaction()
    {
        ShowDetails = false;
        await OnCompactRequested.InvokeAsync();
    }
}
