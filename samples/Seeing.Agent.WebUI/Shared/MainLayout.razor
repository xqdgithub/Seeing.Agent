@inherits LayoutComponentBase
@using AntDesign
@using Seeing.Agent.Core.Interfaces
@using Seeing.Agent.Llm
@using Seeing.Agent.WebUI.State
@using Seeing.Agent.WebUI.Models
@using Seeing.Agent.WebUI.Components
@using Seeing.Agent.WebUI.Services
@using Seeing.Session.Core
@using Seeing.Session.Management
@inject AppState AppState
@inject SessionState SessionState
@inject SessionProvider SessionProvider
@inject NavigationManager NavigationManager
@inject IMessageService MessageService
@inject IAgentRegistry AgentRegistry
@inject ILlmService LlmService
@implements IDisposable

<Layout Class="app-layout" Style="min-height: 100vh;">
    <!-- 左侧边栏 -->
    <AppSidebar Collapsed="@AppState.SidebarCollapsed"
                CollapsedChanged="@OnSiderCollapse" />
    
    <!-- 主内容区域 -->
    <Layout Class="@(AppState.SidebarCollapsed ? "main-layout-content collapsed" : "main-layout-content")">
        <Content Class="content-area">
            @Body
        </Content>
    </Layout>
</Layout>

<PermissionHost />

@code {
    private bool _hasRendered;

    protected override async Task OnInitializedAsync()
    {
        AppState.OnChange += OnAppStateChange;
        SessionProvider.OnCurrentSessionChanged += OnCurrentSessionChanged;

        await LoadAgentsAndModelsAsync();

        await SessionProvider.InitializeSessionListAsync();
        var sessionList = SessionProvider.GetSessionList();

        if (sessionList.Count > 0)
        {
            var recentSession = sessionList.First();
            await SessionProvider.LoadSessionAsync(recentSession.Id);
            AppState.CurrentSessionId = recentSession.Id;
        }

        SessionState.SelectedAgent = AppState.SelectedAgent;
        SessionState.SelectedModel = AppState.SelectedModel;
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
            _hasRendered = true;
    }

    private void OnAppStateChange()
    {
        RequestRender();
    }

    private void OnCurrentSessionChanged()
    {
        if (SessionProvider.CurrentSession != null)
        {
            SessionState.SetSession(SessionProvider.CurrentSession);
            AppState.CurrentSessionId = SessionProvider.CurrentSession.Id;
            AppState.NotifyChange();
        }
    }

    private void RequestRender()
    {
        if (!_hasRendered)
            return;
        _ = InvokeAsync(StateHasChanged);
    }
    
    private async Task LoadAgentsAndModelsAsync()
    {
        try
        {
            var primaryAgents = await AgentRegistry.GetPrimaryAgentsAsync();
            AppState.AvailableAgents = primaryAgents.Where(a => !string.IsNullOrEmpty(a.Name)).ToList();
            
            if (string.IsNullOrEmpty(AppState.SelectedAgent) && AppState.AvailableAgents.Count > 0)
            {
                var defaultAgent = await AgentRegistry.GetDefaultAgentNameAsync();
                AppState.SelectedAgent = defaultAgent ?? AppState.AvailableAgents[0].Name;
            }
            
            AppState.AvailableModels = LlmService.GetAvailableModels();
            
            if (string.IsNullOrEmpty(AppState.SelectedModel) && AppState.AvailableModels.Count > 0)
            {
                var firstWithProvider = AppState.AvailableModels.FirstOrDefault(m => !string.IsNullOrEmpty(m.Value.Provider));
                AppState.SelectedModel = firstWithProvider.Key ?? AppState.AvailableModels.Keys.First();
            }

            AppState.NotifyChange();
        }
        catch (Exception ex)
        {
            AppState.ErrorMessage = $"加载失败: {ex.Message}";
        }
    }
    
    private void OnSiderCollapse(bool collapsed)
    {
        AppState.SidebarCollapsed = collapsed;
    }
    
    public void Dispose()
    {
        AppState.OnChange -= OnAppStateChange;
        SessionProvider.OnCurrentSessionChanged -= OnCurrentSessionChanged;
    }
}
