@page "/"
@using AntDesign
@using Seeing.Agent.WebUI.Services
@using Seeing.Session.Core
@inject SessionState SessionState
@inject SessionProvider SessionProvider
@inject AppState AppState
@inject NavigationManager NavigationManager

<div class="home-page">
    <div class="home-hero">
        <div class="hero-icon">🤖</div>
        <h1 class="hero-title">Seeing.Agent</h1>
        <p class="hero-subtitle">AI Agent 智能体框架 · Blazor Server Web 界面</p>
    </div>
    
    <div class="home-actions">
        <Button Type="@ButtonType.Primary"
                Size="@ButtonSize.Large"
                Icon="@IconType.Outline.Message"
                OnClick="@GoToSession">
            开始对话
        </Button>
        <Button Type="@ButtonType.Default"
                Size="@ButtonSize.Large"
                Icon="@IconType.Outline.Plus"
                OnClick="@CreateNewSession">
            新建会话
        </Button>
    </div>
    
    <div class="home-stats">
        <div class="stat-card">
            <div class="stat-icon">
                <Icon Type="@IconType.Outline.Team" />
            </div>
            <div class="stat-info">
                <div class="stat-value">@_sessionCount</div>
                <div class="stat-label">会话</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">
                <Icon Type="@IconType.Outline.Robot" />
            </div>
            <div class="stat-info">
                <div class="stat-value">@AppState.SelectedAgent</div>
                <div class="stat-label">当前智能体</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon">
                <Icon Type="@IconType.Outline.CloudServer" />
            </div>
            <div class="stat-info">
                <div class="stat-value">@GetModelShortName()</div>
                <div class="stat-label">当前模型</div>
            </div>
        </div>
    </div>
    
    @if (SessionState.Messages.Count > 0)
    {
        <div class="home-recent">
            <div class="recent-header">
                <h3>最近消息</h3>
                <Button Type="@ButtonType.Link" OnClick="@GoToSession">
                    查看全部 →
                </Button>
            </div>
            <div class="recent-messages">
                @foreach (var msg in SessionState.Messages.TakeLast(4))
                {
                    <div class="@GetMessageClass(msg.Role)">
                        <span class="msg-role">@GetRoleIcon(msg.Role)</span>
                        <span class="msg-content">@(msg.Content.Length > 80 ? msg.Content.Substring(0, 80) + "..." : msg.Content)</span>
                    </div>
                }
            </div>
        </div>
    }
</div>

<style>
.home-page {
    max-width: 800px;
    margin: 0 auto;
    padding: 40px 20px;
}

.home-hero {
    text-align: center;
    margin-bottom: 40px;
}

.hero-icon {
    font-size: 64px;
    margin-bottom: 16px;
}

.hero-title {
    font-size: 32px;
    font-weight: 600;
    color: #1890ff;
    margin: 0 0 8px 0;
}

.hero-subtitle {
    font-size: 14px;
    color: #8c8c8c;
    margin: 0;
}

.home-actions {
    display: flex;
    justify-content: center;
    gap: 16px;
    margin-bottom: 40px;
}

.home-stats {
    display: flex;
    gap: 16px;
    margin-bottom: 40px;
}

.stat-card {
    flex: 1;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px;
    background: #fff;
    border-radius: 8px;
    border: 1px solid #e8e8e8;
}

.stat-icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #e6f7ff;
    border-radius: 8px;
    color: #1890ff;
    font-size: 20px;
}

.stat-value {
    font-size: 16px;
    font-weight: 600;
    color: #262626;
}

.stat-label {
    font-size: 12px;
    color: #8c8c8c;
}

.home-recent {
    background: #fff;
    border-radius: 8px;
    border: 1px solid #e8e8e8;
    padding: 16px;
}

.recent-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
}

.recent-header h3 {
    margin: 0;
    font-size: 14px;
    font-weight: 500;
}

.recent-messages {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.msg-item {
    display: flex;
    gap: 8px;
    padding: 8px;
    border-radius: 6px;
    font-size: 13px;
}

.msg-user {
    background: #e6f7ff;
}

.msg-assistant {
    background: #f6ffed;
}

.msg-system {
    background: #fff7e6;
}

.msg-role {
    flex-shrink: 0;
}

.msg-content {
    color: #595959;
    line-height: 1.5;
}

@@media (max-width: 768px) {
    .home-stats {
        flex-direction: column;
    }
    
    .home-actions {
        flex-direction: column;
        align-items: center;
    }
}
</style>

@code {
    private int _sessionCount = 0;
    
    protected override async Task OnInitializedAsync()
    {
        await SessionProvider.InitializeSessionListAsync();
        _sessionCount = SessionProvider.GetSessionList().Count;
        
        if (_sessionCount > 0)
        {
            var recentSession = SessionProvider.GetSessionList().First();
            await SessionProvider.LoadSessionAsync(recentSession.Id);
            AppState.CurrentSessionId = recentSession.Id;
        }
    }
    
    private void GoToSession()
    {
        if (!string.IsNullOrEmpty(AppState.CurrentSessionId))
        {
            NavigationManager.NavigateTo($"/session/{AppState.CurrentSessionId}");
        }
        else
        {
            NavigationManager.NavigateTo("/sessions");
        }
    }
    
    private async Task CreateNewSession()
    {
        var newSession = await SessionProvider.CreateSessionAsync("新会话", AppState.SelectedAgent);
        newSession.SelectedModel = AppState.SelectedModel;
        await SessionProvider.SaveCurrentSessionAsync();
        NavigationManager.NavigateTo($"/session/{newSession.Id}");
    }
    
    private string GetModelShortName()
    {
        if (string.IsNullOrEmpty(AppState.SelectedModel))
            return "-";
        var parts = AppState.SelectedModel.Split('/');
        return parts.Length > 1 ? parts[1] : AppState.SelectedModel;
    }
    
    private string GetMessageClass(string role) => role.ToLowerInvariant() switch
    {
        "user" => "msg-item msg-user",
        "assistant" => "msg-item msg-assistant",
        "system" => "msg-item msg-system",
        _ => "msg-item"
    };
    
    private string GetRoleIcon(string role) => role.ToLowerInvariant() switch
    {
        "user" => "👤",
        "assistant" => "🤖",
        "system" => "⚙️",
        _ => "📝"
    };
}
