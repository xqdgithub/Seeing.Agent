@page "/cron-jobs"
@using AntDesign
@using Seeing.Agent.Scheduler
@using Seeing.Agent.Scheduler.Abstractions
@using Seeing.Agent.Scheduler.Models
@using Seeing.Agent.WebUI.Components.CronJobs
@using Seeing.Agent.WebUI.Services
@inject IScheduleManager ScheduleManager
@inject IScheduleRepository ScheduleRepository
@inject SchedulerStatusService StatusService
@inject JobNotificationService NotificationService
@inject IMessageService MessageService
@inject NavigationManager Navigation
@implements IDisposable

<PageTitle>定时任务 - Seeing.Agent</PageTitle>

<WorkspacePageShell Loading="@_loading" IsEmpty="@(!_rows.Any())"
                    EmptyTitle="暂无定时任务" EmptyDescription="创建第一个定时任务以自动执行 Agent 或发送消息">
    <Breadcrumb>
        <BreadcrumbItem>控制中心</BreadcrumbItem>
        <BreadcrumbItem>定时任务</BreadcrumbItem>
    </Breadcrumb>
    <Extra>
        <Space>
            <Button Icon="@IconType.Outline.Reload" OnClick="LoadAsync">刷新</Button>
            <Button Type="@ButtonType.Primary" Icon="@IconType.Outline.Plus" OnClick="ShowCreate">新建任务</Button>
        </Space>
    </Extra>
    <Stats>
        <div class="stat-item">
            <div class="stat-icon"><Icon Type="@IconType.Outline.ClockCircle" /></div>
            <div class="stat-content">
                <span class="stat-value">@_status.TotalJobs</span>
                <span class="stat-label">任务总数</span>
            </div>
        </div>
        <div class="stat-item">
            <div class="stat-icon" style="color: #52c41a;"><Icon Type="@IconType.Outline.CheckCircle" /></div>
            <div class="stat-content">
                <span class="stat-value">@_rows.Count(r => r.State == JobState.Scheduled)</span>
                <span class="stat-label">已调度</span>
            </div>
        </div>
        <div class="stat-item">
            <div class="stat-icon" style="color: #1890ff;"><Icon Type="@IconType.Outline.Sync" Spin="@(_status.RunningJobs > 0)" /></div>
            <div class="stat-content">
                <span class="stat-value">@_status.RunningJobs</span>
                <span class="stat-label">运行中</span>
            </div>
        </div>
        <div class="stat-item">
            <div class="stat-icon" style="color: #faad14;"><Icon Type="@IconType.Outline.PauseCircle" /></div>
            <div class="stat-content">
                <span class="stat-value">@_rows.Count(r => r.State == JobState.Paused)</span>
                <span class="stat-label">已暂停</span>
            </div>
        </div>
        <div class="stat-item">
            <div class="stat-icon" style="color: #8c8c8c;"><Icon Type="@IconType.Outline.Stop" /></div>
            <div class="stat-content">
                <span class="stat-value">@_rows.Count(r => r.State == JobState.Disabled)</span>
                <span class="stat-label">已禁用</span>
            </div>
        </div>
    </Stats>
    <ChildContent>
        @* 状态筛选标签页 *@
        <Tabs @bind-ActiveKey="_activeTab" OnChange="OnTabChange" Style="margin-bottom: 16px;">
            <TabPane Key="all" Tab="@($"全部 ({_rows.Count})")" />
            <TabPane Key="scheduled" Tab="@($"已调度 ({_rows.Count(r => r.State == JobState.Scheduled)})")" />
            <TabPane Key="running" Tab="@($"运行中 ({_rows.Count(r => r.State == JobState.Running)})")" />
            <TabPane Key="paused" Tab="@($"已暂停 ({_rows.Count(r => r.State == JobState.Paused)})")" />
            <TabPane Key="disabled" Tab="@($"已禁用 ({_rows.Count(r => r.State == JobState.Disabled)})")" />
        </Tabs>
        
        <Table TItem="JobRow" DataSource="@_filteredRows" RowKey="@(j => j.Id)" @key="_rowsVersion">
            <PropertyColumn Property="c => c.Name" Title="名称" />
            <PropertyColumn Property="c => c.Id" Title="ID" />
            <PropertyColumn Property="c => c.TaskType" Title="类型" />
            <PropertyColumn Property="c => c.ScheduleText" Title="调度" />
            <PropertyColumn Property="c => c.Agent" Title="Agent" />
            <PropertyColumn Property="c => c.State" Title="状态">
                <JobStatusBadge State="@context.State" />
            </PropertyColumn>
            <PropertyColumn Property="c => c.NextRunText" Title="下次运行">
                <JobNextRunTimer NextRun="@context.NextFireTime" />
            </PropertyColumn>
            <ActionColumn Title="操作">
                <Space>
                    @if (CanRun(context.State))
                    {
                        <Button Size="@ButtonSize.Small" 
                                Loading="@_runningJobs.Contains(context.Id)" 
                                OnClick="@(() => RunOnce(context.Id))">
                            @if (_runningJobs.Contains(context.Id))
                            {
                                <Text>执行中</Text>
                            }
                            else
                            {
                                <Text>运行</Text>
                            }
                        </Button>
                    }
                    @if (CanPause(context.State))
                    {
                        <Button Size="@ButtonSize.Small" OnClick="@(() => PauseJob(context.Id))">暂停</Button>
                    }
                    @if (CanResume(context.State))
                    {
                        <Button Size="@ButtonSize.Small" Type="@ButtonType.Primary" OnClick="@(() => ResumeJob(context.Id))">恢复</Button>
                    }
                    @if (CanDisable(context.State))
                    {
                        <Popconfirm Title="确定要禁用此任务吗？" OnConfirm="@(() => DisableJob(context.Id))">
                            <Button Size="@ButtonSize.Small">禁用</Button>
                        </Popconfirm>
                    }
                    @if (CanCancel(context.State))
                    {
                        <Popconfirm Title="确定要取消正在运行的任务吗？当前操作将被中断。" OnConfirm="@(() => CancelJob(context.Id))">
                            <Button Size="@ButtonSize.Small" Danger="true">取消</Button>
                        </Popconfirm>
                    }
                    @if (CanEdit(context.State))
                    {
                        <Button Size="@ButtonSize.Small" OnClick="@(() => EditJob(context.Id))">编辑</Button>
                    }
                    <Button Size="@ButtonSize.Small" OnClick="@(() => NavigateToDetail(context.Id))">详情</Button>
                    @if (CanDelete(context.State))
                    {
                        <Popconfirm Title="确定删除此任务？" OnConfirm="@(() => DeleteJob(context.Id))">
                            <Button Size="@ButtonSize.Small" Danger="true">删除</Button>
                        </Popconfirm>
                    }
                </Space>
            </ActionColumn>
        </Table>
    </ChildContent>
    <EmptyAction>
        <Button Type="@ButtonType.Primary" OnClick="ShowCreate">新建任务</Button>
    </EmptyAction>
</WorkspacePageShell>

<JobEditorModal Visible="@_editorVisible"
                VisibleChanged="@(v => _editorVisible = v)"
                Job="@_editingJob"
                IsEdit="@_isEdit"
                Saving="@_saving"
                OnSave="SaveJob" />

@code {
    private List<ScheduledJobSpec> _jobs = new();
    private List<JobRow> _rows = new();
    private List<JobRow> _filteredRows = new();
    private ScheduledJobSpec _editingJob = new();
    private SchedulerStatus _status = new();
    private bool _loading;
    private bool _editorVisible;
    private bool _isEdit;
    private bool _saving;
    private string _activeTab = "all";
    private HashSet<string> _runningJobs = new();  // 追踪正在执行的任务
    private int _rowsVersion;  // 用于强制 Table 刷新

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        
        // 订阅通知
        NotificationService.JobError += OnJobError;
        NotificationService.JobSuccess += OnJobSuccess;
        NotificationService.JobProgress += OnJobProgress;
        StatusService.JobStatusChanged += OnJobStatusChanged;
    }

    public void Dispose()
    {
        NotificationService.JobError -= OnJobError;
        NotificationService.JobSuccess -= OnJobSuccess;
        NotificationService.JobProgress -= OnJobProgress;
        StatusService.JobStatusChanged -= OnJobStatusChanged;
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            _jobs = (await ScheduleManager.ListJobsAsync()).ToList();
            _status = await StatusService.GetStatusAsync();
            
            var jobStatuses = await StatusService.GetAllJobStatusesAsync();
            var statusDict = jobStatuses.ToDictionary(s => s.JobId, s => s);

            _rows = _jobs.Select(j =>
            {
                var status = statusDict.GetValueOrDefault(j.Id);
                return new JobRow
                {
                    Id = j.Id,
                    Name = j.Name ?? j.Id,
                    TaskType = j.TaskType,
                    ScheduleText = GetScheduleText(j),
                    Agent = j.Agent ?? "",
                    Intent = j.Intent,
                    State = status?.State ?? JobState.Disabled,
                    NextFireTime = status?.NextFireTime,
                    NextRunText = status?.NextFireTime?.ToString("yyyy-MM-dd HH:mm") ?? "-"
                };
            }).ToList();
            
            ApplyTabFilter();
            _rowsVersion++;
        }
        finally
        {
            _loading = false;
        }
    }

    private void OnTabChange(string key)
    {
        _activeTab = key;
        ApplyTabFilter();
    }

    private void ApplyTabFilter()
    {
        _filteredRows = _activeTab switch
        {
            "scheduled" => _rows.Where(r => r.State == JobState.Scheduled).ToList(),
            "running" => _rows.Where(r => r.State == JobState.Running).ToList(),
            "paused" => _rows.Where(r => r.State == JobState.Paused).ToList(),
            "disabled" => _rows.Where(r => r.State == JobState.Disabled).ToList(),
            _ => _rows.ToList()
        };
    }

    // ===== 操作权限控制 =====
    
    private static bool CanRun(JobState state) => state == JobState.Scheduled || state == JobState.Paused;
    
    private static bool CanPause(JobState state) => state == JobState.Scheduled;
    
    private static bool CanResume(JobState state) => state == JobState.Paused;
    
    private static bool CanDisable(JobState state) => state == JobState.Scheduled || state == JobState.Paused;
    
    private static bool CanCancel(JobState state) => state == JobState.Running;
    
    private static bool CanEdit(JobState state) => state != JobState.Running;
    
    private static bool CanDelete(JobState state) => state != JobState.Running;

    private void OnJobError(object? sender, JobErrorEventArgs args)
    {
        _ = InvokeAsync(() =>
        {
            MessageService.Error($"任务 {args.JobId} 执行失败: {args.Error}");
            return LoadAsync();
        });
    }

    private void OnJobSuccess(object? sender, JobSuccessEventArgs args)
    {
        _ = InvokeAsync(() =>
        {
            MessageService.Success($"任务 {args.JobId} 执行成功");
            _runningJobs.Remove(args.JobId);
            return LoadAsync();
        });
    }
    
    private void OnJobProgress(object? sender, JobProgressEventArgs args)
    {
        _ = InvokeAsync(() =>
        {
            switch (args.Stage)
            {
                case JobProgressStage.Triggered:
                    _runningJobs.Add(args.JobId);
                    MessageService.Info($"任务 {args.JobId} 已触发");
                    break;
                case JobProgressStage.Completed:
                    _runningJobs.Remove(args.JobId);
                    break;
                case JobProgressStage.Failed:
                    _runningJobs.Remove(args.JobId);
                    break;
                case JobProgressStage.Cancelled:
                    _runningJobs.Remove(args.JobId);
                    MessageService.Warning($"任务 {args.JobId} 已取消");
                    break;
            }
            StateHasChanged();
            return Task.CompletedTask;
        });
    }
    
    private void OnJobStatusChanged(object? sender, JobStatusChangedEventArgs args)
    {
        _ = InvokeAsync(async () =>
        {
            // 状态变化时刷新列表
            if (args.NewState != args.OldState)
            {
                await LoadAsync();
            }
        });
    }

    private void ShowCreate()
    {
        _editingJob = new ScheduledJobSpec
        {
            Id = $"job-{Guid.NewGuid():N}"[..12],
            Intent = ScheduleIntent.Active,
            Schedule = new ScheduleSpec { Type = ScheduleTypes.Cron, Timezone = "Asia/Shanghai" },
            Dispatch = new DispatchSpec { Target = new DispatchTarget { SessionId = "main" } }
        };
        _isEdit = false;
        _editorVisible = true;
    }

    private void EditJob(string id)
    {
        var job = _jobs.FirstOrDefault(j => j.Id == id);
        if (job == null) return;
        _editingJob = CloneJob(job);
        _isEdit = true;
        _editorVisible = true;
    }

    private static ScheduledJobSpec CloneJob(ScheduledJobSpec job) =>
        System.Text.Json.JsonSerializer.Deserialize<ScheduledJobSpec>(
            System.Text.Json.JsonSerializer.Serialize(job)) ?? new ScheduledJobSpec();

    private async Task SaveJob(ScheduledJobSpec job)
    {
        _saving = true;
        try
        {
            await ScheduleManager.CreateOrReplaceJobAsync(job);
            MessageService.Success("任务已保存");
            await LoadAsync();
        }
        finally { _saving = false; }
    }

    private async Task DeleteJob(string id)
    {
        await ScheduleManager.DeleteJobAsync(id);
        MessageService.Success("任务已删除");
        await LoadAsync();
    }

    private async Task RunOnce(string id)
    {
        var result = await ScheduleManager.RunJobOnceAsync(id);
        switch (result)
        {
            case TriggerResult.Accepted accepted:
                MessageService.Info($"任务已触发，RunId={accepted.RunId}");
                break;
            case TriggerResult.NotFound:
                MessageService.Error("任务未找到");
                break;
            case TriggerResult.Disabled:
                MessageService.Warning("任务已禁用");
                break;
            case TriggerResult.Conflict conflict:
                MessageService.Warning($"触发冲突: {conflict.Reason}");
                break;
        }
        await LoadAsync();
    }

    private async Task PauseJob(string id)
    {
        await StatusService.PauseJobAsync(id);
        MessageService.Info("任务已暂停");
        await LoadAsync();
    }

    private async Task ResumeJob(string id)
    {
        await StatusService.ResumeJobAsync(id);
        MessageService.Success("任务已恢复");
        await LoadAsync();
    }

    private async Task DisableJob(string id)
    {
        await StatusService.DisableJobAsync(id);
        MessageService.Warning("任务已禁用");
        await LoadAsync();
    }

    private async Task CancelJob(string id)
    {
        var success = await StatusService.CancelJobAsync(id);
        if (success)
        {
            MessageService.Success("任务已取消");
        }
        else
        {
            MessageService.Warning("取消任务失败，任务可能已完成");
        }
        await LoadAsync();
    }

    private void NavigateToDetail(string jobId)
    {
        Navigation.NavigateTo($"/cron-jobs/{jobId}");
    }

    private static string GetScheduleText(ScheduledJobSpec job) => job.Schedule.Type switch
    {
        ScheduleTypes.Cron => job.Schedule.Cron ?? "cron",
        ScheduleTypes.Interval => job.Schedule.Every ?? "interval",
        ScheduleTypes.Once => job.Schedule.RunAt?.ToString("yyyy-MM-dd HH:mm") ?? "once",
        _ => job.Schedule.Type
    };

    private sealed class JobRow
    {
        public string Id { get; set; } = "";
        public string Name { get; set; } = "";
        public string TaskType { get; set; } = "";
        public string ScheduleText { get; set; } = "";
        public string Agent { get; set; } = "";
        public ScheduleIntent Intent { get; set; }
        public JobState State { get; set; }
        public DateTime? NextFireTime { get; set; }
        public string NextRunText { get; set; } = "";
    }
}