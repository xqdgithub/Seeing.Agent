@page "/home"
@using AntDesign
@using Seeing.Agent.WebUI.Models
@using Seeing.Agent.WebUI.Services
@using Seeing.Session.Core
@inject SessionState SessionState
@inject SessionProvider SessionProvider
@inject AppState AppState
@inject NavigationManager NavigationManager

<div Class="home-welcome-container">
    <!-- 欢迎头部 -->
    <div Class="welcome-header">
        <!-- Slot: home_logo -->
        <SlotHost SlotName="home_logo" />
        
        <div Class="welcome-title">
            <h1 Class="app-brand">Seeing.Agent</h1>
            <p Class="app-description">
                智能 Agent 框架 · 代码助手 · 知识引擎
            </p>
        </div>
    </div>

    <!-- 特性展示 -->
    <div Class="welcome-features">
        <div Class="feature-card">
            <Icon Type="@IconType.Outline.Team" Class="feature-icon" />
            <div Class="feature-title">多 Agent 支持</div>
            <div Class="feature-desc">支持主 Agent 和子 Agent 协作，灵活配置系统提示词和模型参数</div>
        </div>
        <div Class="feature-card">
            <Icon Type="@IconType.Outline.Tool" Class="feature-icon" />
            <div Class="feature-title">工具调用可视化</div>
            <div Class="feature-desc">实时显示工具执行状态，支持权限控制和执行取消</div>
        </div>
        <div Class="feature-card">
            <Icon Type="@IconType.Outline.History" Class="feature-icon" />
            <div Class="feature-title">会话管理</div>
            <div Class="feature-desc">自动保存会话历史，支持会话分支和快速切换</div>
        </div>
    </div>

    <!-- 大输入框 -->
    <div Class="welcome-input">
        <!-- Slot: home_prompt -->
        <SlotHost SlotName="home_prompt" />
        
        <div Class="large-prompt-wrapper">
            <TextArea @bind-Value="@WelcomeInput"
                      Placeholder="输入您的问题或任务，开始与 AI Agent 对话..."
                      AutoSize="true"
                      Class="large-prompt-textarea"
                      @onkeydown="@OnKeyDown" />
            
            <div Class="prompt-footer">
                <div Class="prompt-tips">
                    <Space>
                        <SpaceItem>
                            <Tag Color="default">Enter 发送</Tag>
                        </SpaceItem>
                        <SpaceItem>
                            <Tag Color="default">Shift+Enter 换行</Tag>
                        </SpaceItem>
                        <SpaceItem>
                            <Tag Color="default">支持粘贴图片</Tag>
                        </SpaceItem>
                    </Space>
                </div>
                <Button Type="@ButtonType.Primary"
                        Size="@ButtonSize.Large"
                        Icon="@IconType.Outline.Send"
                        OnClick="@OnStartChat">
                    开始对话
                </Button>
            </div>
        </div>
    </div>

    <!-- 快捷入口 -->
    <div Class="quick-actions">
        <div Class="quick-action-title">快捷入口</div>
        <Space Size="@SpaceSize.Middle">
            <SpaceItem>
                <Button Type="@ButtonType.Default" Size="@ButtonSize.Large" OnClick="@GoToChat">
                    <Icon Type="@IconType.Outline.Message" />
                    <span>进入聊天</span>
                </Button>
            </SpaceItem>
            <SpaceItem>
                <Button Type="@ButtonType.Default" Size="@ButtonSize.Large" OnClick="@GoToSettings">
                    <Icon Type="@IconType.Outline.Setting" />
                    <span>设置</span>
                </Button>
            </SpaceItem>
            <SpaceItem>
                <Button Type="@ButtonType.Default" Size="@ButtonSize.Large" OnClick="@GoToDocs">
                    <Icon Type="@IconType.Outline.Book" />
                    <span>文档</span>
                </Button>
            </SpaceItem>
        </Space>
    </div>

    <!-- 页脚 -->
    <div Class="welcome-footer">
        <span Class="footer-text">© 2026 Seeing.Agent · MIT License</span>
    </div>
</div>

@code {
    /// <summary>
    /// 欢迎页输入文本
    /// </summary>
    private string WelcomeInput { get; set; } = "";

    /// <summary>
    /// 键盘事件处理
    /// </summary>
    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await OnStartChat();
        }
    }

    /// <summary>
    /// 开始对话
    /// </summary>
    private async Task OnStartChat()
    {
        if (string.IsNullOrWhiteSpace(WelcomeInput))
            return;

        // 创建新会话
        var newSession = await SessionProvider.CreateSessionAsync("新对话", AppState.SelectedAgent);
        
        // 设置 Model
        newSession.SelectedModel = AppState.SelectedModel;
        newSession.SelectedModelProvider = AppState.SelectedModelProvider;

        // 添加用户消息
        newSession.AddMessage(SessionMessage.UserMessage(WelcomeInput.Trim()));

        // 设置到 SessionState
        SessionState.SetSession(newSession);

        // 保存会话
        await SessionProvider.SaveCurrentSessionAsync();

        // 导航到聊天页面
        NavigationManager.NavigateTo($"/session/{newSession.Id}");
    }

    /// <summary>
    /// 进入聊天页面
    /// </summary>
    private void GoToChat()
    {
        NavigationManager.NavigateTo("/");
    }

    /// <summary>
    /// 进入设置页面
    /// </summary>
    private void GoToSettings()
    {
        // TODO: 设置页面
        NavigationManager.NavigateTo("/settings");
    }

    /// <summary>
    /// 进入文档页面
    /// </summary>
    private void GoToDocs()
    {
        // TODO: 文档页面
        NavigationManager.NavigateTo("/docs");
    }
}