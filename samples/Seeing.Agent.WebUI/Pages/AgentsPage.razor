@page "/agents"
@using AntDesign
@using Seeing.Agent.Core.Interfaces
@using Seeing.Agent.Core.Models
@using Seeing.Agent.Configuration
@using Seeing.Agent.WebUI.Services
@inject IAgentManager AgentManager
@inject NavigationManager NavigationManager
@inject IMessageService MessageService
@inject IWorkspaceProvider WorkspaceProvider

<PageTitle>智能体管理 - Seeing.Agent</PageTitle>

<WorkspacePageShell Loading="@_loading" IsEmpty="@(!_rows.Any())"
                    EmptyTitle="暂无智能体" EmptyDescription="请检查 Agent 配置">
    <Breadcrumb>
        <BreadcrumbItem>设置</BreadcrumbItem>
        <BreadcrumbItem>智能体管理</BreadcrumbItem>
    </Breadcrumb>
    <Extra>
        <Space>
            <Select TItemValue="ConfigLevel" TItem="ConfigLevel" @bind-Value="_selectedLevel" Style="width: 120px;">
                <SelectOption TItemValue="ConfigLevel" TItem="ConfigLevel" Value="@ConfigLevel.Project">项目级</SelectOption>
                <SelectOption TItemValue="ConfigLevel" TItem="ConfigLevel" Value="@ConfigLevel.User">用户级</SelectOption>
            </Select>
            <Button Type="@ButtonType.Primary" Icon="@IconType.Outline.Plus" OnClick="OpenCreateDialog">新增 MD 配置</Button>
            <Button Icon="@IconType.Outline.Reload" OnClick="LoadAsync">刷新</Button>
        </Space>
    </Extra>
    <Stats>
        <div class="stat-item">
            <div class="stat-icon"><Icon Type="@IconType.Outline.Robot" /></div>
            <div class="stat-content">
                <span class="stat-value">@_rows.Count</span>
                <span class="stat-label">智能体总数</span>
            </div>
        </div>
        <div class="stat-item">
            <div class="stat-icon"><Icon Type="@IconType.Outline.Star" /></div>
            <div class="stat-content">
                <span class="stat-value">@_defaultAgent</span>
                <span class="stat-label">默认智能体</span>
            </div>
        </div>
        <div class="stat-item">
            <div class="stat-icon"><Icon Type="@IconType.Outline.FileText" /></div>
            <div class="stat-content">
                <span class="stat-value">@_mdConfigs.Count</span>
                <span class="stat-label">MD 配置</span>
            </div>
        </div>
    </Stats>
    <ChildContent>
        <Table TItem="AgentRow" DataSource="@_rows" RowKey="@(a => a.Name)" Size="@TableSize.Middle">
            <PropertyColumn Property="c => c.Name" Title="名称" />
            <PropertyColumn Property="c => c.DefaultLabel" Title="默认" />
            <PropertyColumn Property="c => c.Description" Title="描述" />
            <PropertyColumn Property="c => c.Source" Title="来源">
                <Tag Color="@GetSourceColor(context)">@GetSourceText(context)</Tag>
            </PropertyColumn>
            <PropertyColumn Property="c => c.StatusText" Title="状态">
                @if (context.Disabled)
                {
                    <Tag Color="@("red")">已禁用</Tag>
                }
                else if (context.IsHidden)
                {
                    <Tag Color="@("orange")">已隐藏</Tag>
                }
                else
                {
                    <Tag Color="@("green")">启用</Tag>
                }
            </PropertyColumn>
            <ActionColumn Title="操作">
                <Space>
                    <Button Size="@ButtonSize.Small"
                            Disabled="@context.IsDefault"
                            OnClick="@(() => SetDefault(context.Name))">设为默认</Button>
                    <Button Size="@ButtonSize.Small" Type="@ButtonType.Primary"
                            OnClick="@(() => GoConfig(context.Name))">配置</Button>
                    @if (context.IsMdConfig && context.IsBuiltIn)
                    {
                        <Popconfirm Title="确定要删除覆盖配置吗？将恢复为内置默认配置。"
                                    OnConfirm="@(() => DeleteMdConfig(context.Name, context.Level))">
                            <Button Size="@ButtonSize.Small" Danger>删除覆盖</Button>
                        </Popconfirm>
                    }
                    else if (context.IsMdConfig && !context.IsBuiltIn)
                    {
                        <Popconfirm Title="确定要删除此自定义智能体吗？"
                                    OnConfirm="@(() => DeleteMdConfig(context.Name, context.Level))">
                            <Button Size="@ButtonSize.Small" Danger>删除</Button>
                        </Popconfirm>
                    }
                    else
                    {
                        <Button Size="@ButtonSize.Small" Disabled>删除</Button>
                    }
                    @if (context.Disabled)
                    {
                        <Button Size="@ButtonSize.Small" Type="@ButtonType.Primary"
                                OnClick="@(() => ToggleDisabled(context, false))">启用</Button>
                    }
                    else
                    {
                        <Popconfirm Title="确定要禁用此智能体吗？禁用后将完全不可用。"
                                    OnConfirm="@(() => ToggleDisabled(context, true))">
                            <Button Size="@ButtonSize.Small" Type="@ButtonType.Dashed" Danger>禁用</Button>
                        </Popconfirm>
                    }
                </Space>
            </ActionColumn>
        </Table>
    </ChildContent>
</WorkspacePageShell>

@if (_createModalVisible)
{
    <Modal Title="新建 MD 配置"
           Visible="true"
           OnOk="HandleCreate"
           OnCancel="@(() => _createModalVisible = false)"
           ConfirmLoading="_creating"
           OkText="@OkText"
           CancelText="@CancelText">
        <Form Model="_createForm" LabelColSpan="6">
            <FormItem Label="名称">
                <Input @bind-Value="_createForm.Name" Placeholder="请输入智能体名称" />
            </FormItem>
            <FormItem Label="层级">
                <RadioGroup @bind-Value="_createForm.Level">
                    <Radio Value="@ConfigLevel.Project">项目级</Radio>
                    <Radio Value="@ConfigLevel.User">用户级</Radio>
                </RadioGroup>
            </FormItem>
        </Form>
    </Modal>
}

<style>
    .agent-row-disabled {
        opacity: 0.6;
        background-color: #fafafa;
    }
</style>

@code {
    /// <summary>
    /// 常量文本（避免编码问题）
    /// </summary>
    private const string OkText = "创建";
    private const string CancelText = "取消";
    
    private List<AgentRow> _rows = new();
    private string _defaultAgent = "";
    private bool _loading;
    
    // MD 配置相关
    private ConfigLevel _selectedLevel = ConfigLevel.Project;
    private List<AgentMdInfo> _mdConfigs = new();
    
    // 创建配置相关
    private bool _createModalVisible;
    private bool _creating;
    private CreateForm _createForm = new();

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            _defaultAgent = await AgentManager.GetDefaultAgentNameAsync();
            var agents = await AgentManager.GetAgentsAsync();
            
            // 加载 MD 配置信息
            _mdConfigs = (await AgentManager.GetAllMdInfoAsync()).ToList();
            
            _rows = agents.Select(a => 
            {
                var mdInfo = _mdConfigs.FirstOrDefault(m => m.Name == a.Name);
                return new AgentRow
                {
                    Name = a.Name,
                    Description = a.Description ?? "",
                    IsMdConfig = mdInfo != null,
                    Level = mdInfo?.Level ?? ConfigLevel.Project,
                    IsDefault = a.Name == _defaultAgent,
                    DefaultLabel = a.Name == _defaultAgent ? "是" : "",
                    IsBuiltIn = a.IsNative,
                    IsHidden = a.IsHidden,
                    Disabled = a.Disabled
                };
            }).ToList();
        }
        finally { _loading = false; }
    }

    private async Task SetDefault(string name)
    {
        await AgentManager.SetDefaultAgentAsync(name);
        await LoadAsync();
        MessageService.Success($"已将 {name} 设为默认智能体");
    }

    private void GoConfig(string name) =>
        NavigationManager.NavigateTo($"/agent-config?agent={Uri.EscapeDataString(name)}");

    private void OpenCreateDialog()
    {
        _createForm = new CreateForm { Level = _selectedLevel };
        _createModalVisible = true;
    }

    private async Task HandleCreate()
    {
        if (string.IsNullOrWhiteSpace(_createForm.Name))
        {
            MessageService.Warning("请输入智能体名称");
            return;
        }

        _creating = true;
        try
        {
            await AgentManager.CreateMdConfigAsync(_createForm.Name, _createForm.Level);
            MessageService.Success($"已创建 MD 配置: {_createForm.Name}");
            _createModalVisible = false;
            await LoadAsync();
            
            // 跳转到配置页面
            GoConfig(_createForm.Name);
        }
        catch (Exception ex)
        {
            MessageService.Error($"创建失败: {ex.Message}");
        }
        finally
        {
            _creating = false;
        }
    }

    private async Task CreateOverride(string name)
    {
        try
        {
            await AgentManager.CreateMdConfigAsync(name, _selectedLevel);
            MessageService.Success($"已创建覆盖配置: {name}");
            await LoadAsync();
            GoConfig(name);
        }
        catch (Exception ex)
        {
            MessageService.Error($"创建失败: {ex.Message}");
        }
    }

    private async Task DeleteMdConfig(string name, ConfigLevel level)
    {
        try
        {
            var success = await AgentManager.DeleteMdConfigAsync(name, level);
            if (success)
            {
                MessageService.Success($"已删除 MD 配置: {name}");
                await LoadAsync();
            }
            else
            {
                MessageService.Error("删除失败");
            }
        }
        catch (Exception ex)
        {
            MessageService.Error($"删除失败: {ex.Message}");
        }
    }

    private async Task ToggleDisabled(AgentRow row, bool disabled)
    {
        try
        {
            var success = await AgentManager.SetAgentDisabledAsync(row.Name, disabled);
            if (success)
            {
                MessageService.Success(disabled ? $"已禁用智能体: {row.Name}" : $"已启用智能体: {row.Name}");
                await LoadAsync();
            }
            else
            {
                MessageService.Error("操作失败");
            }
        }
        catch (Exception ex)
        {
            MessageService.Error($"操作失败: {ex.Message}");
        }
    }

    private string GetSourceText(AgentRow row)
    {
        if (row.IsBuiltIn) return "内置";
        if (row.IsMdConfig) return row.Level == ConfigLevel.Project ? "MD(项目)" : "MD(用户)";
        return "其他";
    }

    private string GetSourceColor(AgentRow row)
    {
        if (row.IsBuiltIn) return "blue";
        if (row.IsMdConfig) return row.Level == ConfigLevel.Project ? "green" : "cyan";
        return "default";
    }

    private sealed class AgentRow
    {
        public string Name { get; set; } = "";
        public string Description { get; set; } = "";
        public string DefaultLabel { get; set; } = "";
        public bool IsDefault { get; set; }
        public bool IsMdConfig { get; set; }
        public bool IsBuiltIn { get; set; }
        public bool IsHidden { get; set; }
        public bool Disabled { get; set; }
        public ConfigLevel Level { get; set; }
        public string Source => IsBuiltIn ? "内置" : (IsMdConfig ? "MD" : "其他");
        public string StatusText => Disabled ? "已禁用" : (IsHidden ? "已隐藏" : "启用");
    }

    private sealed class CreateForm
    {
        public string Name { get; set; } = "";
        public ConfigLevel Level { get; set; } = ConfigLevel.Project;
    }
}
