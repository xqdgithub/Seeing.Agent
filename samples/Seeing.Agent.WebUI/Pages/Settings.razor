@page "/settings"
@using AntDesign
@using Seeing.Agent.Configuration
@using Seeing.Agent.Scheduler
@using Seeing.Agent.Scheduler.Abstractions
@using Seeing.Agent.Scheduler.Models
@using Seeing.Agent.WebUI.Components
@using Seeing.Agent.WebUI.Components.Scheduler
@using Seeing.Agent.WebUI.Services
@inject SeeingConfigService ConfigService
@inject IWorkspaceProvider WorkspaceProvider
@inject WorkspaceSwitchService WorkspaceSwitchService
@inject IScheduleManager ScheduleManager
@inject SchedulerStatusService StatusService
@inject NavigationManager NavigationManager
@inject IMessageService MessageService

<PageTitle>系统设置 - Seeing.Agent</PageTitle>

<WorkspacePageShell>
    <Breadcrumb>
        <BreadcrumbItem>设置</BreadcrumbItem>
        <BreadcrumbItem>系统设置</BreadcrumbItem>
    </Breadcrumb>
    <Extra>
        <Space>
            @if (_activeTab == "general" || _activeTab == "plugins")
            {
                <Select TItemValue="ConfigLevel" TItem="ConfigLevel" @bind-Value="_saveLevel" Style="width: 160px;">
                    <SelectOption TItemValue="ConfigLevel" TItem="ConfigLevel" Value="@ConfigLevel.Project">项目级</SelectOption>
                    <SelectOption TItemValue="ConfigLevel" TItem="ConfigLevel" Value="@ConfigLevel.User">用户级</SelectOption>
                </Select>
            }
            <Button Type="@ButtonType.Primary" Icon="@IconType.Outline.Save" OnClick="SaveCurrentTab">保存</Button>
        </Space>
    </Extra>
    <ChildContent>
        <Tabs @bind-ActiveKey="_activeTab">
            <TabPane Key="general" Tab="常规">
                <Form Layout="@FormLayout.Vertical" Model="@_options">
                    <FormItem Label="默认智能体"><Input @bind-Value="@_options.DefaultAgent" /></FormItem>
                    <FormItem Label="默认模型"><Input @bind-Value="@_options.DefaultModel" /></FormItem>
                    
                    <Divider Orientation="@DividerOrientation.Left">工作区设置</Divider>
                    
                    <FormItem Label="当前工作区">
                        <InputGroup Compact>
                            <Input Value="@_workspacePath" Style="width: calc(100% - 100px)" Disabled="true" />
                            <Button Type="@ButtonType.Default" OnClick="ShowWorkspaceSelector">切换</Button>
                        </InputGroup>
                        <div style="margin-top: 4px; font-size: 12px; color: #888;">
                            来源: @WorkspaceSwitchService.ResolutionSourceDescription
                        </div>
                    </FormItem>
                    
                    <FormItem Label="启动目录">
                        <Input Value="@WorkspaceSwitchService.StartupDirectory" Disabled="true" />
                        <div style="margin-top: 4px; font-size: 12px; color: #888;">
                            程序启动时的当前目录，作为默认工作区
                        </div>
                    </FormItem>
                    
                    <FormItem Label="工作区模式">
                        <RadioGroup @bind-Value="@_workspaceUseGlobal">
                            <Radio Value="false">使用启动目录（默认）</Radio>
                            <Radio Value="true">使用全局默认工作区</Radio>
                        </RadioGroup>
                    </FormItem>
                    
                    @if (_workspaceUseGlobal)
                    {
                        <FormItem Label="全局默认工作区">
                            <InputGroup Compact>
                                <Input Value="@_globalWorkspacePath" Style="width: calc(100% - 100px)" Disabled="true" />
                                <Button Type="@ButtonType.Default" OnClick="ShowGlobalWorkspaceSelector">选择</Button>
                            </InputGroup>
                            <div style="margin-top: 4px; font-size: 12px; color: #888;">
                                全局默认工作区在所有启用"使用全局"的项目中生效
                            </div>
                        </FormItem>
                    }
                    
                    <FormItem Label="自定义路径（可选）">
                        <InputGroup Compact>
                            <Input @bind-Value="@_customWorkspacePath" Style="width: calc(100% - 140px)" 
                                   Placeholder="留空则使用上述模式" AllowClear="true" />
                            <Button Type="@ButtonType.Default" OnClick="ShowCustomWorkspaceSelector">选择</Button>
                        </InputGroup>
                        <div style="margin-top: 4px; font-size: 12px; color: #faad14;">
                            设置后将忽略工作区模式，直接使用此路径
                        </div>
                    </FormItem>
                </Form>
            </TabPane>
            <TabPane Key="scheduler" Tab="调度器">
                <SchedulerStatusPanel Status="@_schedulerStatus" 
                                      ShowControls="true"
                                      OnStart="StartScheduler"
                                      OnStop="StopScheduler"
                                      OnReload="ReloadScheduler"
                                      IsLoading="@_schedulerLoading" />
                
                <Divider />
                
                <Alert Type="@AlertType.Info" ShowIcon="true" 
                       Message="调度器使用 Quartz.NET 框架，支持持久化和任务恢复"
                       Style="margin-bottom: 16px;" />
                
                <Form Layout="@FormLayout.Vertical" Model="@_scheduler" Context="schedulerForm">
                    <FormItem Label="启用调度器">
                        <Switch @bind-Checked="@_scheduler.Enabled" />
                    </FormItem>
                    <FormItem Label="时区">
                        <Input @bind-Value="@_scheduler.Timezone" Placeholder="Asia/Shanghai" />
                    </FormItem>
                    <FormItem Label="最大并发任务">
                        <InputNumber @bind-Value="@_scheduler.MaxConcurrentJobs" Min="1" Max="20" Style="width: 100%;" />
                    </FormItem>
                    
                    <Divider Orientation="@DividerOrientation.Left">持久化配置</Divider>
                    
                    <FormItem Label="启用持久化">
                        <Switch @bind-Checked="@_scheduler.Persistence.Enabled" />
                        <span style="margin-left: 8px; color: #888;">启用后任务状态将保存到数据库，应用重启后自动恢复</span>
                    </FormItem>
                    @if (_scheduler.Persistence.Enabled)
                    {
                        <FormItem Label="存储类型">
                            <Select TItemValue="string" TItem="string" @bind-Value="@_scheduler.Persistence.Provider" Context="providerSelect">
                                <SelectOption TItemValue="string" TItem="string" Value="@("sqlite")">SQLite（推荐）</SelectOption>
                                <SelectOption TItemValue="string" TItem="string" Value="@("memory")">内存（仅测试）</SelectOption>
                            </Select>
                        </FormItem>
                        @if (_scheduler.Persistence.Provider == "sqlite")
                        {
                            <FormItem Label="数据库路径">
                                <Input @bind-Value="@_scheduler.Persistence.ConnectionString" 
                                       Placeholder="Data Source=.seeing/quartz.db" />
                            </FormItem>
                        }
                    }
                </Form>
            </TabPane>
            <TabPane Key="plugins" Tab="插件">
                @if (_options.Plugins.Count == 0 && _options.PluginEnabled.Count == 0)
                {
                    <Empty Description="@("未配置插件，可在 seeing.json 的 Plugins 节添加")" />
                }
                else
                {
                    <Table TItem="PluginRow" DataSource="@_pluginRows" RowKey="@(p => p.Id)">
                        <PropertyColumn Property="c => c.Id" Title="插件" />
                        <ActionColumn Title="启用">
                            <Switch Checked="@context.Enabled" OnChange="@((bool v) => TogglePlugin(context.Id, v))" />
                        </ActionColumn>
                    </Table>
                }
            </TabPane>
            <TabPane Key="mcp" Tab="MCP 概览">
                <McpStatusPanel />
                <Button Type="@ButtonType.Link" Style="margin-top: 16px;" OnClick="@(() => NavigationManager.NavigateTo("/mcp"))">
                    前往 MCP 管理 →
                </Button>
            </TabPane>
            <TabPane Key="advanced" Tab="高级">
                <Alert Type="@AlertType.Warning" ShowIcon="true" Message="直接编辑 JSON，保存前请确保格式正确。" Style="margin-bottom: 16px;" />
                <TextArea Rows="20" @bind-Value="@_rawJson" Style="font-family: monospace;" />
            </TabPane>
        </Tabs>
    </ChildContent>
</WorkspacePageShell>

<WorkspaceSelectorModal @ref="_workspaceSelectorModal" 
                        OnWorkspaceChanged="EventCallback.Factory.Create<string>(this, HandleWorkspaceChanged)" />

<WorkspaceSelectorModal @ref="_globalWorkspaceSelectorModal"
                        Title="选择全局默认工作区"
                        OnWorkspaceChanged="EventCallback.Factory.Create<string>(this, HandleGlobalWorkspaceChanged)" />

<WorkspaceSelectorModal @ref="_customWorkspaceSelectorModal"
                        Title="选择自定义工作区路径"
                        OnWorkspaceChanged="EventCallback.Factory.Create<string>(this, HandleCustomWorkspaceChanged)" />

@code {
    private string _activeTab = "general";
    private ConfigLevel _saveLevel = ConfigLevel.Project;
    private SeeingAgentOptions _options = new();
    private SchedulerOptions _scheduler = new();
    private SchedulerStatus _schedulerStatus = new();
    private string _rawJson = "";
    private string _workspacePath = "";
    private List<PluginRow> _pluginRows = new();
    private bool _schedulerLoading;
    private WorkspaceSelectorModal? _workspaceSelectorModal;
    private WorkspaceSelectorModal? _globalWorkspaceSelectorModal;
    private WorkspaceSelectorModal? _customWorkspaceSelectorModal;
    
    // 工作区配置
    private bool _workspaceUseGlobal;
    private string _globalWorkspacePath = "";
    private string _customWorkspacePath = "";

    protected override async Task OnInitializedAsync()
    {
        _workspacePath = WorkspaceProvider.WorkspaceRoot;
        _options = await ConfigService.LoadProjectOptionsAsync();
        _scheduler = ConfigService.GetSchedulerOptions();
        
        _rawJson = await ConfigService.GetRawProjectJsonAsync();
        BuildPluginRows();
        
        // 加载工作区配置
        LoadWorkspaceSettings();
        
        // 加载调度器状态
        await LoadSchedulerStatusAsync();
    }

    private void LoadWorkspaceSettings()
    {
        _workspacePath = WorkspaceProvider.WorkspaceRoot;
        _globalWorkspacePath = WorkspaceSwitchService.GlobalWorkspaceRoot ?? "";
        _customWorkspacePath = _options.Workspace?.CustomPath ?? "";
        _workspaceUseGlobal = _options.Workspace?.UseGlobal ?? false;
    }

    private async Task LoadSchedulerStatusAsync()
    {
        try
        {
            _schedulerStatus = await StatusService.GetStatusAsync();
        }
        catch
        {
            _schedulerStatus = new SchedulerStatus { IsRunning = false };
        }
    }

    private void ShowWorkspaceSelector()
    {
        _workspaceSelectorModal?.Show();
    }

    private void ShowGlobalWorkspaceSelector()
    {
        _globalWorkspaceSelectorModal?.Show();
    }

    private void ShowCustomWorkspaceSelector()
    {
        _customWorkspaceSelectorModal?.Show();
    }

    private async Task HandleWorkspaceChanged(string newWorkspace)
    {
        // 重新加载设置页面数据
        _workspacePath = WorkspaceProvider.WorkspaceRoot;
        _options = await ConfigService.LoadProjectOptionsAsync();
        _rawJson = await ConfigService.GetRawProjectJsonAsync();
        BuildPluginRows();
        LoadWorkspaceSettings();
        
        // 刷新页面状态
        await InvokeAsync(StateHasChanged);
    }

    private async Task HandleGlobalWorkspaceChanged(string newWorkspace)
    {
        _globalWorkspacePath = newWorkspace;
        await WorkspaceSwitchService.SetGlobalWorkspaceRootAsync(newWorkspace);
        MessageService.Success($"全局默认工作区已设置: {newWorkspace}");
    }

    private async Task HandleCustomWorkspaceChanged(string newWorkspace)
    {
        _customWorkspacePath = newWorkspace;
        StateHasChanged();
    }

    private async Task StartScheduler()
    {
        _schedulerLoading = true;
        try
        {
            await StatusService.StartAsync();
            await LoadSchedulerStatusAsync();
            MessageService.Success("调度器已启动");
        }
        catch (Exception ex)
        {
            MessageService.Error($"启动失败: {ex.Message}");
        }
        finally
        {
            _schedulerLoading = false;
        }
    }

    private async Task StopScheduler()
    {
        _schedulerLoading = true;
        try
        {
            await StatusService.StopAsync();
            await LoadSchedulerStatusAsync();
            MessageService.Info("调度器已停止");
        }
        catch (Exception ex)
        {
            MessageService.Error($"停止失败: {ex.Message}");
        }
        finally
        {
            _schedulerLoading = false;
        }
    }

    private async Task ReloadScheduler()
    {
        _schedulerLoading = true;
        try
        {
            await ScheduleManager.ReloadHeartbeatAsync();
            await LoadSchedulerStatusAsync();
            MessageService.Success("配置已重载");
        }
        catch (Exception ex)
        {
            MessageService.Error($"重载失败: {ex.Message}");
        }
        finally
        {
            _schedulerLoading = false;
        }
    }

    private void BuildPluginRows()
    {
        var ids = _options.Plugins.Select(p => p.Spec).Concat(_options.PluginEnabled.Keys).Distinct();
        _pluginRows = ids.Select(id => new PluginRow
        {
            Id = id ?? "",
            Enabled = !_options.PluginEnabled.TryGetValue(id ?? "", out var enabled) || enabled
        }).ToList();
    }

    private void TogglePlugin(string id, bool enabled)
    {
        _options.PluginEnabled[id] = enabled;
        BuildPluginRows();
    }

    private async Task SaveCurrentTab()
    {
        try
        {
            switch (_activeTab)
            {
                case "general":
                    // 保存基本配置
                    await ConfigService.SaveLevelSectionsAsync(_saveLevel, new Dictionary<string, object?>
                    {
                        ["DefaultAgent"] = _options.DefaultAgent,
                        ["DefaultModel"] = _options.DefaultModel
                    });
                    
                    // 保存工作区配置
                    var workspaceOptions = new WorkspaceOptions
                    {
                        UseGlobal = _workspaceUseGlobal,
                        CustomPath = string.IsNullOrWhiteSpace(_customWorkspacePath) ? null : _customWorkspacePath
                    };
                    await WorkspaceSwitchService.SetWorkspaceOptionsAsync(workspaceOptions);
                    
                    // 更新显示
                    _workspacePath = WorkspaceProvider.WorkspaceRoot;
                    break;
                case "scheduler":
                    await ConfigService.SaveSchedulerOptionsAsync(s =>
                    {
                        s.Enabled = _scheduler.Enabled;
                        s.Timezone = _scheduler.Timezone;
                        s.MaxConcurrentJobs = _scheduler.MaxConcurrentJobs;
                        s.Persistence = _scheduler.Persistence;
                    });
                    
                    // 重载调度器
                    await ScheduleManager.ReloadHeartbeatAsync();
                    break;
                case "plugins":
                    await ConfigService.SaveLevelSectionsAsync(_saveLevel, new Dictionary<string, object?>
                    {
                        ["PluginEnabled"] = _options.PluginEnabled
                    });
                    break;
                case "advanced":
                    await ConfigService.SaveRawProjectJsonAsync(_rawJson);
                    _options = await ConfigService.LoadEffectiveOptionsAsync();
                    break;
            }
            MessageService.Success("保存成功");
        }
        catch (Exception ex)
        {
            MessageService.Error($"保存失败: {ex.Message}");
        }
    }

    private sealed class PluginRow
    {
        public string Id { get; set; } = "";
        public bool Enabled { get; set; }
    }
}
