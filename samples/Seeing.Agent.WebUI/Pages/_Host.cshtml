@page "/"
@namespace Seeing.Agent.WebUI.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#1890ff" />
    
    <!-- Favicon (inline SVG) -->
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🤖</text></svg>" />
    
    <title>Seeing.Agent WebUI</title>
    <base href="/" />
    
    <!-- AntDesign CSS (1.6.0 稳定版) -->
    <link href="_content/AntDesign/css/ant-design-blazor.css" rel="stylesheet" />
    
    <!-- 设计系统 CSS -->
    <link href="css/design-system.css" rel="stylesheet" />
    <link href="css/main-layout.css" rel="stylesheet" />
    <link href="css/message-list.css" rel="stylesheet" />
    <link href="css/message-item.css" rel="stylesheet" />
    <link href="css/prompt-input.css" rel="stylesheet" />
    <link href="css/selectors.css" rel="stylesheet" />
    <link href="css/tool-components.css" rel="stylesheet" />
    <link href="css/session-sidebar.css" rel="stylesheet" />
    <link href="css/home-welcome.css" rel="stylesheet" />
    <link href="css/session-page.css" rel="stylesheet" />
    <link href="css/quick-command.css" rel="stylesheet" />
    <link href="css/index.css" rel="stylesheet" />
</head>
<body>
    <app>
        <component type="typeof(App)" render-mode="ServerPrerendered" />
    </app>
    
    <!-- AntDesign 弹窗容器 -->
    <component type="typeof(AntDesign.AntContainer)" render-mode="Server" />
    
    <!-- Blazor Server JS -->
    <script src="_framework/blazor.server.js"></script>
    
    <!-- AntDesign JS -->
    <script src="_content/AntDesign/js/ant-design-blazor.js"></script>
    
    <!-- App Utilities JS -->
    <script src="js/app.js"></script>
</body>
</html>