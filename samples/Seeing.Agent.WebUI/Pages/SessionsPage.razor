@page "/sessions"
@using AntDesign
@using Seeing.Agent.Configuration
@using Seeing.Agent.WebUI.Services
@using Seeing.Session.Core
@inject SessionProvider SessionProvider
@inject IWorkspaceProvider WorkspaceProvider
@inject IMessageService MessageService
@inject NavigationManager NavigationManager
@implements IDisposable

<PageTitle>会话管理 - Seeing.Agent</PageTitle>

<div class="workspace-page">
    <!-- Page Header -->
    <div class="page-header">
        <div class="page-header-left">
            <Breadcrumb>
                <BreadcrumbItem>工作区</BreadcrumbItem>
                <BreadcrumbItem>会话</BreadcrumbItem>
            </Breadcrumb>
        </div>
        <div class="page-header-actions">
            <Button Type="@ButtonType.Primary" Icon="@IconType.Outline.Plus" OnClick="CreateSession">
                新建会话
            </Button>
            <Button Icon="@IconType.Outline.Reload" OnClick="RefreshSessions">
                刷新
            </Button>
        </div>
    </div>
    
    <!-- Statistics Bar -->
    <div class="page-stats">
        <div class="stat-item">
            <div class="stat-icon">
                <Icon Type="@IconType.Outline.Folder" />
            </div>
            <div class="stat-content">
                <div class="stat-value">@_totalCount</div>
                <div class="stat-label">总会话</div>
            </div>
        </div>
        <div class="stat-item">
            <div class="stat-icon">
                <Icon Type="@IconType.Outline.Calendar" />
            </div>
            <div class="stat-content">
                <div class="stat-value">@_todayCount</div>
                <div class="stat-label">今日创建</div>
            </div>
        </div>
        <div class="stat-item">
            <div class="stat-icon">
                <Icon Type="@IconType.Outline.Thunderbolt" />
            </div>
            <div class="stat-content">
                <div class="stat-value">@_activeCount</div>
                <div class="stat-label">活跃 (24h)</div>
            </div>
        </div>
    </div>
    
    <!-- Filters Bar -->
    <div class="page-filters">
        <div class="filter-search">
            <Input @bind-Value="_searchText" Placeholder="搜索会话..." AllowClear="true">
                <Prefix><Icon Type="@IconType.Outline.Search" /></Prefix>
            </Input>
        </div>
    </div>
    
    <!-- Session List -->
    <div class="page-content">
        @if (_filteredSessions == null || _filteredSessions.Count == 0)
        {
            <Empty />
        }
        else
        {
            <div class="session-list">
                @foreach (var session in _filteredSessions)
                {
                    var workspace = !string.IsNullOrEmpty(session.WorkingDirectory) 
                        ? session.WorkingDirectory 
                        : WorkspaceProvider.WorkspaceRoot;
                    
                    <div Class="session-card-wrapper" @onclick="@(() => ViewSession(session.Id))">
                        <Card Size="@CardSize.Small" Hoverable="true" Class="session-card">
                            <div Class="session-card-content">
                                <div Class="session-card-header">
                                    <span Class="session-title">@session.Title</span>
                                    <Tag Color="@TagColor.Blue">@session.SelectedAgent</Tag>
                                </div>
                                <div Class="session-card-meta">
                                    <span Class="meta-item">
                                        <Icon Type="@IconType.Outline.ClockCircle" /> @GetRelativeTime(session.UpdatedAt)
                                    </span>
                                    <Tooltip Title="@workspace">
                                        <span Class="meta-item">
                                            <Icon Type="@IconType.Outline.Folder" /> @TruncatePath(workspace)
                                        </span>
                                    </Tooltip>
                                    <span Class="meta-item">
                                        <Icon Type="@IconType.Outline.Message" /> @session.MessageCount 条消息
                                    </span>
                                </div>
                                <div Class="session-card-actions" @onclick:stopPropagation>
                                    <Button Type="@ButtonType.Text" Size="@ButtonSize.Small" 
                                            Icon="@IconType.Outline.Fork" 
                                            OnClick="@(() => BranchSession(session.Id))">
                                        分支
                                    </Button>
                                    <Popconfirm Title="确定删除此会话？" OnConfirm="@(() => DeleteSession(session.Id))">
                                        <Button Type="@ButtonType.Text" Size="@ButtonSize.Small" 
                                                Danger Icon="@IconType.Outline.Delete">
                                            删除
                                        </Button>
                                    </Popconfirm>
                                </div>
                            </div>
                        </Card>
                    </div>
                }
            </div>
        }
    </div>
</div>

<style>
.session-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 16px;
}

.session-card-wrapper {
    cursor: pointer;
}

.session-card {
    margin-bottom: 0 !important;
}

.session-card .ant-card-body {
    padding: 16px !important;
}

.session-card-content {
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.session-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 8px;
}

.session-card-header .session-title {
    font-size: 15px;
    font-weight: 600;
    color: #262626;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    flex: 1;
}

.session-card-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
}

.session-card-actions {
    display: flex;
    gap: 8px;
    justify-content: flex-end;
    padding-top: 8px;
    border-top: 1px solid #f0f0f0;
}
</style>

@code {
    private List<SessionData> _filteredSessions = new();
    private string _searchText = "";
    private int _totalCount;
    private int _todayCount;
    private int _activeCount;
    private bool _hasRendered;

    protected override async Task OnInitializedAsync()
    {
        SessionProvider.OnSessionListChanged += OnSessionListChanged;
        
        // 确保会话列表已初始化（刷新页面时可能需要重新加载）
        await SessionProvider.InitializeSessionListAsync();
        
        RefreshSessions();
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
            _hasRendered = true;
    }

    public void Dispose()
    {
        SessionProvider.OnSessionListChanged -= OnSessionListChanged;
    }

    private void OnSessionListChanged()
    {
        if (!_hasRendered)
            return;
        _ = InvokeAsync(() =>
        {
            RefreshSessions();
            StateHasChanged();
        });
    }
    
    void RefreshSessions()
    {
        try
        {
            var sessions = SessionProvider.GetSessionList() ?? new List<SessionData>();
            
            _filteredSessions = sessions
                .Where(s => string.IsNullOrEmpty(_searchText) || 
                            (s.Title?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
                            (s.SelectedAgent?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false))
                .OrderByDescending(s => s.UpdatedAt)
                .ToList();
            
            _totalCount = sessions.Count;
            var today = DateTime.Today;
            _todayCount = sessions.Count(s => s.CreatedAt.Date == today);
            var yesterday = DateTime.Now.AddHours(-24);
            _activeCount = sessions.Count(s => s.UpdatedAt >= yesterday);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error refreshing sessions: {ex.Message}");
            _filteredSessions = new List<SessionData>();
        }
    }
    
    async Task CreateSession()
    {
        try
        {
            var session = await SessionProvider.CreateSessionAsync(
                workingDirectory: WorkspaceProvider.WorkspaceRoot);
            MessageService.Success("会话已创建");
            NavigationManager.NavigateTo($"/session/{session.Id}");
        }
        catch (Exception ex)
        {
            MessageService.Error($"创建失败: {ex.Message}");
        }
    }
    
    async Task DeleteSession(string id)
    {
        try
        {
            await SessionProvider.DeleteSessionAsync(id);
            MessageService.Success("会话已删除");
            RefreshSessions();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            MessageService.Error($"删除失败: {ex.Message}");
        }
    }
    
    void ViewSession(string id) => NavigationManager.NavigateTo($"/session/{id}");
    
    async Task BranchSession(string id)
    {
        try
        {
            var session = await SessionProvider.BranchSessionAsync(id);
            MessageService.Success("会话已分支");
            NavigationManager.NavigateTo($"/session/{session.Id}");
        }
        catch (Exception ex)
        {
            MessageService.Error($"分支失败: {ex.Message}");
        }
    }
    
    string GetRelativeTime(DateTime time)
    {
        var diff = DateTime.Now - time;
        
        if (diff.TotalMinutes < 1)
            return "刚刚";
        if (diff.TotalMinutes < 60)
            return $"{(int)diff.TotalMinutes}分钟前";
        if (diff.TotalHours < 24)
            return $"{(int)diff.TotalHours}小时前";
        if (diff.TotalDays < 7)
            return $"{(int)diff.TotalDays}天前";
        
        return time.ToString("MM-dd");
    }
    
    static string TruncatePath(string path)
    {
        if (string.IsNullOrEmpty(path)) return path;
        if (path.Length <= 30) return path;
        
        var parts = path.Split(Path.DirectorySeparatorChar, Path.AltDirectorySeparatorChar);
        if (parts.Length <= 2) return path;
        
        return ".../" + string.Join("/", parts.TakeLast(2));
    }
}
