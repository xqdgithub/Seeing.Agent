@page "/skills/{SkillName}"
@using AntDesign
@using Seeing.Agent.Core.Interfaces
@using Seeing.Agent.Skills
@inject SkillManager SkillManager
@inject NavigationManager NavigationManager
@inject IMessageService MessageService

<PageTitle>@SkillName - 技能详情</PageTitle>

<WorkspacePageShell Loading="@_loading" IsEmpty="@(_skill == null)" EmptyTitle="技能不存在">
    <Breadcrumb>
        <BreadcrumbItem><a @onclick="@(() => NavigationManager.NavigateTo("/skills"))" style="cursor:pointer;">技能</a></BreadcrumbItem>
        <BreadcrumbItem>@SkillName</BreadcrumbItem>
    </Breadcrumb>
    <Extra>
        <Space>
            <span>启用</span>
            <Switch Checked="@_enabled" OnChange="ToggleEnabled" />
            <Button OnClick="@(() => NavigationManager.NavigateTo("/skills"))">返回列表</Button>
        </Space>
    </Extra>
    <ChildContent>
        @if (_skill != null)
        {
            <Descriptions Bordered Column="2" Style="margin-bottom: 16px;">
                <DescriptionsItem Title="名称">@SkillName</DescriptionsItem>
                <DescriptionsItem Title="类型"><Tag Color="@GetSkillTypeColor(_skill)">@GetSkillType(_skill)</Tag></DescriptionsItem>
                <DescriptionsItem Title="路径" Span="2">@_skill.Location</DescriptionsItem>
                <DescriptionsItem Title="描述" Span="2">@(_skill.Description ?? "无")</DescriptionsItem>
            </Descriptions>
            <Tabs>
                <TabPane Key="content" Tab="说明">
                    <div style="white-space: pre-wrap; line-height: 1.6;">@(_skill.Content ?? "无内容")</div>
                </TabPane>
                <TabPane Key="raw" Tab="原始文件">
                    <pre style="white-space: pre-wrap; max-height: 500px; overflow: auto;">@_rawContent</pre>
                </TabPane>
                @if (_files.Any())
                {
                    <TabPane Key="files" Tab="相关文件">
                        <ul>
                            @foreach (var f in _files)
                            {
                                <li>@f</li>
                            }
                        </ul>
                    </TabPane>
                }
            </Tabs>
        }
    </ChildContent>
</WorkspacePageShell>

@code {
    [Parameter] public string SkillName { get; set; } = "";
    private SkillInfo? _skill;
    private string _rawContent = "";
    private List<string> _files = new();
    private bool _enabled = true;
    private bool _loading;

    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        _skill = SkillManager.GetSkillInfoIncludingDisabled(SkillName);
        _enabled = SkillManager.IsSkillEnabled(SkillName);
        if (_skill != null && !string.IsNullOrEmpty(_skill.Location) && File.Exists(_skill.Location))
            _rawContent = await File.ReadAllTextAsync(_skill.Location);
        _files = SkillManager.GetSkillFiles(SkillName);
        _loading = false;
    }

    private async Task ToggleEnabled(bool enabled)
    {
        await SkillManager.SetSkillEnabledAsync(SkillName, enabled);
        _enabled = enabled;
        MessageService.Success(enabled ? "已启用" : "已禁用");
    }

    string GetSkillType(SkillInfo? s) {
        if (s?.Location == null) return "未知";
        // 内置技能：embedded:// 开头
        if (s.Location.StartsWith("embedded://", StringComparison.OrdinalIgnoreCase)) return "内置";
        // 用户级：路径包含用户目录
        var userProfile = Environment.GetFolderPath(Environment.SpecialFolder.UserProfile);
        if (s.Location.StartsWith(userProfile, StringComparison.OrdinalIgnoreCase)) return "用户级";
        // 项目级：其他路径
        return "项目级";
    }

    string GetSkillTypeColor(SkillInfo? s) {
        if (s?.Location == null) return "default";
        if (s.Location.StartsWith("embedded://", StringComparison.OrdinalIgnoreCase)) return "orange";
        var userProfile = Environment.GetFolderPath(Environment.SpecialFolder.UserProfile);
        if (s.Location.StartsWith(userProfile, StringComparison.OrdinalIgnoreCase)) return "purple";
        return "blue";
    }
}
