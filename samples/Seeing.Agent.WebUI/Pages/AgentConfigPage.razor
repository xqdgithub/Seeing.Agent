@page "/agent-config"
@using AntDesign
@using Seeing.Agent.Configuration
@using Seeing.Agent.Core.Interfaces
@using Seeing.Agent.Core.Permission
@using Seeing.Agent.Llm
@using Seeing.Agent.Tools
@using Seeing.Agent.WebUI.Components.Agents
@using Seeing.Agent.WebUI.State
@inject IAgentManager AgentManager
@inject ILlmService LlmService
@inject ToolInvoker ToolInvoker
@inject NavigationManager NavigationManager
@inject IMessageService MessageService

<PageTitle>智能体配置 - Seeing.Agent</PageTitle>

<WorkspacePageShell Loading="@_loading">
    <Breadcrumb>
        <BreadcrumbItem Href="/agents">智能体管理</BreadcrumbItem>
        <BreadcrumbItem>配置</BreadcrumbItem>
    </Breadcrumb>
    <Extra>
        <Space>
            <Select TItemValue="ConfigLevel" TItem="ConfigLevel" @bind-Value="_saveLevel" Style="width: 160px;">
                <SelectOption TItemValue="ConfigLevel" TItem="ConfigLevel" Value="@ConfigLevel.Project">项目级</SelectOption>
                <SelectOption TItemValue="ConfigLevel" TItem="ConfigLevel" Value="@ConfigLevel.User">用户级</SelectOption>
            </Select>
            @if (_agentNames.Count > 0)
            {
                <Select TItemValue="string" TItem="string"
                        Value="@_agentName"
                        ValueExpression="@(() => _agentName)"
                        ValueChanged="OnAgentChanged"
                        DataSource="@_agentNames"
                        Style="width: 200px;" />
            }
            <Button Icon="@IconType.Outline.Reload" OnClick="UpdatePreview">刷新预览</Button>
            <Button Type="@ButtonType.Primary" Icon="@IconType.Outline.Save" OnClick="SaveAsync">保存</Button>
            <Button OnClick="GoBack">返回</Button>
        </Space>
    </Extra>
    <ChildContent>
        @if (string.IsNullOrEmpty(_agentName))
        {
            <Empty>
                <DescriptionTemplate>
                    <span>未找到可配置的主智能体</span>
                </DescriptionTemplate>
            </Empty>
        }
        else
        {
            <div class="agent-config-layout">
                <div class="config-form-panel">
                    <div class="panel-header">
                        <Icon Type="@IconType.Outline.Edit" />
                        <span>表单编辑</span>
                    </div>
                    <div class="panel-body">
                        <AgentConfigForm @key="@_agentName"
                                         @ref="_form"
                                         EditModel="@_editModel"
                                         ModelKeys="@_modelKeys" />
                    </div>
                </div>
                <div class="config-preview-panel">
                    <AgentMdPreview MdContent="@_mdPreview" Level="@_saveLevel.ToString()" />
                </div>
            </div>
        }
    </ChildContent>
</WorkspacePageShell>

<style>
    .agent-config-layout {
        display: flex;
        gap: 16px;
        height: calc(100vh - 220px);
        min-height: 500px;
    }
    
    .config-form-panel, .config-preview-panel {
        flex: 1;
        display: flex;
        flex-direction: column;
        border: 1px solid #d9d9d9;
        border-radius: 4px;
        background: #fff;
        overflow: hidden;
    }
    
    .panel-header {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 12px 16px;
        border-bottom: 1px solid #f0f0f0;
        background: #fafafa;
        font-weight: 500;
    }
    
    .panel-body {
        flex: 1;
        padding: 16px;
        overflow-y: auto;
    }
    
    .config-preview-panel {
        min-width: 400px;
    }
</style>

@code {
    private AgentConfigForm? _form;
    private string _agentName = "";
    private List<string> _agentNames = new();
    private AgentEditModel _editModel = new();
    private List<string> _modelKeys = new();
    private ConfigLevel _saveLevel = ConfigLevel.Project;
    private bool _loading;
    private string _mdPreview = "";

    protected override async Task OnInitializedAsync()
    {
        var allAgents = await AgentManager.GetAgentsAsync();
        _agentNames = allAgents
            .Where(a => !string.IsNullOrEmpty(a.Name))
            .Select(a => a.Name)
            .ToList();

        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        _agentName = query["agent"];
        if (string.IsNullOrEmpty(_agentName) && _agentNames.Count > 0)
            _agentName = await AgentManager.GetDefaultAgentNameAsync() ?? _agentNames[0];
        if (!string.IsNullOrEmpty(_agentName) && !_agentNames.Contains(_agentName))
            _agentName = _agentNames.FirstOrDefault() ?? "";

        _modelKeys = LlmService.GetAvailableModels().Keys
            .Where(k => !string.IsNullOrEmpty(k))
            .ToList();
        await LoadAgentAsync();
    }

    private async Task LoadAgentAsync()
    {
        if (string.IsNullOrEmpty(_agentName))
        {
            _editModel = new AgentEditModel();
            _mdPreview = "";
            return;
        }

        _loading = true;
        try
        {
            _editModel = await AgentManager.GetEditModelAsync(_agentName) ?? new AgentEditModel { Name = _agentName };

            // 设置保存级别
            if (_editModel.MdConfigLevel.HasValue)
            {
                _saveLevel = _editModel.MdConfigLevel.Value;
            }

            // 生成 MD 预览
            UpdatePreview();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnAgentChanged(string name)
    {
        _agentName = name ?? "";
        if (string.IsNullOrEmpty(_agentName))
            return;

        await LoadAgentAsync();
    }

    private void UpdatePreview()
    {
        _form?.ApplyToModel();
        _mdPreview = AgentManager.GenerateMdContent(_editModel);
    }

    private async Task SaveAsync()
    {
        if (string.IsNullOrEmpty(_agentName))
            return;

        _form?.ApplyToModel();
        
        var success = await AgentManager.SaveEditModelAsync(_editModel, _saveLevel);
        if (success)
        {
            MessageService.Success($"智能体 {_agentName} 配置已保存");
            UpdatePreview();
        }
        else
        {
            MessageService.Error("保存失败");
        }
    }

    private void GoBack() => NavigationManager.NavigateTo("/agents");
}
