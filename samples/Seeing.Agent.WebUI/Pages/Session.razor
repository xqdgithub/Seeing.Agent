    /// <summary>
    /// 手动触发压缩
    /// </summary>
    private async Task OnCompactRequested()
    {
        if (SessionState.CurrentSession == null) return;

        try
        {
            SessionState.IsCompacting = true;
            await InvokeAsync(StateHasChanged);

            var result = await CompactionService.CompactAsync(
                SessionState.CurrentSession.Messages,
                SessionState.CurrentSession.Id);

            if (result.Success && result.SummaryMessage != null && result.TailMessages != null)
            {
                // 替换消息列表
                SessionState.CurrentSession.Messages.Clear();
                SessionState.CurrentSession.Messages.Add(result.SummaryMessage);
                foreach (var msg in result.TailMessages)
                {
                    SessionState.CurrentSession.Messages.Add(msg);
                }

                // 清除缓存
                SessionState.CurrentSession.ClearUsageCache();

                // 保存 Session
                await SessionManager.SaveAsync(SessionState.CurrentSession.Id);

                // 更新 Token 预算状态
                UpdateBudgetStatus();

                MessageService.Success(string.Format("已压缩 {0} 条消息", result.CompressedCount));
                RefreshMessageViewModels();
            }
            else if (!string.IsNullOrEmpty(result.Message))
            {
                MessageService.Info(result.Message);
            }
            else if (!string.IsNullOrEmpty(result.Error))
            {
                MessageService.Error(string.Format("压缩失败: {0}", result.Error));
            }
        }
        catch (Exception ex)
        {
            MessageService.Error(string.Format("压缩失败: {0}", ex.Message));
        }
        finally
        {
            SessionState.IsCompacting = false;
            await InvokeAsync(StateHasChanged);
        }
    }
    
