@page "/session"
@page "/session/{SessionId}"
@using AntDesign
@using Microsoft.AspNetCore.Components.Web
@using Seeing.Agent.WebUI.Models
@using Seeing.Agent.WebUI.Commands
@using Services = Seeing.Agent.WebUI.Services
@using Core = Seeing.Agent.Core
@using Seeing.Session.Core
@using Seeing.Agent.WebUI.State
@using Seeing.Agent.Tools
@using Seeing.Agent.Skills
@using Seeing.Agent.Configuration
@using Seeing.Agent.Llm
@using Seeing.Session.Management
@using Seeing.Session.Compression
@using Seeing.Agent.App
@using Seeing.Agent.App.Events
@using Seeing.Agent.App.Models
@using Seeing.Agent.App.Execution
@using Seeing.Agent.Core.Events
@inject SessionState SessionState
@inject AppState AppState
@inject EventStreamHandler EventStreamHandler
@inject ErrorHandlingService ErrorHandlingService
@inject NavigationManager NavigationManager
@inject IMessageService MessageService
@inject Core.Interfaces.IAgentExecutionRouter AgentRouter
@inject IChatOrchestrator ChatOrchestrator
@inject Core.Interfaces.IAgentRegistry AgentRegistry
@inject Core.AgentSelectionResolver AgentSelectionResolver
@inject IWorkspaceProvider WorkspaceProvider
@inject Core.Interfaces.IPermissionChannel PermissionChannel
@inject ToolInvoker ToolInvoker
@inject SkillManager SkillManager
@inject ILlmService LlmService
@inject Services.SessionCompactionService CompactionService
@inject Services.CommandListService CommandListService
@inject Seeing.Agent.TokenBudget.IBudgetStatusNotifier BudgetNotifier
@inject Seeing.Agent.TokenBudget.ITokenBudgetManager TokenBudgetManager
@inject ISessionManager SessionManager
@implements IDisposable

<div Class="session-page-container">
    <!-- 会话头部 -->
    <div Class="session-header">
        <div Class="session-header-left">
            <Button Type="@ButtonType.Text"
                    Size="@ButtonSize.Small"
                    Icon="@IconType.Outline.Home"
                    OnClick="@GoToHome">
                @if (!SidebarCollapsed)
                {
                    <span>首页</span>
                }
            </Button>
            <Divider Type="@DividerType.Vertical" />
            <span Class="session-title">@SessionState.Title</span>
            @if (SessionState.IsQueued)
            {
                <Badge Status="@BadgeStatus.Default" Text="@($"排队中 ({SessionState.QueuePosition})" )" />
            }
            else if (SessionState.HasActiveExecution)
            {
                <Badge Status="@BadgeStatus.Processing" Text="执行中" />
            }
            @{
                var currentWorkspace = !string.IsNullOrEmpty(SessionState.CurrentSession?.WorkingDirectory) 
                    ? SessionState.CurrentSession.WorkingDirectory 
                    : WorkspaceProvider.WorkspaceRoot;
            }
            <Tooltip Title="@currentWorkspace">
                <span Class="session-workspace-badge">
                    <Icon Type="@IconType.Outline.Folder" />
                    @TruncateWorkspacePath(currentWorkspace)
                </span>
            </Tooltip>
        </div>
        <div Class="session-header-right">
            <Space>
                <SpaceItem>
                    @if (_optionsReady)
                    {
                        <Select TItemValue="string" TItem="string"
                                Value="@_selectedAgent"
                                ValueExpression="@(() => _selectedAgent)"
                                ValueChanged="EventCallback.Factory.Create<string>(this, OnAgentChanged)"
                                DataSource="@_agentNames"
                                Style="min-width: 120px;"
                                Size="@InputSize.Small"
                                Placeholder="智能体" />
                    }
                </SpaceItem>
                @if (_optionsReady && _isAcpPassthrough)
                {
                    <SpaceItem>
                        <Input Value="@_selectedAcpMode"
                               ValueChanged="EventCallback.Factory.Create<string?>(this, OnAcpModeChanged)"
                               Placeholder="Mode"
                               Style="width: 80px;"
                               Size="@InputSize.Small" />
                    </SpaceItem>
                    <SpaceItem>
                        <Input Value="@_selectedModel"
                               ValueChanged="EventCallback.Factory.Create<string?>(this, OnAcpModelChanged)"
                               Placeholder="Provider/Model"
                               Style="width: 160px;"
                               Size="@InputSize.Small" />
                    </SpaceItem>
                }
                else if (_optionsReady)
                {
                    <SpaceItem>
                        <Select TItemValue="string" TItem="ModelViewModel"
                                Value="@_selectedModel"
                                ValueExpression="@(() => _selectedModel)"
                                ValueChanged="@OnModelChanged"
                                DataSource="@_models"
                                ValueName="Id"
                                LabelName="ModelName"
                                Style="min-width: 160px;"
                                Size="@InputSize.Small"
                                Placeholder="模型"
                                EnableSearch="true">
                            <ItemTemplate Context="model">
                                <span>@model.ModelName</span>
                                @if (!string.IsNullOrEmpty(model.ProviderName))
                                {
                                    <span style="color: #999; font-size: 12px; margin-left: 4px;">(@model.ProviderName)</span>
                                }
                            </ItemTemplate>
                        </Select>
                    </SpaceItem>
                }
                <SpaceItem>
                    <Tooltip Title="重命名会话">
                        <Button Type="@ButtonType.Text"
                                Size="@ButtonSize.Small"
                                Icon="@IconType.Outline.Edit"
                                OnClick="@OnRenameSession" />
                    </Tooltip>
                </SpaceItem>
                <SpaceItem>
                    <Tooltip Title="分支会话">
                        <Button Type="@ButtonType.Text"
                                Size="@ButtonSize.Small"
                                Icon="@IconType.Outline.Copy"
                                OnClick="@OnBranchSession" />
                    </Tooltip>
                </SpaceItem>
                <SpaceItem>
                    <Tooltip Title="清空会话">
                        <Button Type="@ButtonType.Text"
                                Size="@ButtonSize.Small"
                                Icon="@IconType.Outline.Delete"
                                OnClick="@OnClearSession"
                                Disabled="@SessionState.IsExecuting" />
                    </Tooltip>
                </SpaceItem>
             </Space>
        </div>
    </div>

    <!-- 主内容区域（消息列表 + Todo 面板） -->
    <div Class="session-content-wrapper">
        <!-- 消息列表区域 -->
        <div Class="session-messages-container">
        @if (ShowEmptyState)
        {
            <!-- 无会话状态：引导用户创建新会话 -->
            <Empty Class="session-empty-state">
                <DescriptionTemplate>
                    <div Class="empty-content">
                        <Icon Type="@IconType.Outline.FileAdd" Class="empty-icon" Style="font-size: 48px;" />
                        <p Style="font-size: 18px; margin-top: 16px;">暂无会话</p>
                        <p Class="empty-hint">点击左侧边栏的"新建会话"按钮开始对话</p>
                    </div>
                </DescriptionTemplate>
            </Empty>
        }
        else if (_messageViewModels.Count == 0)
        {
            <Empty Class="session-empty-state">
                <DescriptionTemplate>
                    <div Class="empty-content">
                        <Icon Type="@IconType.Outline.Message" Class="empty-icon" />
                        <p>暂无消息</p>
                        <p Class="empty-hint">输入问题开始与 AI Agent 对话</p>
                    </div>
                </DescriptionTemplate>
            </Empty>
        }
        else
        {
            <MessageList Messages="@_messageViewModels"
                         AutoScroll="true"
                         OnToolClick="@OnToolClick" />
        }
        
        <!-- 加载状态指示器 -->
        @if (IsLoadingSession)
        {
            <div Class="loading-overlay">
                <Spin Size="@SpinSize.Large" Tip="加载会话..." />
            </div>
        }
        </div>
        
        @* Todo 侧边面板（当有任务时显示） *@
        @if (SessionState.CurrentTodoList != null && SessionState.CurrentTodoList.HasTasks)
        {
            <div Class="session-todo-panel">
                <TodoPanel TodoList="@SessionState.CurrentTodoList" />
            </div>
        }
    </div>

    <!-- 输入区域：仅在非空状态时显示 -->
    @if (!ShowEmptyState)
    {
        <div Class="session-input-container">
            <!-- Slot 扩展点: session_prompt -->
            <SlotHost SlotName="session_prompt" />
            
             <PromptInput IsProcessing="@SessionState.HasActiveExecution"
                          Placeholder="@GetPlaceholderText()"
                          HelpText="@GetHelpText()"
                          AvailableCommands="_availableCommands"
                          SessionState="SessionState"
                          CancellationTokenSource="@SessionState.CancellationTokenSource"
                          BudgetStatus="SessionState.BudgetStatus"
                          OnCompactRequested="OnCompactRequested"
                          OnSubmitCallback="@OnSubmitMessage"
                          OnCancelCallback="@OnCancelExecution" />
        </div>
    }
    
    <!-- 错误提示 -->
    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <Alert Type="@AlertType.Error"
               Message="@ErrorMessage"
               ShowIcon="true"
               Closable="true"
               OnClose="@OnClearError"
               Class="session-error-alert" />
    }
    
    <!-- 重命名对话框（仅在打开时渲染，避免隐藏 Modal 内 FormItem 初始化失败） -->
    @if (RenameModalVisible)
    {
        <Modal Title="重命名会话"
               Visible="true"
               OnOk="@OnRenameConfirm"
               OnCancel="@OnRenameCancel"
               OkText="@OkText"
               CancelText="@CancelText">
            <Form Model="@RenameForm" Layout="@FormLayout.Horizontal">
                <FormItem Label="会话标题">
                    <Input @bind-Value="@RenameForm.Title"
                           Placeholder="输入新的会话标题" />
                </FormItem>
            </Form>
        </Modal>
    }
</div>

@code {

    /// <summary>
    /// 常量文本（避免编码问题）
    /// </summary>
    private const string OkText = "确定";
    private const string CancelText = "取消";
    
    /// <summary>
    /// Agent/模型选择器相关
    /// </summary>
    private string _selectedAgent = "";
    private List<string> _agentNames = new();
    private string _selectedModel = "";
    private List<ModelViewModel> _models = new();
    private string _selectedAcpMode = "";
    private bool _isAcpPassthrough;
    private bool _optionsReady;
    
    /// <summary>
    /// 模型视图类 - 用于选择器显示
    /// </summary>
    private class ModelViewModel
    {
        /// <summary>完整 ID（provider/model 格式）</summary>
        public string Id { get; init; } = "";
        
        /// <summary>模型名称</summary>
        public string ModelName { get; init; } = "";
        
        /// <summary>Provider 名称</summary>
        public string ProviderName { get; init; } = "";
    }

    /// <summary>
    /// 可用命令列表（从后端获取）
    /// </summary>
    private List<CommandItemViewModel> _availableCommands = new();

    /// <summary>
    /// UI 显示用的消息视图模型列表（从 SessionData.Messages 转换）
    /// </summary>
    private List<MessageViewModel> _messageViewModels = new();

    /// <summary>
    /// 当前流式输出的消息 ID
    /// </summary>
    private string? _currentStreamingMessageId;

    /// <summary>
    /// 路由参数：会话 ID
    /// </summary>
    [Parameter]
    public string? SessionId { get; set; }

    /// <summary>
    /// 侧边栏折叠状态（从 MainLayout 获取）
    /// </summary>
    private bool SidebarCollapsed { get; set; } = false;

    /// <summary>
    /// 是否正在加载会话
    /// </summary>
    private bool IsLoadingSession { get; set; } = false;

    /// <summary>
    /// 是否显示空状态（无会话）
    /// </summary>
    private bool ShowEmptyState { get; set; } = false;

    /// <summary>
    /// 错误消息
    /// </summary>
    private string? ErrorMessage { get; set; }

    /// <summary>
    /// 重命名对话框可见性
    /// </summary>
    private bool RenameModalVisible { get; set; } = false;

    /// <summary>
    /// 重命名表单
    /// </summary>
    private RenameSessionForm RenameForm { get; set; } = new();

    /// <summary>
    /// 当前选中的工具调用（用于详情显示）
    /// </summary>
    private ToolCallViewModel? SelectedToolCall { get; set; }

    private bool _hasRendered;
    private string? _loadedSessionId;
    private IDisposable? _budgetSubscription;

    /// <summary>
    /// 组件初始化
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        // 加载 Agent 和模型选项列表（不设置选中值）
        await LoadOptionsAsync();
        
        // 加载工具和技能数据
        await LoadToolsAndSkillsAsync();
        
        // 加载命令列表（从后端）
        LoadCommandsFromBackend();
        
        // 加载会话（选项就绪后再加载，避免 Select 在 DataSource 为空时渲染）
        if (!string.IsNullOrEmpty(SessionId))
        {
            await LoadSessionByIdAsync(SessionId);
            _loadedSessionId = SessionId;
            
            // 检查是否有正在进行的执行（页面刷新恢复）
            var overview = ChatOrchestrator.GetOverview(SessionId);
            if (overview?.CurrentExecution != null)
            {
                // 恢复执行状态
                SessionState.ExecutionStatus = overview.CurrentExecution.Status;
                SessionState.QueuePosition = overview.CurrentExecution.QueuePosition;
                SessionState.CurrentExecutionId = overview.CurrentExecution.ExecutionId;
                
                // 如果有活跃执行，恢复订阅事件流
                if (overview.HasActiveExecution)
                {
                    _ = ConsumeEventStreamAsync(overview.CurrentExecution.ExecutionId);
                }
            }
        }
        else
        {
            await LoadSessionAsync();
            _loadedSessionId = SessionState.CurrentSession?.Id;
        }
        
        // Subscribe to Budget status updates
        SubscribeToBudgetUpdates();
    }

    private void SubscribeToBudgetUpdates()
    {
        // Dispose previous subscription
        _budgetSubscription?.Dispose();
        
        if (!string.IsNullOrEmpty(SessionState.SessionId))
        {
            _budgetSubscription = BudgetNotifier.Subscribe(SessionState.SessionId, status =>
            {
                SessionState.UpdateBudgetStatus(status);
                _ = InvokeAsync(StateHasChanged);
            });
        }
    }

    /// <summary>
    /// 计算并更新当前会话的 Token 预算状态
    /// </summary>
    private void UpdateBudgetStatus()
    {
        var session = SessionState.CurrentSession;
        if (session == null) return;

        try
        {
            // 使用 TokenBudgetManager 计算预算状态
            var status = TokenBudgetManager.GetBudgetStatus(session, session.SelectedModel);

            var response = new Seeing.Agent.TokenBudget.Api.Responses.BudgetStatusResponse
            {
                SessionId = session.Id,
                CurrentTokens = status.CurrentTokens,
                MaxTokens = status.MaxTokens,
                AvailableTokens = status.AvailableTokens,
                UsagePercentage = status.UsagePercentage,
                Level = status.Level.ToString().ToLowerInvariant(),
                NeedsCompaction = status.Level >= BudgetLevel.Critical,
                Breakdown = null
            };

            SessionState.UpdateBudgetStatus(response);
        }
        catch (Exception)
        {
            // 忽略计算错误
        }
    }

    /// <summary>
    /// 根据当前 tokens 确定预算级别
    /// </summary>
    private static string DetermineLevel(int currentTokens, int maxTokens)
    {
        if (maxTokens <= 0) return "normal";
        var percentage = 100.0 * currentTokens / maxTokens;
        if (percentage >= 100) return "overflow";
        if (percentage >= 90) return "critical";
        if (percentage >= 80) return "warning";
        return "normal";
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
            _hasRendered = true;
    }

    private void RequestRender()
    {
        if (!_hasRendered)
            return;
        _ = InvokeAsync(StateHasChanged);
    }
    
    /// <summary>
    /// 同步选择器值（从 SessionState 获取）
    /// </summary>
    private void SyncSelectorValues()
    {
        var agent = SessionState.SelectedAgent ?? "";
        var model = SessionState.SelectedModel ?? "";
        var provider = SessionState.SelectedModelProvider ?? "";
        
        _selectedAgent = _agentNames.Contains(agent) ? agent : (_agentNames.FirstOrDefault() ?? agent);
        
        // 组装完整的 modelId 格式来匹配（_models 使用 provider/model 格式）
        if (_isAcpPassthrough)
        {
            _selectedModel = model;
        }
        else
        {
            // 如果模型列表为空，保持当前值
            if (_models.Count == 0)
            {
                _selectedModel = model;
            }
            else
            {
                var fullModelId = !string.IsNullOrEmpty(provider) && !model.Contains('/')
                    ? $"{provider}/{model}"
                    : model;
                
                _selectedModel = _models.Any(m => m.Id == fullModelId)
                    ? fullModelId
                    : (_models.FirstOrDefault()?.Id ?? model);
            }
        }
        
        _selectedAcpMode = SessionState.SelectedAcpMode ?? "";
        RefreshAgentRuntime();
        RequestRender();
    }

    private void RefreshAgentRuntime()
    {
        if (string.IsNullOrWhiteSpace(_selectedAgent))
        {
            _isAcpPassthrough = false;
            return;
        }

        var info = AppState.AvailableAgents.FirstOrDefault(a =>
            string.Equals(a.Name, _selectedAgent, StringComparison.OrdinalIgnoreCase));
        _isAcpPassthrough = info?.Runtime == Seeing.Agent.Core.Models.AgentRuntime.AcpPassthrough;
    }
    
    /// <summary>
    /// 加载模型选项
    /// </summary>
    private async Task LoadOptionsAsync()
    {
        _optionsReady = false;
        // 加载 Agent 选项
        try
        {
            var agents = await AgentRegistry.GetPrimaryAgentsAsync();
            _agentNames = agents
                .Where(a => !string.IsNullOrEmpty(a.Name))
                .Select(a => a.Name)
                .ToList();
        }
        catch (Exception ex)
        {
            _agentNames = new List<string>();
        }
        
        // 加载模型选项
        try
        {
            var availableModels = LlmService.GetAvailableModels();
            if (availableModels != null)
            {
                AppState.AvailableModels = availableModels;
                _models = availableModels
                    .Where(m => !string.IsNullOrEmpty(m.Key))
                    .Select(m =>
                    {
                        // 解析 provider 和 model 名称
                        var parts = m.Key.Split('/', 2);
                        var providerName = parts.Length > 1 ? parts[0] : "";
                        var modelName = parts.Length > 1 ? parts[1] : parts[0];
                        return new ModelViewModel
                        {
                            Id = m.Key,
                            ModelName = modelName,
                            ProviderName = providerName
                        };
                    })
                    .ToList();
            }
        }
        catch (Exception ex)
        {
            _models = new List<ModelViewModel>();
        }

        _optionsReady = _agentNames.Count > 0 || _models.Count > 0;
        RefreshAgentRuntime();
        // 注意：不在这里调用 SyncSelectorValues()，因为会话还没加载
        // 选择器值会在 LoadSessionByIdAsync 或 LoadSessionAsync 完成后同步
    }
    
    /// <summary>
    /// Agent 选择变更
    /// </summary>
    private async Task OnAgentChanged(string value)
    {
        _selectedAgent = value ?? "";
        SessionState.SelectedAgent = _selectedAgent;
        
        var wasAcpPassthrough = _isAcpPassthrough;
        RefreshAgentRuntime();
        
        // 切换 Agent 后重新加载命令列表（按 Runtime 过滤）
        LoadCommandsFromBackend();
        
        // 切换到 ACP Agent 时，清空 Provider 和 Model，让用户重新输入
        if (!wasAcpPassthrough && _isAcpPassthrough)
        {
            _selectedModel = "";
            _selectedAcpMode = "";
            SessionState.SelectedModel = "";
            SessionState.SelectedModelProvider = "";
            SessionState.SelectedAcpMode = "";
            
            if (SessionState.CurrentSession != null)
            {
                SessionState.CurrentSession.SelectedModel = "";
                SessionState.CurrentSession.SelectedModelProvider = "";
                SessionState.CurrentSession.SelectedAcpMode = "";
            }
        }
        // 切换到 Native Agent 时，尝试恢复默认模型
        else if (wasAcpPassthrough && !_isAcpPassthrough)
        {
            var defaultModel = _models.FirstOrDefault()?.Id ?? "";
            _selectedModel = defaultModel;
            SessionState.SelectedModel = defaultModel;
            
            if (SessionState.CurrentSession != null)
            {
                SessionState.CurrentSession.SelectedModel = defaultModel;
            }
        }
        
        // Agent 变更时也需要更新 session（通过 session.updated hook）
        if (SessionState.CurrentSession != null)
        {
            SessionState.CurrentSession.SelectedAgent = _selectedAgent;
            SessionState.CurrentSession.UpdatedAt = DateTime.Now;
            await SessionManager.SaveAsync(SessionState.CurrentSession.Id);
        }
    }

    /// <summary>
    /// Native 模型选择变更
    /// </summary>
    private async Task OnModelChanged(string value)
    {
        _selectedModel = value ?? "";
        
        // 统一由 SessionManager 处理模型切换，Budget 会自动更新
        await SessionManager.SetModelAsync(SessionState.SessionId, _selectedModel);
    }

    private async Task OnAcpModelChanged(string? value)
    {
        _selectedModel = value ?? "";
        
        // 统一由 SessionManager 处理模型切换，Budget 会自动更新
        await SessionManager.SetModelAsync(SessionState.SessionId, _selectedModel);
    }

    private void OnAcpModeChanged(string? value)
    {
        _selectedAcpMode = value ?? "";
        SessionState.SelectedAcpMode = _selectedAcpMode;
    }
    
    /// <summary>
    /// 加载工具和技能数据（用于快速命令浮窗）
    /// </summary>
    private async Task LoadToolsAndSkillsAsync()
    {
        try
        {
            // 加载工具和技能信息（用于其他用途）
            await ToolInvoker.GetToolSchemasAsync();
            await SkillManager.DiscoverSkillsAsync();
        }
        catch (Exception ex)
        {
            // 静默处理，不影响主流程
        }
    }
    
    /// <summary>
    /// 从后端加载命令列表
    /// </summary>
    private void LoadCommandsFromBackend()
    {
        try
        {
            _availableCommands = CommandListService.GetAvailableCommands(SessionState);
        }
        catch (Exception ex)
        {
            _availableCommands = new List<CommandItemViewModel>();
        }
    }
    
    /// <summary>
    /// 压缩会话上下文（AI 摘要 + fallback）
    /// </summary>
    private async Task CompactSessionAsync()
    {
        if (SessionState.CurrentSession == null)
        {
            MessageService.Warning("没有活动会话");
            return;
        }
        
        var messages = SessionState.Messages;
        if (messages.Count <= 10)
        {
            MessageService.Info($"消息数量较少（{messages.Count} 条），无需压缩");
            return;
        }

        SessionState.IsCompacting = true;
        StateHasChanged();

        try
        {
            var result = await CompactionService.CompactAsync(
                SessionState.Messages, 
                SessionState.SessionId, 
                SessionState.CancellationToken);

            if (result.Success)
            {
                SessionState.CurrentSession.Messages.Clear();
                SessionState.CurrentSession.Messages.Add(result.SummaryMessage!);
                SessionState.CurrentSession.Messages.AddRange(result.TailMessages!);
                // Session 由 ChatOrchestrator 管理，这里只更新本地状态
                RefreshMessageViewModels();
                MessageService.Success(string.Format("已压缩 {0} 条消息", result.CompressedCount));
            }
            else
            {
                if (!CompactionService.IsAiCompactionAvailable)
                {
                    MessageService.Warning(result.Message ?? "未配置 LLM 模型，无法使用 AI 压缩");
                }
                else
                {
                    await FallbackCompactAsync();
                    MessageService.Warning(result.Error ?? result.Message ?? "压缩失败");
                }
            }
        }
        catch (Exception ex)
        {
            await FallbackCompactAsync();
            MessageService.Warning($"压缩失败: {ex.Message}");
        }
        finally
        {
            SessionState.IsCompacting = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Fallback：简单截断压缩（使用 SessionCompressor）
    /// </summary>
    private async Task FallbackCompactAsync()
    {
        var compressor = new SessionCompressor(keepLastN: 10);
        var messages = SessionState.CurrentSession!.Messages;
        var originalCount = messages.Count;
        var compressed = compressor.Compress(messages);
        messages.Clear();
        messages.AddRange(compressed);
        var discarded = compressor.GetDiscardedCount(originalCount);
        if (discarded > 0)
            messages.Insert(0, SessionMessage.SystemMessage(string.Format("已截断 {0} 条旧消息", discarded)));
        // Session 由 ChatOrchestrator 管理，这里只更新本地状态
        RefreshMessageViewModels();
    }
    
    /// <summary>
    /// 显示帮助信息
    /// </summary>
    private void ShowHelp()
    {
        var helpText = @"可用命令:

基础命令:
  /help   - 显示帮助信息
  /clear  - 清空当前会话消息

会话命令:
  /new    - 创建新会话
  /fork   - 分支当前会话
  /compact- 压缩会话上下文

