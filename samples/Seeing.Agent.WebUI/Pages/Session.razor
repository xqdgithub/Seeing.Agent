    /// <summary>
    /// 重命名会话
    /// </summary>
    private void OnRenameSession()
    {
        RenameForm.Title = SessionState.Title;
        RenameModalVisible = true;
    }
    
    /// <summary>
    /// 确认重命名
    /// </summary>
    private async Task OnRenameConfirm()
    {
        if (!string.IsNullOrWhiteSpace(RenameForm.Title) && SessionState.CurrentSession != null)
        {
            await SessionProvider.RenameSessionAsync(SessionState.CurrentSession.Id, RenameForm.Title.Trim());
            MessageService.Success("会话已重命名");
        }
        
        RenameModalVisible = false;
        await InvokeAsync(StateHasChanged);
    }
    
    /// <summary>
    /// 取消重命名
    /// </summary>
    private void OnRenameCancel()
    {
        RenameModalVisible = false;
    }
    
    /// <summary>
    /// 分支会话
    /// </summary>
    private async Task OnBranchSession()
    {
        if (SessionState.CurrentSession == null) return;
        
        var branchedSession = await SessionProvider.BranchSessionAsync(SessionState.CurrentSession.Id, $"{SessionState.Title} (分支)");
        
        MessageService.Success("会话已分支");
        
        // 导航到新会话
        NavigationManager.NavigateTo($"/session/{branchedSession.Id}");
    }
    
    /// <summary>
    /// 清空会话
    /// </summary>
    private async Task OnClearSession()
    {
        if (SessionState.CurrentSession != null)
        {
            SessionState.CurrentSession.ClearMessages();
            SessionState.CurrentSession.Title = "新会话";
            
            await SessionProvider.SaveCurrentSessionAsync();
            MessageService.Info("会话已清空");
            
            // 刷新 UI
            RefreshMessageViewModels();
        }
        
        await InvokeAsync(StateHasChanged);
    }
    
    /// <summary>
    /// 清除错误消息
    /// </summary>
    private void OnClearError()
    {
        ErrorMessage = null;
    }
    
    /// <summary>
    /// 释放资源
    /// </summary>
    public void Dispose()
    {
        // 取消事件订阅
        SessionProvider.OnCurrentSessionChanged -= OnSessionProviderChanged;
        
        // 清理资源
        SessionState.CancelExecution();
    }
    
