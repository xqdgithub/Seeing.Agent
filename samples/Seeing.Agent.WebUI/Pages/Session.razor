@page "/session"
@page "/session/{SessionId}"
@using AntDesign
@using Microsoft.AspNetCore.Components.Web
@using Seeing.Agent.WebUI.Models
@using Services = Seeing.Agent.WebUI.Services
@using Core = Seeing.Agent.Core
@using Seeing.Agent.WebUI.State
@using Seeing.Agent.Tools
@using Seeing.Agent.Skills
@using Seeing.Agent.Configuration
@using Seeing.Agent.Llm
@using Seeing.Session.Core
@using Seeing.Session.Management
@inject SessionState SessionState
@inject AppState AppState
@inject SessionProvider SessionProvider
@inject EventStreamHandler EventStreamHandler
@inject ErrorHandlingService ErrorHandlingService
@inject NavigationManager NavigationManager
@inject IMessageService MessageService
@inject Core.Interfaces.IAgentExecutionRouter AgentRouter
@inject Core.Interfaces.IAgentRegistry AgentRegistry
@inject Core.AgentSelectionResolver AgentSelectionResolver
@inject IWorkspaceProvider WorkspaceProvider
@inject Core.Interfaces.IPermissionChannel PermissionChannel
@inject ToolInvoker ToolInvoker
@inject SkillManager SkillManager
@inject ILlmService LlmService
@implements IDisposable

<div Class="session-page-container">
    <!-- 会话头部 -->
    <div Class="session-header">
        <div Class="session-header-left">
            <Button Type="@ButtonType.Text"
                    Size="@ButtonSize.Small"
                    Icon="@IconType.Outline.Home"
                    OnClick="@GoToHome">
                @if (!SidebarCollapsed)
                {
                    <span>首页</span>
                }
            </Button>
            <Divider Type="@DividerType.Vertical" />
            <span Class="session-title">@SessionState.Title</span>
            @if (SessionState.IsExecuting)
            {
                <Badge Status="@BadgeStatus.Processing" Text="执行中" />
            }
        </div>
        <div Class="session-header-right">
            <Space>
                <SpaceItem>
                    @if (_optionsReady)
                    {
                        <Select TItemValue="string" TItem="string"
                                Value="@_selectedAgent"
                                ValueExpression="@(() => _selectedAgent)"
                                ValueChanged="EventCallback.Factory.Create<string>(this, OnAgentChanged)"
                                DataSource="@_agentNames"
                                Style="min-width: 120px;"
                                Size="@InputSize.Small"
                                Placeholder="智能体" />
                    }
                </SpaceItem>
                <SpaceItem>
                    @if (_optionsReady)
                    {
                        @if (_isAcpPassthrough)
                        {
                            <Input Value="@_selectedAcpMode"
                                   ValueChanged="EventCallback.Factory.Create<string?>(this, OnAcpModeChanged)"
                                   Placeholder="ACP Mode"
                                   Style="min-width: 100px;"
                                   Size="@InputSize.Small" />
                            <Input Value="@_selectedModel"
                                   ValueChanged="EventCallback.Factory.Create<string?>(this, OnAcpModelChanged)"
                                   Placeholder="ACP Model"
                                   Style="min-width: 180px;"
                                   Size="@InputSize.Small" />
                        }
                        else
                        {
                            <Select TItemValue="string" TItem="string"
                                    Value="@_selectedModel"
                                    ValueExpression="@(() => _selectedModel)"
                                    ValueChanged="EventCallback.Factory.Create<string>(this, OnModelChanged)"
                                    DataSource="@_modelNames"
                                    Style="min-width: 160px;"
                                    Size="@InputSize.Small"
                                    Placeholder="模型" />
                        }
                    }
                </SpaceItem>
                <SpaceItem>
                    <Tooltip Title="重命名会话">
                        <Button Type="@ButtonType.Text"
                                Size="@ButtonSize.Small"
                                Icon="@IconType.Outline.Edit"
                                OnClick="@OnRenameSession" />
                    </Tooltip>
                </SpaceItem>
                <SpaceItem>
                    <Tooltip Title="分支会话">
                        <Button Type="@ButtonType.Text"
                                Size="@ButtonSize.Small"
                                Icon="@IconType.Outline.Copy"
                                OnClick="@OnBranchSession" />
                    </Tooltip>
                </SpaceItem>
                <SpaceItem>
                    <Tooltip Title="清空会话">
                        <Button Type="@ButtonType.Text"
                                Size="@ButtonSize.Small"
                                Icon="@IconType.Outline.Delete"
                                OnClick="@OnClearSession"
                                Disabled="@SessionState.IsExecuting" />
                    </Tooltip>
                </SpaceItem>
            </Space>
        </div>
    </div>

    <!-- 主内容区域（消息列表 + Todo 面板） -->
    <div Class="session-content-wrapper">
        <!-- 消息列表区域 -->
        <div Class="session-messages-container">
        @if (ShowEmptyState)
        {
            <!-- 无会话状态：引导用户创建新会话 -->
            <Empty Class="session-empty-state">
                <DescriptionTemplate>
                    <div Class="empty-content">
                        <Icon Type="@IconType.Outline.FileAdd" Class="empty-icon" Style="font-size: 48px;" />
                        <p Style="font-size: 18px; margin-top: 16px;">暂无会话</p>
                        <p Class="empty-hint">点击左侧边栏的"新建会话"按钮开始对话</p>
                    </div>
                </DescriptionTemplate>
            </Empty>
        }
        else if (_messageViewModels.Count == 0)
        {
            <Empty Class="session-empty-state">
                <DescriptionTemplate>
                    <div Class="empty-content">
                        <Icon Type="@IconType.Outline.Message" Class="empty-icon" />
                        <p>暂无消息</p>
                        <p Class="empty-hint">输入问题开始与 AI Agent 对话</p>
                    </div>
                </DescriptionTemplate>
            </Empty>
        }
        else
        {
            <MessageList Messages="@_messageViewModels"
                         AutoScroll="true"
                         OnToolClick="@OnToolClick" />
        }
        
        <!-- 加载状态指示器 -->
        @if (IsLoadingSession)
        {
            <div Class="loading-overlay">
                <Spin Size="@SpinSize.Large" Tip="加载会话..." />
            </div>
        }
        </div>
        
        @* Todo 侧边面板（当有任务时显示） *@
        @if (SessionState.CurrentTodoList != null && SessionState.CurrentTodoList.HasTasks)
        {
            <div Class="session-todo-panel">
                <TodoPanel TodoList="@SessionState.CurrentTodoList" />
            </div>
        }
    </div>

    <!-- 输入区域：仅在非空状态时显示 -->
    @if (!ShowEmptyState)
    {
        <div Class="session-input-container">
            <!-- Slot 扩展点: session_prompt -->
            <SlotHost SlotName="session_prompt" />
            
            <PromptInput IsProcessing="@SessionState.IsExecuting"
                         Placeholder="@GetPlaceholderText()"
                         HelpText="@GetHelpText()"
                         AvailableTools="_availableTools"
                         AvailableSkills="_availableSkills"
                         CancellationTokenSource="@SessionState.CancellationTokenSource"
                         OnSubmitCallback="@OnSubmitMessage"
                         OnCancelCallback="@OnCancelExecution" />
        </div>
    }
    
    <!-- 错误提示 -->
    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <Alert Type="@AlertType.Error"
               Message="@ErrorMessage"
               ShowIcon="true"
               Closable="true"
               OnClose="@OnClearError"
               Class="session-error-alert" />
    }
    
    <!-- 重命名对话框（仅在打开时渲染，避免隐藏 Modal 内 FormItem 初始化失败） -->
    @if (RenameModalVisible)
    {
        <Modal Title="重命名会话"
               Visible="true"
               OnOk="@OnRenameConfirm"
               OnCancel="@OnRenameCancel"
               OkText="@OkText"
               CancelText="@CancelText">
            <Form Model="@RenameForm" Layout="@FormLayout.Horizontal">
                <FormItem Label="会话标题">
                    <Input @bind-Value="@RenameForm.Title"
                           Placeholder="输入新的会话标题" />
                </FormItem>
            </Form>
        </Modal>
    }
</div>

@code {

    /// <summary>
    /// 常量文本（避免编码问题）
    /// </summary>
    private const string OkText = "确定";
    private const string CancelText = "取消";
    
    /// <summary>
    /// Agent/模型选择器相关
    /// </summary>
    private string _selectedAgent = "";
    private List<string> _agentNames = new();
    private string _selectedModel = "";
    private List<string> _modelNames = new();
    private string _selectedAcpMode = "";
    private bool _isAcpPassthrough;
    private bool _optionsReady;
    
    /// <summary>
    /// 可用工具列表（用于快速命令）
    /// </summary>
    private List<QuickToolViewModel> _availableTools = new();
    
    /// <summary>
    /// 可用技能列表（用于快速命令）
    /// </summary>
    private List<QuickSkillViewModel> _availableSkills = new();

    /// <summary>
    /// UI 显示用的消息视图模型列表（从 SessionData.Messages 转换）
    /// </summary>
    private List<MessageViewModel> _messageViewModels = new();

    /// <summary>
    /// 路由参数：会话 ID
    /// </summary>
    [Parameter]
    public string? SessionId { get; set; }

    /// <summary>
    /// 侧边栏折叠状态（从 MainLayout 获取）
    /// </summary>
    private bool SidebarCollapsed { get; set; } = false;

    /// <summary>
    /// 是否正在加载会话
    /// </summary>
    private bool IsLoadingSession { get; set; } = false;

    /// <summary>
    /// 是否显示空状态（无会话）
    /// </summary>
    private bool ShowEmptyState { get; set; } = false;

    /// <summary>
    /// 错误消息
    /// </summary>
    private string? ErrorMessage { get; set; }

    /// <summary>
    /// 重命名对话框可见性
    /// </summary>
    private bool RenameModalVisible { get; set; } = false;

    /// <summary>
    /// 重命名表单
    /// </summary>
    private RenameSessionForm RenameForm { get; set; } = new();

    /// <summary>
    /// 当前选中的工具调用（用于详情显示）
    /// </summary>
    private ToolCallViewModel? SelectedToolCall { get; set; }

    private bool _hasRendered;
    private string? _loadedSessionId;

    /// <summary>
    /// 组件初始化
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        // 订阅会话变更事件
        SessionProvider.OnCurrentSessionChanged += OnSessionProviderChanged;
        
        // 加载 Agent 和模型选项列表（不设置选中值）
        await LoadOptionsAsync();
        
        // 加载工具和技能数据
        await LoadToolsAndSkillsAsync();
        
        // 加载会话（选项就绪后再加载，避免 Select 在 DataSource 为空时渲染）
        if (!string.IsNullOrEmpty(SessionId))
        {
            await LoadSessionByIdAsync(SessionId);
            _loadedSessionId = SessionId;
        }
        else
        {
            await LoadSessionAsync();
            _loadedSessionId = SessionState.CurrentSession?.Id;
        }
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
            _hasRendered = true;
    }

    private void RequestRender()
    {
        if (!_hasRendered)
            return;
        _ = InvokeAsync(StateHasChanged);
    }
    
    /// <summary>
    /// 同步选择器值（从 SessionState 获取）
    /// </summary>
    private void SyncSelectorValues()
    {
        var agent = SessionState.SelectedAgent ?? "";
        var model = SessionState.SelectedModel ?? "";
        _selectedAgent = _agentNames.Contains(agent) ? agent : (_agentNames.FirstOrDefault() ?? agent);
        _selectedModel = _isAcpPassthrough
            ? model
            : (_modelNames.Contains(model) ? model : (_modelNames.FirstOrDefault() ?? model));
        _selectedAcpMode = SessionState.SelectedAcpMode ?? "";
        RefreshAgentRuntime();
        RequestRender();
    }

    private void RefreshAgentRuntime()
    {
        if (string.IsNullOrWhiteSpace(_selectedAgent))
        {
            _isAcpPassthrough = false;
            return;
        }

        var info = AppState.AvailableAgents.FirstOrDefault(a =>
            string.Equals(a.Name, _selectedAgent, StringComparison.OrdinalIgnoreCase));
        _isAcpPassthrough = info?.Runtime == Seeing.Agent.Core.Models.AgentRuntime.AcpPassthrough;
    }
    
    /// <summary>
    /// 加载模型选项
    /// </summary>
    private async Task LoadOptionsAsync()
    {
        _optionsReady = false;
        // 加载 Agent 选项
        try
        {
            var agents = await AgentRegistry.GetPrimaryAgentsAsync();
            _agentNames = agents
                .Where(a => !string.IsNullOrEmpty(a.Name))
                .Select(a => a.Name)
                .ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"加载Agent列表失败: {ex.Message}");
            _agentNames = new List<string>();
        }
        
        // 加载模型选项
        try
        {
            var availableModels = LlmService.GetAvailableModels();
            if (availableModels != null)
            {
                AppState.AvailableModels = availableModels;
                _modelNames = availableModels
                    .Where(m => !string.IsNullOrEmpty(m.Key))
                    .Select(m => m.Key)
                    .ToList();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"加载模型列表失败: {ex.Message}");
            _modelNames = new List<string>();
        }

        _optionsReady = _agentNames.Count > 0 || _modelNames.Count > 0;
        RefreshAgentRuntime();
        SyncSelectorValues();
    }
    
    /// <summary>
    /// Agent 选择变更
    /// </summary>
    private async Task OnAgentChanged(string value)
    {
        _selectedAgent = value ?? "";
        SessionState.SelectedAgent = _selectedAgent;
        AppState.SelectedAgent = _selectedAgent;
        RefreshAgentRuntime();
        await SaveSessionAsync();
    }

    /// <summary>
    /// Native 模型选择变更
    /// </summary>
    private async Task OnModelChanged(string value)
    {
        _selectedModel = value ?? "";
        SessionState.SelectedModel = _selectedModel;
        AppState.SelectedModel = _selectedModel;
        await SaveSessionAsync();
    }

    private async Task OnAcpModelChanged(string? value)
    {
        _selectedModel = value ?? "";
        SessionState.SelectedModel = _selectedModel;
        AppState.SelectedModel = _selectedModel;
        await SaveSessionAsync();
    }

    private async Task OnAcpModeChanged(string? value)
    {
        _selectedAcpMode = value ?? "";
        SessionState.SelectedAcpMode = _selectedAcpMode;
        await SaveSessionAsync();
    }
    
    /// <summary>
    /// 保存会话
    /// </summary>
    private async Task SaveSessionAsync()
    {
        if (SessionState.CurrentSession != null)
        {
            await SessionProvider.SaveCurrentSessionAsync();
        }
    }
    
    /// <summary>
    /// 会话变更事件处理
    /// </summary>
    private void OnSessionProviderChanged()
    {
        if (SessionProvider.CurrentSession == null)
            return;

        if (SessionState.CurrentSession?.Id == SessionProvider.CurrentSession.Id)
            return;

        _ = InvokeAsync(async () =>
        {
            SessionState.SetSession(SessionProvider.CurrentSession!);
            RefreshMessageViewModels();
            _loadedSessionId = SessionProvider.CurrentSession!.Id;

            AppState.SelectedAgent = SessionState.SelectedAgent;
            AppState.SelectedModel = SessionState.SelectedModel;
            AppState.SelectedModelProvider = SessionState.SelectedModelProvider;
            AppState.CurrentSessionId = SessionProvider.CurrentSession!.Id;
            SyncSelectorValues();
            AppState.NotifyChange();
        });
    }
    
    /// <summary>
    /// 加载工具和技能数据（用于快速命令浮窗）
    /// </summary>
    private async Task LoadToolsAndSkillsAsync()
    {
        try
        {
            // 加载工具
            var toolSchemas = await ToolInvoker.GetToolSchemasAsync();
            _availableTools = toolSchemas.Select(t => new QuickToolViewModel
            {
                Name = t.Function.Name,
                Id = t.Function.Name,
                Description = t.Function.Description ?? "",
                ParametersHint = GetParametersHint(t.Function.Parameters)
            }).ToList();
            
            // 加载技能
            await SkillManager.DiscoverSkillsAsync();
            var skillInfos = SkillManager.GetAllSkillInfos();
            _availableSkills = skillInfos.Values.Select(s => new QuickSkillViewModel
            {
                Name = s.Name,
                Description = s.Description ?? "",
                Version = s.Version,
                Author = s.Author
            }).ToList();
        }
        catch (Exception ex)
        {
            // 静默处理，不影响主流程
            Console.WriteLine($"加载工具/技能失败: {ex.Message}");
        }
    }
    
    /// <summary>
    /// 获取参数提示（简要描述）
    /// </summary>
    private string? GetParametersHint(object? parameters)
    {
        if (parameters == null) return null;
        
        try
        {
            // 尝试解析为 JsonElement
            if (parameters is System.Text.Json.JsonElement element)
            {
                if (element.TryGetProperty("properties", out var props))
                {
                    var names = props.EnumerateObject().Select(p => p.Name).Take(3);
                    return $"参数: {string.Join(", ", names)}";
                }
            }
            return null;
        }
        catch
        {
            return null;
        }
    }

    /// <summary>
    /// 参数变更时重新加载会话
    /// </summary>
    protected override async Task OnParametersSetAsync()
    {
        if (!_optionsReady)
            return;

        if (!string.IsNullOrEmpty(SessionId) && SessionId != _loadedSessionId)
        {
            await LoadSessionByIdAsync(SessionId);
            _loadedSessionId = SessionId;
            return;
        }

        // SessionId 相同但需要刷新 UI（比如外部切换会话后）
        if (!string.IsNullOrEmpty(SessionId) && SessionId == _loadedSessionId)
        {
            // 确保 SessionState 与 SessionProvider 同步
            if (SessionProvider.CurrentSession != null && 
                SessionProvider.CurrentSession.Id == SessionId &&
                SessionState.CurrentSession != SessionProvider.CurrentSession)
            {
                SessionState.SetSession(SessionProvider.CurrentSession);
            }
            
            // 刷新消息列表 UI
            RefreshMessageViewModels();
            RequestRender();
        }
    }

    /// <summary>
    /// 加载会话
    /// </summary>
    private async Task LoadSessionAsync()
    {
        IsLoadingSession = true;

        try
        {
            // 如果路由有指定会话 ID，加载该会话
            if (!string.IsNullOrEmpty(SessionId))
            {
                await LoadSessionByIdAsync(SessionId);
            }
            else
            {
                // 无路由参数时，确保有会话可用
                // 等待 MainLayout 完成初始化（检查 CurrentSession）
                if (SessionProvider.CurrentSession == null)
                {
                    // MainLayout 可能还没完成初始化，自行初始化
                    await SessionProvider.InitializeSessionListAsync();
                    
                    var sessions = SessionProvider.GetSessionList();
                    if (sessions.Count > 0)
                    {
                        // 加载最近的会话
                        await LoadSessionByIdAsync(sessions.First().Id);
                    }
                    else
                    {
                        // 无任何会话，显示空状态
                        ShowEmptyState = true;
                    }
                }
                else
                {
                    // 已有当前会话，直接使用
                    SessionState.SetSession(SessionProvider.CurrentSession);
                    RefreshMessageViewModels();
                    ShowEmptyState = false;
                    SyncSelectorValues();
                }
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"加载会话失败: {ex.Message}";
            ShowEmptyState = true;
        }
        finally
        {
            IsLoadingSession = false;
            RequestRender();
        }
    }

    /// <summary>
    /// 根据 ID 加载会话（使用 SessionProvider）
    /// </summary>
    private async Task LoadSessionByIdAsync(string sessionId)
    {
        // 使用 SessionProvider 加载 SessionData
        var sessionData = await SessionProvider.LoadSessionAsync(sessionId);

        if (sessionData != null)
        {
            SessionState.SetSession(sessionData);
            await EnsureDefaultAgentSelectionAsync();
            
            // 转换消息为 UI 显示用的 MessageViewModel
            RefreshMessageViewModels();
            
            // 同步更新 AppState（用于 AgentSelector/ModelSelector 显示）
            AppState.SelectedAgent = SessionState.SelectedAgent;
            AppState.SelectedModel = SessionState.SelectedModel;
            AppState.CurrentSessionId = sessionId;
            
            // 同步选择器显示值
            SyncSelectorValues();
            
            // 通知 UI 更新
            AppState.NotifyChange();
            
            // 隐藏空状态
            ShowEmptyState = false;
        }
        else
        {
            ErrorMessage = $"找不到会话: {sessionId}";
            ShowEmptyState = true;
        }
    }

    /// <summary>
    /// 会话未指定 Agent/Model 时，按 .seeing 配置解析默认值并同步到 UI 状态。
    /// </summary>
    private async Task EnsureDefaultAgentSelectionAsync()
    {
        if (SessionState.CurrentSession == null)
            return;

        if (string.IsNullOrWhiteSpace(SessionState.CurrentSession.SelectedAgent))
        {
            var agentId = await AgentSelectionResolver.ResolveAgentIdAsync(
                null,
                null,
                SessionState.CancellationToken);
            SessionState.SelectedAgent = agentId;
            _selectedAgent = agentId;
            AppState.SelectedAgent = agentId;
        }

        if (string.IsNullOrWhiteSpace(SessionState.CurrentSession.SelectedModel))
        {
            RefreshAgentRuntime();
            string? modelId;
            if (_isAcpPassthrough)
            {
                modelId = AgentSelectionResolver.ResolveAcpModelId(null, null);
            }
            else
            {
                modelId = AgentSelectionResolver.ResolveModelId(
                    null,
                    null,
                    SessionState.SelectedAgent);
            }

            if (!string.IsNullOrEmpty(modelId))
            {
                SessionState.SelectedModel = modelId;
                _selectedModel = modelId;
                AppState.SelectedModel = modelId;
            }
        }
    }

    /// <summary>
    /// 从 SessionData.Messages 刷新 UI 显示的消息列表
    /// </summary>
    private void RefreshMessageViewModels()
    {
        _messageViewModels.Clear();
        
        if (SessionState.CurrentSession?.Messages != null)
        {
            foreach (var msg in SessionState.CurrentSession.Messages)
            {
                _messageViewModels.Add(ConvertToMessageViewModel(msg));
            }
        }
    }

    /// <summary>
    /// 增量更新当前助手消息（用于流式显示，避免全量刷新）
    /// </summary>
    private void UpdateCurrentAssistantMessage()
    {
        var currentMsg = EventStreamHandler.GetCurrentAssistantMessage();
        if (currentMsg == null) return;

        // 直接使用消息 ID 查找（ID 已包含 loopId + step，确保唯一性）
        var existingViewModel = _messageViewModels.FirstOrDefault(m => m.Id == currentMsg.Id);
        
        if (existingViewModel != null)
        {
            // 跟踪推理内容是否还在更新
            var hadReasoningBefore = !string.IsNullOrEmpty(existingViewModel.Reasoning);
            var previousReasoning = existingViewModel.Reasoning;
            
            // 增量更新现有消息
            existingViewModel.Content = currentMsg.Content ?? "";
            existingViewModel.Reasoning = currentMsg.ReasoningContent;
            existingViewModel.LoopId = currentMsg.LoopId;
            existingViewModel.Step = currentMsg.Step;
            existingViewModel.IsComplete = false;
            
            // 推理完成判断：推理内容存在且本次更新未变化 → 推理阶段已完成
            if (!string.IsNullOrEmpty(existingViewModel.Reasoning) && 
                existingViewModel.Reasoning == previousReasoning &&
                hadReasoningBefore)
            {
                existingViewModel.IsReasoningComplete = true;
            }
            
            // 更新工具调用（使用统一工厂方法）
            if (currentMsg.ToolCalls != null)
            {
                existingViewModel.ToolCalls = currentMsg.ToolCalls
                    .Select(tc => ToolCallViewModel.FromSessionToolCall(tc, SessionState.SessionId))
                    .ToList();
            }
        }
        else
        {
            // 新消息，添加到列表（流式过程中标记为未完成）
            _messageViewModels.Add(ConvertToMessageViewModel(currentMsg, isComplete: false));
        }
    }

    /// <summary>
    /// 将 SessionMessage 转换为 MessageViewModel（用于 UI 显示）
    /// </summary>
    /// <param name="msg">会话消息</param>
    /// <param name="isComplete">消息是否已完成（默认 true，流式过程中应传 false）</param>
    private MessageViewModel ConvertToMessageViewModel(SessionMessage msg, bool isComplete = true)
    {
        var viewModel = new MessageViewModel
        {
            Id = msg.Id ?? Guid.NewGuid().ToString("N")[..8],
            LoopId = msg.LoopId,
            Step = msg.Step,
            Role = msg.Role,
            Content = msg.Content,
            Reasoning = msg.ReasoningContent,
            Timestamp = msg.CreatedAt.ToLocalTime(),
            IsComplete = isComplete,
            IsReasoningComplete = isComplete && !string.IsNullOrEmpty(msg.ReasoningContent)
        };

        // 转换多模态内容段（修复：复制 Parts）
        if (msg.Parts != null && msg.Parts.Count > 0)
        {
            viewModel.Parts = msg.Parts.Select(p => ContentPartViewModel.FromSessionPart(p)).ToList();
        }

        // 转换工具调用（使用统一工厂方法）
        if (msg.ToolCalls != null && msg.ToolCalls.Count > 0)
        {
            viewModel.ToolCalls = msg.ToolCalls
                .Select(tc => ToolCallViewModel.FromSessionToolCall(tc, SessionState.SessionId))
                .ToList();
        }

        return viewModel;
    }

