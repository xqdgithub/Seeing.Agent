    /// <summary>
    /// 提交消息处理（使用 Submit + SubscribeEvents 模式）
    /// </summary>
    private async Task OnSubmitMessage(PromptSubmitEventArgs args)
    {
        // 验证输入
        if (string.IsNullOrWhiteSpace(args.Text) && args.Attachments.Count == 0)
        {
            ErrorMessage = "请输入消息内容";
            return;
        }

        // 确保有当前会话
        if (SessionState.CurrentSession == null)
        {
            ErrorMessage = "请先创建或选择一个会话";
            return;
        }

        // 清除错误消息
        ErrorMessage = null;

        // 构建输入
        var input = new ChatInput { Text = args.Text };
        
        if (args.Attachments != null && args.Attachments.Count > 0)
        {
            input = new ChatInput
            {
                Text = args.Text,
                Attachments = args.Attachments
                    .Where(a => a.Status == AttachmentUploadStatus.Completed)
                    .Select(a => new ChatAttachment
                    {
                        Base64Data = ExtractBase64Data(a.Base64Content),
                        MimeType = a.FileType,
                        FileName = a.FileName
                    }).ToList()
            };
        }

        // 构建选项
        // 组装完整的 ModelId 格式: provider/model（Native Agent 需要）
        var modelId = SessionState.SelectedModel;
        var providerId = SessionState.SelectedModelProvider;
        var fullModelId = !string.IsNullOrEmpty(providerId) && !modelId.Contains('/')
            ? $"{providerId}/{modelId}"
            : modelId;

        var options = new ChatOptions
        {
            AgentId = SessionState.SelectedAgent,
            ModelId = fullModelId,
            ModeId = SessionState.SelectedAcpMode,
            WorkingDirectory = SessionState.CurrentSession?.WorkingDirectory ?? WorkspaceProvider.WorkspaceRoot
        };

        try
        {
            // 初始化取消令牌源
            SessionState.StartExecution();
            
            // 提交执行（用户消息会立即保存）
            var result = await ChatOrchestrator.SubmitAsync(SessionState.SessionId, input, options);
            
            if (!result.Success)
            {
                ErrorMessage = result.Error ?? "提交失败";
                SessionState.CompleteExecution();
                await InvokeAsync(StateHasChanged);
                return;
            }

            // 更新 UI 状态
            SessionState.ExecutionStatus = result.Status;
            SessionState.QueuePosition = result.QueuePosition;
            SessionState.CurrentExecutionId = result.ExecutionId;
            
            await InvokeAsync(StateHasChanged);

            // 订阅事件流
            _ = ConsumeEventStreamAsync(result.ExecutionId!);
        }
        catch (Exception ex)
        {
            ErrorMessage = $"执行失败: {ex.Message}";
            await InvokeAsync(StateHasChanged);
        }
    }

    /// <summary>
    /// 消费事件流（后台任务）
    /// </summary>
    private async Task ConsumeEventStreamAsync(string executionId)
    {
        var charCount = 0;
        var _currentCodeBlockDepth = 0;

        try
        {
            await foreach (var evt in ChatOrchestrator.SubscribeEvents(SessionState.SessionId, CancellationToken.None))
            {
                // 检查是否是当前执行的事件
                if (evt is ExecutionCompleteEvent completeEvt && completeEvt.ExecutionId == executionId)
                {
                    // 执行完成，更新状态
                    SessionState.ExecutionStatus = completeEvt.Status;
                    SessionState.CurrentExecutionId = null;
                    RefreshMessageViewModels();
                    await InvokeAsync(StateHasChanged);
                    break;
                }

                // 处理事件 - 由 EventStreamHandler 统一处理
                // HandleMessageEvent 不再创建/更新消息，只刷新 UI
                EventStreamHandler.ProcessEvent(evt);

                // UI 更新动态节流
                if (evt is StreamDeltaEvent deltaEvt)
                {
                    var contentLen = deltaEvt.ContentDelta?.Length ?? 0;
                    var reasoningLen = deltaEvt.ReasoningDelta?.Length ?? 0;
                    charCount += contentLen + reasoningLen;

                    var inCodeBlock = _currentCodeBlockDepth > 0;
                    var contentDelta = deltaEvt.ContentDelta;
                    var hasNewline = contentDelta?.Contains("\n") == true;
                    var threshold = inCodeBlock ? 20 : 8;

                    if (contentDelta?.Contains("```") == true)
                    {
                        _currentCodeBlockDepth += contentDelta.Count(c => c == '`') / 3;
                        _currentCodeBlockDepth = Math.Max(0, _currentCodeBlockDepth % 2 == 0 ? 0 : 1);
                        threshold = 0;
                    }

                    if (charCount >= threshold || hasNewline || threshold == 0)
                    {
                        RefreshMessageViewModels();
                        await InvokeAsync(StateHasChanged);
                        charCount = 0;
                    }
                }
                else if (evt is StreamStartEvent)
                {
                    RefreshMessageViewModels();
                    await InvokeAsync(StateHasChanged);
                }
                else if (evt is SessionUpdatedEvent)
                {
                    RefreshMessageViewModels();
                }
                else if (evt is NavigateEvent navEvt)
                {
                    if (!string.IsNullOrEmpty(navEvt.Target))
                    {
                        NavigationManager.NavigateTo(navEvt.Target);
                    }
                }
                else
                {
                    RefreshMessageViewModels();
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        catch (OperationCanceledException)
        {
            // 只有在执行状态为 Cancelled 时才显示取消消息
            // 避免 CancellationToken.None 导致的误判
            if (SessionState.ExecutionStatus == ExecutionStatus.Cancelled)
            {
                if (SessionState.CurrentSession != null)
                {
                    SessionState.CurrentSession.AddMessage(SessionMessage.SystemMessage("执行已取消"));
                }
            }
            RefreshMessageViewModels();
        }
        catch (Exception ex)
        {
            ErrorMessage = $"执行失败: {ex.Message}";
            if (SessionState.CurrentSession != null)
            {
                SessionState.CurrentSession.AddMessage(SessionMessage.SystemMessage($"执行出错: {ex.Message}"));
            }
            RefreshMessageViewModels();
        }
        finally
        {
            SessionState.ExecutionStatus = null;
            SessionState.CurrentExecutionId = null;
            SessionState.CompleteExecution();
            RefreshMessageViewModels();
            await InvokeAsync(StateHasChanged);
        }
    }



    /// <summary>
    /// 处理 IMessageEvent - 仅处理 UI 相关逻辑
    /// 消息数据由 EventStreamHandler 统一管理
    /// </summary>
    private void HandleMessageEvent(IMessageEvent evt)
    {
        // 消息数据由 EventStreamHandler 处理
        // 这里只处理 UI 相关的逻辑（如导航、刷新等）
        
        if (evt is NavigateEvent navEvt && !string.IsNullOrEmpty(navEvt.Target))
        {
            NavigationManager.NavigateTo(navEvt.Target);
        }
    }

    /// <summary>
    /// 查找工具调用的目标消息
    /// </summary>
    private SessionMessage? FindTargetMessageForToolCall(ToolCallEvent toolEvt)
    {
        if (SessionState.CurrentSession?.Messages == null)
            return null;
        
        // 1. 优先使用 _currentStreamingMessageId
        if (!string.IsNullOrEmpty(_currentStreamingMessageId))
        {
            var msg = SessionState.CurrentSession.Messages.FirstOrDefault(m => m.Id == _currentStreamingMessageId);
            if (msg != null)
                return msg;
        }
        
        // 2. 使用 LoopId 查找
        if (!string.IsNullOrEmpty(toolEvt.LoopId))
        {
            var msg = SessionState.CurrentSession.Messages
                .Where(m => m.LoopId == toolEvt.LoopId && m.Role == "assistant")
                .OrderByDescending(m => m.Step)
                .FirstOrDefault();
            if (msg != null)
                return msg;
        }
        
        // 3. 使用最后一条助手消息
        return SessionState.CurrentSession.Messages
            .Where(m => m.Role == "assistant")
            .LastOrDefault();
    }

    /// <summary>
    /// 从 Base64 字符串中提取纯 Base64 数据（去除 data: 前缀）
    /// </summary>
    private static string ExtractBase64Data(string? base64Content)
    {
        if (string.IsNullOrEmpty(base64Content))
            return string.Empty;
        
        // 检查是否有 data: URL 前缀
        const string dataPrefix = "data:";
        if (base64Content.StartsWith(dataPrefix))
        {
            // 找到 base64, 的位置
            var base64Index = base64Content.IndexOf(";base64,");
            if (base64Index >= 0)
            {
                return base64Content.Substring(base64Index + 8);
            }
        }
        
        return base64Content;
    }

    /// <summary>
    /// 取消执行处理（使用新的 Cancel API）
    /// </summary>
    private async Task OnCancelExecution()
    {
        // 取消本地 CancellationToken
        SessionState.CancelExecution();
        
        // 取消当前执行
        if (!string.IsNullOrEmpty(SessionState.CurrentExecutionId))
        {
            var cancelled = ChatOrchestrator.Cancel(SessionState.CurrentExecutionId);
            
            if (cancelled)
            {
                SessionState.ExecutionStatus = ExecutionStatus.Cancelled;
                SessionState.CurrentExecutionId = null;
                
                // 添加取消提示
                if (SessionState.CurrentSession != null)
                {
                    SessionState.CurrentSession.AddMessage(SessionMessage.SystemMessage("用户取消了当前执行"));
                }
            }
        }
        
        await InvokeAsync(StateHasChanged);
    }
    
