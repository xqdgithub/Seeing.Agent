@page "/memory"
@using AntDesign
@using Seeing.Agent.Memory.Abstractions
@using Seeing.Agent.Memory.Core.Models
@using Seeing.Agent.Memory.Core.Graph
@inject IMemoryService MemoryService
@inject IMessageService MessageService
@inject NavigationManager Navigation

<PageTitle>记忆 - Seeing.Agent</PageTitle>

<WorkspacePageShell Loading="@_loading" IsEmpty="@false"
                    EmptyTitle="记忆模块" EmptyDescription="基于文件的记忆系统，支持混合检索和知识图谱">
    <Breadcrumb>
        <BreadcrumbItem>工作区</BreadcrumbItem>
        <BreadcrumbItem>记忆</BreadcrumbItem>
    </Breadcrumb>
    <Extra>
        <Space>
            <Button OnClick="@(() => Navigation.NavigateTo("/memory/settings"))">设置</Button>
            <Button OnClick="@(() => Navigation.NavigateTo("/memory/browse"))">目录浏览</Button>
            <Button OnClick="@(() => Navigation.NavigateTo("/memory/graph"))">知识图谱</Button>
            <Button OnClick="@(() => Navigation.NavigateTo("/memory/stats"))">统计</Button>
            <Button Icon="@IconType.Outline.Reload" OnClick="LoadStatsAsync">刷新</Button>
            <Popconfirm Title="确定清空全部记忆文件、索引与图谱？此操作不可恢复。"
                        OnConfirm="ClearAllAsync"
                        OkText="清空全部"
                        OkButtonProps="@(new ButtonProps { Danger = true })">
                <Button Danger Loading="@_clearing">清空全部</Button>
            </Popconfirm>
        </Space>
    </Extra>
    <Stats>
        <div class="stat-item">
            <div class="stat-icon"><Icon Type="@IconType.Outline.Database" /></div>
            <div class="stat-content">
                <span class="stat-value">@_fileCount</span>
                <span class="stat-label">记忆文件</span>
            </div>
        </div>
        <div class="stat-item">
            <div class="stat-icon"><Icon Type="@IconType.Outline.Search" /></div>
            <div class="stat-content">
                <span class="stat-value">@_vectorCount</span>
                <span class="stat-label">向量索引</span>
            </div>
        </div>
        <div class="stat-item">
            <div class="stat-icon"><Icon Type="@IconType.Outline.Apartment" /></div>
            <div class="stat-content">
                <span class="stat-value">@_nodeCount</span>
                <span class="stat-label">图谱节点</span>
            </div>
        </div>
        <div class="stat-item">
            <div class="stat-icon"><Icon Type="@IconType.Outline.Link" /></div>
            <div class="stat-content">
                <span class="stat-value">@_edgeCount</span>
                <span class="stat-label">图谱边</span>
            </div>
        </div>
    </Stats>
    <Filters>
        <div class="filter-search" style="flex: 1;">
            <Search Placeholder="搜索记忆..." @bind-Value="@_query" OnSearch="SearchAsync" AllowClear="true" EnterButton="true" />
        </div>
    </Filters>
    <ChildContent>
        @if (_hits.Any())
        {
            <Table TItem="SearchHitRow" DataSource="@_hits" RowKey="@(m => m.Path)">
                <PropertyColumn Property="c => c.Id" Title="ID" />
                <PropertyColumn Property="c => c.Type" Title="类型" />
                <PropertyColumn Property="c => c.Title" Title="标题" />
                <PropertyColumn Property="c => c.ScoreText" Title="相关度" />
                <PropertyColumn Property="c => c.Highlight" Title="摘要" />
                <ActionColumn Title="操作">
                    <Button Size="@ButtonSize.Small" OnClick="@(() => Navigation.NavigateTo($"/memory/detail/{context.EncodedPath}"))">查看</Button>
                </ActionColumn>
            </Table>
        }
        else if (!string.IsNullOrWhiteSpace(_query))
        {
            <div style="text-align: center; padding: 40px; color: #999;">
                未找到匹配的记忆
            </div>
        }
        else
        {
            <div style="text-align: center; padding: 40px; color: #999;">
                输入关键词搜索记忆，或点击上方按钮浏览目录、查看图谱
            </div>
        }
    </ChildContent>
</WorkspacePageShell>

@code {
    private string _query = "";
    private bool _loading;
    private bool _clearing;
    private int _fileCount;
    private int _vectorCount;
    private int _nodeCount;
    private int _edgeCount;
    private List<SearchHitRow> _hits = new();

    protected override async Task OnInitializedAsync() => await LoadStatsAsync();

    private async Task LoadStatsAsync()
    {
        _loading = true;
        try
        {
            var stats = await MemoryService.GetStatsAsync();
            _fileCount = stats.FileCount;
            _vectorCount = stats.Index.TotalVectors;
            _nodeCount = stats.Graph.NodeCount;
            _edgeCount = stats.Graph.EdgeCount;
        }
        finally { _loading = false; }
    }

    private async Task ClearAllAsync()
    {
        _clearing = true;
        try
        {
            var count = await MemoryService.ClearAllAsync();
            MessageService.Success($"已清空全部记忆（{count} 个文件）");
            _hits.Clear();
            await LoadStatsAsync();
        }
        catch (Exception ex)
        {
            MessageService.Error($"清空失败: {ex.Message}");
        }
        finally
        {
            _clearing = false;
        }
    }

    private async Task SearchAsync()
    {
        if (string.IsNullOrWhiteSpace(_query)) return;

        _loading = true;
        try
        {
            var query = new SearchQuery(Text: _query, Mode: SearchMode.Hybrid, Limit: 20);
            var results = await MemoryService.SearchAsync(query);
            _hits = results.Select(h => new SearchHitRow
            {
                Path = h.Node.Path,
                EncodedPath = Uri.EscapeDataString(h.Node.Path),
                Id = h.Node.Metadata.Id,
                Type = h.Node.Metadata.Type.ToString(),
                Title = h.Node.Metadata.Title ?? Path.GetFileName(h.Node.Path),
                ScoreText = $"{h.Score:P0}",
                Highlight = h.Highlight?.Length > 100 ? h.Highlight[..100] + "..." : h.Highlight ?? ""
            }).ToList();
        }
        finally { _loading = false; }
    }

    private sealed class SearchHitRow
    {
        public string Path { get; set; } = "";
        public string EncodedPath { get; set; } = "";
        public string Id { get; set; } = "";
        public string Type { get; set; } = "";
        public string Title { get; set; } = "";
        public string ScoreText { get; set; } = "";
        public string Highlight { get; set; } = "";
    }
}
