@page "/mcp"
@using AntDesign
@using Seeing.Agent.Configuration
@using Seeing.Agent.MCP
@using Seeing.Agent.MCP.Core
@using Seeing.Agent.WebUI.Services
@using System.Text.Json
@inject IMcpManager McpManager
@inject McpStateService McpStateService
@inject IMessageService MessageService
@implements IDisposable

<PageTitle>MCP - Seeing.Agent</PageTitle>

<div class="workspace-page">
    <div class="page-header">
        <Breadcrumb>
            <BreadcrumbItem>工作区</BreadcrumbItem>
            <BreadcrumbItem>MCP 客户端</BreadcrumbItem>
        </Breadcrumb>
        <div class="header-actions">
            <Space>
                <SpaceItem>
                    <Button Type="@ButtonType.Default" Icon="@IconType.Outline.Reload" OnClick="HandleRefresh">刷新</Button>
                </SpaceItem>
                <SpaceItem>
                    <Button Type="@ButtonType.Primary" Icon="@IconType.Outline.Plus" OnClick="ShowAddModal">添加客户端</Button>
                </SpaceItem>
            </Space>
        </div>
    </div>
    
    @* Statistics Bar *@
    @if (!_isLoading && _statuses.Any())
    {
        <div class="page-stats">
            <div class="stat-item">
                <div class="stat-icon">
                    <Icon Type="@IconType.Outline.Appstore" />
                </div>
                <div class="stat-content">
                    <span class="stat-value">@_statuses.Count</span>
                    <span class="stat-label">Total</span>
                </div>
            </div>
            <div class="stat-item">
                <div class="stat-icon" style="background: var(--color-success-bg); color: var(--color-success);">
                    <Icon Type="@IconType.Outline.CheckCircle" />
                </div>
                <div class="stat-content">
                    <span class="stat-value">@_connectedCount</span>
                    <span class="stat-label">Connected</span>
                </div>
            </div>
            <div class="stat-item">
                <div class="stat-icon" style="background: var(--color-error-bg); color: var(--color-error);">
                    <Icon Type="@IconType.Outline.CloseCircle" />
                </div>
                <div class="stat-content">
                    <span class="stat-value">@_errorCount</span>
                    <span class="stat-label">Error</span>
                </div>
            </div>
            <div class="stat-item">
                <div class="stat-icon" style="background: var(--color-warning-bg); color: var(--color-warning);">
                    <Icon Type="@IconType.Outline.PauseCircle" />
                </div>
                <div class="stat-content">
                    <span class="stat-value">@_pausedCount</span>
                    <span class="stat-label">Paused</span>
                </div>
            </div>
            <div class="stat-item">
                <div class="stat-icon" style="background: var(--color-bg-subtle); color: var(--color-text-secondary);">
                    <Icon Type="@IconType.Outline.Stop" />
                </div>
                <div class="stat-content">
                    <span class="stat-value">@_disabledCount</span>
                    <span class="stat-label">Disabled</span>
                </div>
            </div>
        </div>
    }
    
    <div class="page-content">
        @if (_isLoading) { 
            <div class="loading-spinner">
                <Spin Size="@SpinSize.Large" />
            </div>
        }
        else if (!_statuses.Any())
        {
            <div class="empty-state">
                <div class="empty-state-icon">
                    <Icon Type="@IconType.Outline.Api" />
                </div>
                <h3 class="empty-state-title">No MCP Clients</h3>
                <p class="empty-state-description">Add an MCP client to connect to external tools and services.</p>
                <div class="empty-state-action">
                    <Button Type="@ButtonType.Primary" Icon="@IconType.Outline.Plus" OnClick="ShowAddModal">添加客户端</Button>
                </div>
            </div>
        }
        else {
            <div class="items-grid">
            @foreach (var kvp in _statuses) {
                var status = kvp.Value;
                <div class="item-card @GetStateClass(status) @(status.State == McpConnectionState.Disabled ? "state-disabled" : "")">
                    <div class="item-card-header">
                        <div class="card-icon @GetIconClass(status)">
                            <Icon Type="@GetStateIcon(status)" />
                        </div>
                        <div class="card-title-section">
                            <h3 class="card-title">@status.Name</h3>
                            <div class="card-subtitle">@GetTransportType(status)</div>
                        </div>
                        <Tag Color="@GetStateColor(status)">@GetDisplayState(status)</Tag>
                    </div>
                    <div class="item-card-body">
                        <div class="card-meta">
                            @if (status.Config != null)
                            {
                                @if (!string.IsNullOrEmpty(status.Config.Command))
                                {
                                    <div class="meta-item">
                                        <Icon Type="@IconType.Outline.Code" />
                                        <span class="meta-label">Command:</span>
                                        <span class="meta-value">@status.Config.Command</span>
                                    </div>
                                }
                                @if (status.Config.Args != null && status.Config.Args.Any())
                                {
                                    <div class="meta-item">
                                        <Icon Type="@IconType.Outline.ConsoleSql" />
                                        <span class="meta-label">Args:</span>
                                        <span class="meta-value">@(string.Join(" ", status.Config.Args))</span>
                                    </div>
                                }
                                @if (status.Config.Url != null)
                                {
                                    <div class="meta-item">
                                        <Icon Type="@IconType.Outline.Link" />
                                        <span class="meta-label">URL:</span>
                                        <span class="meta-value">@status.Config.Url.ToString()</span>
                                    </div>
                                }
                            }
                            <div class="meta-item">
                                <Icon Type="@IconType.Outline.Tool" />
                                <span class="meta-label">Tools:</span>
                                <span class="meta-value">@status.ToolCount</span>
                            </div>
                            @if (status.LastConnectedAt.HasValue)
                            {
                                <div class="meta-item">
                                    <Icon Type="@IconType.Outline.ClockCircle" />
                                    <span class="meta-label">Last connected:</span>
                                    <span class="meta-value">@status.LastConnectedAt.Value.ToLocalTime().ToString("HH:mm:ss")</span>
                                </div>
                            }
                        </div>
                    </div>
                    <div class="item-card-footer">
                        <div class="card-actions">
                            <Space Size="@SpaceSize.Small">
                                @if (!status.IsDisabled && status.State == McpConnectionState.Connected) {
                                    <SpaceItem><Button Size="@ButtonSize.Small" Icon="@IconType.Outline.PauseCircle" OnClick="@(() => PauseServer(status.Name))">Pause</Button></SpaceItem>
                                }
                                else if (!status.IsDisabled && status.State == McpConnectionState.Paused) {
                                    <SpaceItem><Button Size="@ButtonSize.Small" Icon="@IconType.Outline.PlayCircle" Type="@ButtonType.Primary" OnClick="@(() => ResumeServer(status.Name))">Resume</Button></SpaceItem>
                                }
                                else if (!status.IsDisabled && status.State == McpConnectionState.Error) {
                                    <SpaceItem><Button Size="@ButtonSize.Small" Icon="@IconType.Outline.Reload" Type="@ButtonType.Primary" OnClick="@(() => ReconnectServer(status.Name))">Reconnect</Button></SpaceItem>
                                }
                                else if (!status.IsDisabled && (status.State == McpConnectionState.Connecting || status.State == McpConnectionState.Reconnecting)) {
                                    <SpaceItem><Button Size="@ButtonSize.Small" Disabled><Spin Size="@SpinSize.Small" /> Connecting...</Button></SpaceItem>
                                }
                                @* Edit, Delete, Enable/Disable buttons *@
                                <SpaceItem>
                                    <Button Size="@ButtonSize.Small" 
                                            Type="@ButtonType.Text"
                                            Icon="@IconType.Outline.Edit"
                                            OnClick="@(() => EditServer(status.Name))">Edit</Button>
                                </SpaceItem>
                                <SpaceItem>
                                    <Button Size="@ButtonSize.Small" 
                                            Type="@ButtonType.Text"
                                            Icon="@IconType.Outline.Delete"
                                            Danger="true"
                                            OnClick="@(() => DeleteServer(status.Name))">Delete</Button>
                                </SpaceItem>
                                @if (status.IsDisabled)
                                {
                                    <SpaceItem>
                                        <Button Size="@ButtonSize.Small" 
                                                Type="@ButtonType.Primary"
                                                Icon="@IconType.Outline.PlayCircle"
                                                OnClick="@(() => EnableServer(status.Name))">Enable</Button>
                                    </SpaceItem>
                                }
                                else if (!status.IsDisabled && status.State != McpConnectionState.Connecting && status.State != McpConnectionState.Reconnecting)
                                {
                                    <SpaceItem>
                                        <Button Size="@ButtonSize.Small"
                                                Icon="@IconType.Outline.Stop"
                                                OnClick="@(() => DisableServer(status.Name))">Disable</Button>
                                    </SpaceItem>
                                }
                            </Space>
                        </div>
                        @if (status.LastError != null)
                        {
                            <Tooltip Title="@status.LastError.UserMessage">
                                <Icon Type="@IconType.Outline.InfoCircle" Style="color: var(--color-error); cursor: help;" />
                            </Tooltip>
                        }
                    </div>
                    @* Tool List *@
                    <div class="item-card-tools">
                        <McpToolList Tools="@McpStateService.GetServerTools(status.Name)" IsDisabled="@status.IsDisabled" />
                    </div>
                </div>
            }
            </div>
        }
    </div>
</div>

@* Add/Edit JSON Modal *@
<Modal @bind-Visible="_jsonEditorVisible" 
       Title="@(_editMode == "add" ? "Add MCP Server" : "Edit MCP Server")" 
       Width="800"
       OnOk="SaveJsonEdit"
       OkText="@("Save")"
       CancelText="@("Cancel")"
       ConfirmLoading="_saving">
    <Alert Type="@AlertType.Info" Message="Config Format" 
           Description="JSON must contain mcpServers object with server configurations." ShowIcon="true" />
    
    <div class="json-editor-container">
        <TextArea @bind-Value="_editingJson"
                  Rows="18"
                  Placeholder="@_jsonPlaceholder" />
    </div>
    
    <div class="config-path-info">
        <span>Save to:</span>
        <Select TItem="ConfigLevel" TItemValue="ConfigLevel" @bind-Value="_saveLevel" Style="width: 200px;">
            <SelectOption TItem="ConfigLevel" TItemValue="ConfigLevel" Value="@ConfigLevel.Project">Project Level</SelectOption>
            <SelectOption TItem="ConfigLevel" TItemValue="ConfigLevel" Value="@ConfigLevel.User">User Level</SelectOption>
        </Select>
        <Text Type="@TextElementType.Secondary">@McpStateService.GetConfigFilePath(_saveLevel)</Text>
    </div>
</Modal>

@code {
    private bool _isLoading = false;
    private Dictionary<string, McpServerStatus> _statuses = new();
    
    // Statistics
    private int _connectedCount => _statuses.Values.Count(s => s.IsAvailable);
    private int _errorCount => _statuses.Values.Count(s => !s.IsDisabled && s.State == McpConnectionState.Error);
    private int _pausedCount => _statuses.Values.Count(s => !s.IsDisabled && s.State == McpConnectionState.Paused);
    private int _disabledCount => _statuses.Values.Count(s => s.State == McpConnectionState.Disabled || s.IsDisabled);
    
    // JSON Editor Modal (统一用于 Add 和 Edit)
    private bool _jsonEditorVisible = false;
    private string _editMode = "";  // "add" or "edit"
    private string _editingJson = "";
    private string _editingServerName = "";
    private ConfigLevel _saveLevel = ConfigLevel.Project;
    private bool _saving = false;
    
    private readonly string _jsonPlaceholder = @"{
  ""mcpServers"": {
    ""server-name"": {
      ""type"": ""stdio"" | ""http"" | ""sse"",
      ""command"": ""npx"",           // stdio only
      ""args"": [""-y"", ""package""], // stdio only
      ""env"": { ""KEY"": ""value"" }, // stdio only, optional
      ""workingDirectory"": ""path"",  // stdio only, optional
      ""url"": ""https://..."",        // http/sse only
      ""headers"": { ""Auth"": ""Bearer token"" }, // http only, optional
      ""autoStart"": true,             // optional
      ""disabled"": false              // optional
    }
  }
}";
    
    private readonly string _jsonAddTemplate = @"{
  ""mcpServers"": {
    ""my-stdio-server"": {
      ""type"": ""stdio"",
      ""command"": ""npx"",
      ""args"": [""-y"", ""@modelcontextprotocol/server-filesystem"", ""/path/to/files""],
      ""env"": {
        ""NODE_ENV"": ""production"",
        ""API_KEY"": ""your-api-key""
      },
      ""workingDirectory"": ""/path/to/workdir""
    },
    ""my-http-server"": {
      ""type"": ""http"",
      ""url"": ""https://example.com/mcp"",
      ""headers"": {
        ""Authorization"": ""Bearer your-token"",
        ""X-Custom-Header"": ""custom-value""
      }
    }
  }
}";
    
    protected override void OnInitialized() {
        McpStateService.StateChanged += OnStateChanged;
        RefreshStatus();
    }
    
    void OnStateChanged(object? s, EventArgs e) => InvokeAsync(() => { RefreshStatus(); StateHasChanged(); });
    void RefreshStatus() => _statuses = McpManager.GetAllStatus().ToDictionary(x => x.Key, x => x.Value);
    
    void HandleRefresh() {
        _isLoading = true;
        StateHasChanged();
        Task.Run(async () => {
            await Task.Delay(100); // Brief delay for UX
            RefreshStatus();
            _isLoading = false;
            await InvokeAsync(StateHasChanged);
        });
    }
    
    void ShowAddModal() {
        _editMode = "add";
        _editingServerName = "";
        _editingJson = _jsonAddTemplate;
        _saveLevel = ConfigLevel.Project;
        _jsonEditorVisible = true;
    }
    
    void PauseServer(string name) { McpManager.PauseServer(name); }
    void ResumeServer(string name) { McpManager.ResumeServer(name); }
    async Task ReconnectServer(string name) => await McpManager.ReconnectServerAsync(name);
    
    string GetStateClass(McpServerStatus status) => status.State switch {
        McpConnectionState.Connected => "state-success",
        McpConnectionState.Error => "state-error",
        McpConnectionState.Paused => "state-warning",
        McpConnectionState.Disabled => "state-disabled-card",
        _ => ""
    };
    
    string GetStateColor(McpServerStatus status) => status.State switch {
        McpConnectionState.Connected => "success",
        McpConnectionState.Error => "error",
        McpConnectionState.Paused => "warning",
        McpConnectionState.Disabled => "default",
        McpConnectionState.Reconnecting => "processing",
        McpConnectionState.Connecting => "processing",
        _ => "default"
    };
    
    string GetStateIcon(McpServerStatus status) => status.State switch {
        McpConnectionState.Connected => IconType.Outline.CheckCircle,
        McpConnectionState.Error => IconType.Outline.CloseCircle,
        McpConnectionState.Paused => IconType.Outline.PauseCircle,
        McpConnectionState.Disabled => IconType.Outline.Stop,
        McpConnectionState.Connecting => IconType.Outline.Loading,
        McpConnectionState.Reconnecting => IconType.Outline.Sync,
        McpConnectionState.Pending => IconType.Outline.ClockCircle,
        _ => IconType.Outline.Api
    };
    
    string GetIconClass(McpServerStatus status) => status.State switch {
        McpConnectionState.Connected => "success",
        McpConnectionState.Error => "error",
        McpConnectionState.Paused => "warning",
        McpConnectionState.Disabled => "disabled",
        _ => ""
    };
    
    string GetDisplayState(McpServerStatus status) => status.State.ToString();
    
    string GetTransportType(McpServerStatus status) {
        if (status.Config == null) return "Unknown";
        return status.Config.TransportType switch {
            McpTransportType.Stdio => $"Stdio: {status.Config.Command ?? "N/A"}",
            McpTransportType.StreamableHttp => "HTTP",
            McpTransportType.Sse => "SSE",
            _ => "Unknown"
        };
    }
    
    void EditServer(string name)
    {
        var json = McpStateService.GetServerConfigAsJsonString(name);
        if (json != null)
        {
            _editMode = "edit";
            _editingServerName = name;
            _editingJson = json;
            _jsonEditorVisible = true;
        }
    }
    
    async Task SaveJsonEdit()
    {
        _saving = true;
        try
        {
            var imported = await McpManager.ImportFromJsonAsync(_editingJson, _saveLevel, overwrite: _editMode == "edit");
            if (imported > 0)
            {
                MessageService.Success(_editMode == "add" 
                    ? $"Successfully added {imported} MCP server(s)" 
                    : "Configuration saved and persisted successfully");
                RefreshStatus();
                // Modal 会自动关闭（@bind-Visible 会处理）
            }
            else
            {
                MessageService.Warning("No servers imported. Please check your JSON configuration.");
                // 保持 Modal 打开，让用户修正
                await Task.Delay(100); // 等待 UI 更新
                _jsonEditorVisible = true;
                StateHasChanged();
            }
        }
        catch (JsonException ex)
        {
            MessageService.Error($"JSON format error: {ex.Message}");
            // 保持 Modal 打开
            await Task.Delay(100);
            _jsonEditorVisible = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            MessageService.Error($"Save failed: {ex.Message}");
            await Task.Delay(100);
            _jsonEditorVisible = true;
            StateHasChanged();
        }
        finally
        {
            _saving = false;
        }
    }
    
    async Task DeleteServer(string name)
    {
        var result = await McpManager.RemoveServerAsync(name);
        if (result.Success)
        {
            MessageService.Success("Server deleted");
            RefreshStatus();
        }
        else
        {
            MessageService.Error($"Delete failed: {result.Error?.UserMessage}");
        }
    }
    
    async Task EnableServer(string name)
    {
        var result = await McpManager.EnableServerAsync(name);
        if (result.Success)
        {
            MessageService.Success("Server enabled");
            RefreshStatus();
        }
        else
        {
            MessageService.Error($"Enable failed: {result.Error?.UserMessage}");
        }
    }
    
    async Task DisableServer(string name)
    {
        var result = await McpManager.DisableServerAsync(name);
        if (result.Success)
        {
            MessageService.Success("Server disabled");
            RefreshStatus();
        }
        else
        {
            MessageService.Error($"Disable failed: {result.Error?.UserMessage}");
        }
    }
    
    public void Dispose() => McpStateService.StateChanged -= OnStateChanged;
}
