{
  "WeCom": {
    "Enabled": true,
    "BotId": "${WECOM_BOT_ID}",
    "Secret": "${WECOM_SECRET}",
    "WsUrl": "wss://openws.work.weixin.qq.com",
    "ShareSessionInGroup": true,
    "SessionIdleTimeoutMinutes": 30,
    "ResetOnEnterChatWhenIdle": true,
    "AppendCommandHintsToWelcome": true,
    "MaxReconnectAttempts": -1,
    "StreamingEnabled": true,
    "WelcomeText": "\u4F60\u597D\uFF01\u6211\u662F\u4F60\u7684\u52A9\u624B\uFF0C\u6709\u4EC0\u4E48\u53EF\u4EE5\u5E2E\u4F60\u7684\uFF1F",
    "HeartbeatIntervalSeconds": 30,
    "EffectiveHeartbeatIntervalSeconds": 30,
    "DeltaThrottleMilliseconds": 150,
    "EffectiveDeltaThrottleMilliseconds": 150,
    "ProcessingRefreshSeconds": 20,
    "ProcessingMaxDurationSeconds": 1800,
    "EffectiveProcessingRefreshSeconds": 20,
    "EffectiveProcessingMaxDurationSeconds": 1800,
    "AutoApproveLowRisk": true,
    "PromptRiskLevels": [
      "medium",
      "high",
      "critical"
    ],
    "PromptPermissionKinds": [
      "shell",
      "file",
      "mcp_tool"
    ],
    "AllowEventKeys": [
      "allow",
      "approve",
      "confirm"
    ],
    "DenyEventKeys": [
      "deny",
      "reject",
      "false_alarm"
    ],
    "MaxMediaBytes": 0,
    "PermissionCardTtlSeconds": 600,
    "EffectivePermissionCardTtlSeconds": 600
  },
  "Gateway": {
    "BaseUrl": "http://127.0.0.1:8765",
    "Transport": "WebSocket",
    "WebSocketPath": "/api/gateway/ws"
  },
  "Agent": "acp-cursor",
  "Model": "Auto",
  "Mode": "Ask"
}