{
  "WeCom": {
    "Enabled": true,
    "BotId": "${WECOM_BOT_ID}",
    "Secret": "${WECOM_SECRET}",
    "WsUrl": "wss://openws.work.weixin.qq.com",
    "ShareSessionInGroup": true,
    "SessionIdleTimeoutMinutes": 30,
    "ResetOnEnterChatWhenIdle": true,
    "AppendCommandHintsToWelcome": true,
    "MaxReconnectAttempts": 0,
    "StreamingEnabled": true,
    "WelcomeText": "\u4F60\u597D\uFF01\u6211\u662F Seeing Agent\uFF0C\u6709\u4EC0\u4E48\u53EF\u4EE5\u5E2E\u4F60\u7684\uFF1F",
    "HeartbeatIntervalSeconds": 0,
    "DeltaThrottleMilliseconds": 0,
    "ProcessingRefreshSeconds": 0,
    "ProcessingMaxDurationSeconds": 0,
    "AutoApproveLowRisk": false,
    "PromptRiskLevels": [
      "high",
      "critical"
    ],
    "PromptPermissionKinds": [
      "shell",
      "file",
      "mcp_tool"
    ],
    "AllowEventKeys": [
      "allow",
      "approve",
      "confirm"
    ],
    "DenyEventKeys": [
      "deny",
      "reject",
      "false_alarm"
    ],
    "MaxMediaBytes": 0,
    "PermissionCardTtlSeconds": 0
  },
  "Gateway": {
    "BaseUrl": "http://127.0.0.1:8765",
    "Transport": "WebSocket",
    "WebSocketPath": "/api/gateway/ws"
  },
  "Agent": "plan"
}