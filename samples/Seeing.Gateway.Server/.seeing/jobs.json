{
  "jobs": [
    {
      "id": "daily-check",
      "name": "每日检查",
      "enabled": true,
      "taskType": "agent",
      "agent": "default",
      "prompt": "检查待办事项并简要汇报",
      "schedule": {
        "type": "cron",
        "cron": "0 9 * * *",
        "timezone": "Asia/Shanghai"
      },
      "dispatch": {
        "target": {
          "sessionId": "main"
        }
      },
      "runtime": {
        "timeoutSeconds": 120,
        "misfireGraceSeconds": 300
      }
    },
    {
      "id": "hourly-reminder",
      "name": "每小时提醒",
      "enabled": false,
      "taskType": "text",
      "text": "记得休息一下",
      "schedule": {
        "type": "interval",
        "every": "1h"
      },
      "dispatch": {
        "target": {
          "sessionId": "main"
        }
      }
    }
  ]
}
