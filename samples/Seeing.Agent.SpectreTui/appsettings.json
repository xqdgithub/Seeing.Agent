{
  "SeeingAgent": {
    "DefaultModel": "gpt-4o",
    "DefaultAgent": "primary",
    "Providers": {
      "openai": {
        "BaseUrl": "https://api.openai.com/v1",
        "Timeout": 60,
        "MaxRetries": 3
      }
    },
    "Agents": {
      "primary": {
        "Model": "gpt-4o",
        "SystemPrompt": "你是一个有帮助的助手。",
        "MaxSteps": 50,
        "Mode": "Primary"
      }
    },
    "Skills": {
      "Paths": ["./.seeing/skills", "./.agents/skills"]
    },
    "Permission": {
      "AutoApproveAll": false
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  }
}
